<%- include("partials/header") %>
<%
  const safeMetrics = typeof metrics === "object" && metrics ? metrics : {};
  const rawMovementLogs = typeof movementLogs !== "undefined" ? movementLogs : [];
  const safeMovementLogs = Array.isArray(rawMovementLogs) ? rawMovementLogs : [];
  const rawInsideVehicles = typeof insideVehicles !== "undefined" ? insideVehicles : [];
  const safeInsideVehicles = Array.isArray(rawInsideVehicles) ? rawInsideVehicles : [];
%>

<section class="cards">
  <article class="card">
    <h3>Total Students</h3>
    <p><%= safeMetrics.students || 0 %></p>
  </article>
  <article class="card">
    <h3>Registered Vehicles</h3>
    <p><%= safeMetrics.vehicles || 0 %></p>
  </article>
  <article class="card">
    <h3>Active Stickers</h3>
    <p><%= safeMetrics.activeStickers || 0 %></p>
  </article>
  <article class="card">
    <h3>Today's Entries</h3>
    <p><%= safeMetrics.todayEntries || 0 %></p>
  </article>
  <article class="card">
    <h3>Today's Exits</h3>
    <p><%= safeMetrics.todayExits || 0 %></p>
  </article>
  <article class="card">
    <h3>Currently Inside</h3>
    <p><%= safeMetrics.currentlyInside || 0 %></p>
  </article>
</section>

<section class="panel">
  <div class="section-head">
    <h2>Currently Inside Vehicles</h2>
    <p>Live roster of vehicles currently inside campus based on latest valid movement.</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Student Name</th>
          <th>Plate</th>
          <th>Sticker</th>
          <th>Entry Gate</th>
          <th>Entered At</th>
          <th>Minutes Inside</th>
        </tr>
      </thead>
      <tbody>
        <% if (safeInsideVehicles.length === 0) { %>
          <tr>
            <td colspan="7">No active vehicles inside.</td>
          </tr>
        <% } %>
        <% safeInsideVehicles.forEach(item => { %>
          <tr>
            <td><%= item.student_number || "-" %></td>
            <td><%= item.full_name || "-" %></td>
            <td><%= item.plate_number || "-" %></td>
            <td><%= item.sticker_code || "-" %></td>
            <td><%= item.entry_gate || "-" %></td>
            <td><%= new Date(item.entered_at).toLocaleString() %></td>
            <td><%= Number(item.minutes_inside || 0) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <div class="section-head">
      <h2>Student Gate Entry and Exit Records</h2>
      <p>Latest verified movements captured from campus gates.</p>
    </div>
    <div class="table-tools">
      <label for="movementSearch" class="sr-only">Search student name or plate</label>
      <input
        id="movementSearch"
        type="search"
        placeholder="Search by student name, plate, student number, or sticker..."
      />
      <div class="table-tools-right">
        <div class="table-chip-group">
          <span class="table-chip active">Activity Center</span>
          <span class="table-chip">Entry Gate</span>
          <span class="table-chip">Activity Gates</span>
        </div>
        <p id="movementSearchCount" class="helper-text">Showing <%= safeMovementLogs.length %> records</p>
      </div>
    </div>
    <div class="table-wrap">
      <table id="movementTable">
      <thead>
        <tr>
          <th>Date/Time</th>
          <th>Student Number</th>
          <th>Student Name</th>
          <th>Plate</th>
          <th>Sticker</th>
          <th>Result</th>
          <th>Movement</th>
          <th>Gate</th>
        </tr>
      </thead>
      <tbody>
        <% if (safeMovementLogs.length === 0) { %>
          <tr>
            <td colspan="8">No scan records yet.</td>
          </tr>
        <% } %>
        <% safeMovementLogs.forEach(scan => { %>
          <tr>
            <td><%= new Date(scan.scanned_at).toLocaleString() %></td>
            <td><%= scan.student_number || "-" %></td>
            <td><%= scan.full_name || "-" %></td>
            <td><%= scan.plate_number || "-" %></td>
            <td><%= scan.sticker_code || "-" %></td>
            <td><span class="badge badge-<%= (scan.result || "INVALID").toLowerCase() %>"><%= scan.result || "-" %></span></td>
            <td><span class="badge badge-action"><%= scan.action || "-" %></span></td>
            <td><%= scan.gate || "-" %></td>
          </tr>
        <% }) %>
      </tbody>
      </table>
    </div>
    <div class="dashboard-foot-widgets">
      <article class="mini-widget">
        <h3>Vehicle & Sticker Snapshot</h3>
        <div class="mini-widget-grid">
          <div class="mini-widget-item">
            <strong><%= safeMetrics.vehicles || 0 %></strong>
            <span>Registered Vehicles</span>
          </div>
          <div class="mini-widget-item">
            <strong><%= safeMetrics.activeStickers || 0 %></strong>
            <span>Active Stickers</span>
          </div>
          <div class="mini-widget-item">
            <strong><%= safeMetrics.currentlyInside || 0 %></strong>
            <span>Currently Inside</span>
          </div>
        </div>
      </article>
      <article class="mini-widget">
        <h3>Operations Health</h3>
        <p class="helper-text">Scanner, verification, and movement logging are active.</p>
        <div class="health-row">
          <span class="health-dot"></span>
          <strong>System Healthy</strong>
        </div>
      </article>
    </div>
  </article>

  <article class="panel">
    <div class="section-head">
      <h2>Latest Updates</h2>
      <p>Most recent gate activity snapshots.</p>
    </div>
    <div class="updates-list">
      <% if (safeMovementLogs.length === 0) { %>
        <p class="helper-text">No updates yet.</p>
      <% } %>
      <% safeMovementLogs.slice(0, 8).forEach(scan => { %>
        <div class="update-item">
          <span class="update-dot <%= (scan.result || 'invalid').toLowerCase() %> <%= (scan.action || 'verify').toLowerCase() %>"></span>
          <div>
            <p>
              <strong><%= scan.full_name || "Unknown Student" %></strong>
              <span class="update-action <%= (scan.action || 'verify').toLowerCase() %>"><%= scan.action || "VERIFY" %></span>
            </p>
            <p class="helper-text"><%= scan.gate || "Main Gate" %> - <%= new Date(scan.scanned_at).toLocaleString() %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </article>
</section>

<script>
  (() => {
    const searchInput = document.getElementById("movementSearch");
    const table = document.getElementById("movementTable");
    const countLabel = document.getElementById("movementSearchCount");
    if (!searchInput || !table || !countLabel) return;

    const rows = Array.from(table.querySelectorAll("tbody tr"));
    const emptyRow = rows.find((row) => row.children.length === 1);
    const dataRows = rows.filter((row) => row.children.length > 1);

    function updateFilter() {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      dataRows.forEach((row) => {
        const rowText = row.textContent.toLowerCase();
        const visible = !query || rowText.includes(query);
        row.style.display = visible ? "" : "none";
        if (visible) visibleCount += 1;
      });

      if (emptyRow) {
        emptyRow.style.display = dataRows.length === 0 ? "" : "none";
      }

      countLabel.textContent = query
        ? `Showing ${visibleCount} matching records`
        : `Showing ${dataRows.length} records`;
    }

    searchInput.addEventListener("input", updateFilter);
    updateFilter();
  })();
</script>

<%- include("partials/footer") %>
