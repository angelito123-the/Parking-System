<%- include("partials/header") %>
  <%
    const safeMetrics = typeof metrics === "object" && metrics ? metrics : {};
    const rawMovementLogs = typeof movementLogs !== "undefined" ? movementLogs : [];
    const safeMovementLogs = Array.isArray(rawMovementLogs) ? rawMovementLogs : [];
    const rawInsideVehicles = typeof insideVehicles !== "undefined" ? insideVehicles : [];
    const safeInsideVehicles = Array.isArray(rawInsideVehicles) ? rawInsideVehicles : [];
    const rawParkingSlots = typeof parkingSlots !== "undefined" ? parkingSlots : [];
    const safeParkingSlots = Array.isArray(rawParkingSlots) ? rawParkingSlots : [];
    const rawOverstayAlerts = typeof overstayAlerts !== "undefined" ? overstayAlerts : [];
    const safeOverstayAlerts = Array.isArray(rawOverstayAlerts) ? rawOverstayAlerts : [];
    const safeOverstayLimitHours = Number(
      typeof overstayLimitHours !== "undefined"
        ? overstayLimitHours
        : (safeMetrics.overstayLimitHours || 4)
    ) || 4;
    const safeOverstayLimitLabel = Number.isInteger(safeOverstayLimitHours)
      ? `${safeOverstayLimitHours}`
      : safeOverstayLimitHours.toFixed(1).replace(/\.0$/, "");
    const safeParkingSlotSummary = typeof parkingSlotSummary === "object" && parkingSlotSummary ? parkingSlotSummary : {
      total: safeParkingSlots.length,
      available: safeParkingSlots.filter(slot => slot.occupancy === "available").length,
      occupied: safeParkingSlots.filter(slot => slot.occupancy === "occupied").length,
      disabled: safeParkingSlots.filter(slot => slot.occupancy === "disabled").length
    };
  %>
    <section class="dashboard-hero">
      <div class="hero-greeting">
        <h2>Welcome Back,</h2>
        <h1>NAAP Guard</h1>
      </div>
      <div class="hero-cards">
        <div class="hero-card">
          <h3>Total Students</h3>
          <p><%= safeMetrics.students || 0 %></p>
        </div>
        <div class="hero-card">
          <h3>Registered Vehicles</h3>
          <p><%= safeMetrics.vehicles || 0 %></p>
        </div>
        <div class="hero-card">
          <h3>Active Stickers</h3>
          <p id="activeStickersCount"><%= safeMetrics.activeStickers || 0 %></p>
        </div>
        <div class="hero-card" style="background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.4);">
          <h3>Currently Inside</h3>
          <p id="currentlyInsideCount"><%= safeMetrics.currentlyInside || 0 %></p>
        </div>
        <div class="hero-card" style="background: rgba(190, 18, 60, 0.2); border: 1px solid rgba(251, 113, 133, 0.4);">
          <h3>Overstay Alerts</h3>
          <p id="overstayAlertCount"><%= safeMetrics.overstayAlerts || safeOverstayAlerts.length || 0 %></p>
        </div>
      </div>
    </section>

    <div class="overlap-wrapper">
      <section class="panel" style="border:none; box-shadow:none; padding:0; margin-bottom: 2.5rem; background: transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Overview of Inside Vehicles</h2>
          <p>Live roster of vehicles currently inside campus.</p>
        </div>
        <div class="refresh-row" style="margin-bottom: 0.75rem;">
          <span id="insideLastUpdated" class="helper-text">Loading...</span>
          <button type="button" class="refresh-btn btn-sm" id="refreshInsideBtn" style="background: var(--surface-soft); color: var(--text); border: 1px solid var(--line);">↻ Refresh</button>
        </div>
        <div id="overstayNotice" class="flash flash-error overstay-notice" style="display:none; margin-bottom:0.85rem;"></div>
        <div class="overstay-panel" style="margin-bottom: 1rem;">
          <div class="overstay-panel-head">
            <strong>Overstay Watch</strong>
            <span id="overstayLimitMeta" class="helper-text">Limit: <%= safeOverstayLimitLabel %> hour(s)</span>
          </div>
          <div id="overstayAlertList" class="overstay-alert-list">
            <% if (safeOverstayAlerts.length === 0) { %>
              <div class="overstay-empty">No active overstay alerts.</div>
            <% } %>
            <% safeOverstayAlerts.forEach(item => { %>
              <div class="overstay-alert-item" data-sticker-id="<%= item.sticker_id %>">
                <div class="overstay-alert-main">
                  <p class="overstay-alert-title">
                    <strong><%= item.full_name || "Unknown Student" %></strong>
                    <span><%= item.plate_number || "-" %></span>
                    <span><%= item.parking_slot || "-" %></span>
                  </p>
                  <p class="helper-text">
                    Entered <%= new Date(item.entered_at).toLocaleString('en-US', { timeZone: 'Asia/Manila' }) %>
                    | Stayed <strong><%= item.duration_label || "-" %></strong>
                    <% if (item.overstay_label) { %>
                      (<%= item.overstay_label %>)
                    <% } %>
                  </p>
                </div>
                <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit</button>
              </div>
            <% }) %>
          </div>
        </div>
        <div class="table-wrap desktop-only-table">
          <table>
            <thead>
              <tr>
                <th>Student No.</th>
                <th>Name</th>
                <th>Plate</th>
                <th>Sticker</th>
                <th>Slot</th>
                <th>Gate</th>
                <th>Duration</th>
                <th>Status</th>
                <th style="text-align: right; padding-right: 1.5rem;">Action</th>
              </tr>
            </thead>
            <tbody id="insideVehiclesBody">
              <% if (safeInsideVehicles.length === 0) { %>
                <tr id="insideEmptyRow" style="box-shadow: none;">
                  <td colspan="9" style="background: transparent; border: none;">
                    <div class="empty-state">
                      <div class="empty-state-icon">🚗</div>
                      <p>No vehicles currently inside campus.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              <% safeInsideVehicles.forEach(item => { %>
                <tr class="<%= item.is_overstay ? 'inside-row-overstay' : '' %>">
                  <td><strong><%= item.student_number || "-" %></strong></td>
                  <td><%= item.full_name || "-" %></td>
                  <td><span class="badge" style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1;"><%= item.plate_number || "-" %></span></td>
                  <td><span class="badge badge-active"><%= item.sticker_code || "-" %></span></td>
                  <td><%= item.parking_slot || "-" %></td>
                  <td><%= item.entry_gate || "-" %></td>
                  <td><%= item.duration_label || "-" %></td>
                  <td>
                    <% if (item.is_overstay) { %>
                      <span class="badge badge-overstay">Overstay</span>
                    <% } else { %>
                      <span class="badge badge-inside">Inside</span>
                    <% } %>
                  </td>
                  <td style="text-align: right;">
                    <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit</button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Mobile-Ready Cards for Inside Vehicles -->
        <div class="mobile-data-list" id="insideVehiclesCards">
          <% if (safeInsideVehicles.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🚗</div>
              <p>No vehicles inside campus.</p>
            </div>
          <% } %>
          <% safeInsideVehicles.forEach(item => { %>
            <div class="mobile-data-card <%= item.is_overstay ? 'overstay-card' : '' %>" data-sticker-id="<%= item.sticker_id %>">
              <div class="card-header">
                <div class="card-title"><%= item.full_name || "Unknown" %></div>
                <% if (item.is_overstay) { %>
                  <span class="badge badge-overstay">Overstay</span>
                <% } else { %>
                  <span class="badge badge-inside">Inside</span>
                <% } %>
              </div>
              <div class="card-body">
                <div class="card-item">Plate: <strong><%= item.plate_number || "-" %></strong></div>
                <div class="card-item">Slot: <strong><%= item.parking_slot || "-" %></strong></div>
                <div class="card-item">Gate: <strong><%= item.entry_gate || "-" %></strong></div>
                <div class="card-item">In: <strong><%= new Date(item.entered_at).toLocaleTimeString() %></strong></div>
                <div class="card-item">Duration: <strong><%= item.duration_label || "-" %></strong></div>
                <% if (item.overstay_label) { %>
                  <div class="card-item overstay-card-alert"><strong>Alert:</strong> <%= item.overstay_label %></div>
                <% } %>
              </div>
              <div class="card-actions">
                <button type="button" class="danger btn-mobile-touch force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit Vehicle</button>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

      <section class="panel" style="border:none; box-shadow:none; padding:0; margin-bottom: 2rem; background: transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Parking Slot Monitoring</h2>
          <p>See exactly which vehicle is parked in each occupied slot. Click any slot to view its history.</p>
        </div>
        <div class="refresh-row" style="margin-bottom: 0.75rem;">
          <span id="parkingSlotsMeta" class="helper-text">
            <%= safeParkingSlotSummary.available %> available | <%= safeParkingSlotSummary.occupied %> occupied | <%= safeParkingSlotSummary.disabled %> disabled | <%= safeParkingSlotSummary.total %> total
          </span>
        </div>
        <div id="parkingSlotsList" class="parking-slots-grid">
          <% if (safeParkingSlots.length === 0) { %>
            <div class="empty-state" style="padding:1.25rem 1rem;">
              <p>No parking slots configured.</p>
            </div>
          <% } %>
          <% safeParkingSlots.forEach(slot => { %>
            <div
              class="parking-slot-card <%= slot.occupancy || 'available' %>"
              data-slot-code="<%= slot.slot_code || '' %>"
              role="button"
              tabindex="0"
              aria-label="View history for slot <%= slot.slot_code || '' %>">
              <div class="parking-slot-head">
                <span class="parking-slot-code"><%= slot.slot_code || "-" %></span>
                <span class="parking-slot-status"><%= (slot.occupancy || "available").toUpperCase() %></span>
              </div>
              <div class="parking-slot-zone"><%= slot.zone || "General" %></div>
              <% if (slot.occupancy === "occupied") { %>
                <div class="parking-slot-detail">Plate: <strong><%= slot.occupied_by_plate || "-" %></strong></div>
                <div class="parking-slot-detail">Student: <strong><%= slot.occupied_by_name || "Unknown" %></strong></div>
              <% } else if (slot.occupancy === "available") { %>
                <div class="parking-slot-detail">Open for entry assignment</div>
              <% } else { %>
                <div class="parking-slot-detail">Slot currently unavailable</div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>

      <div id="slotHistoryModal" class="slot-history-modal" aria-hidden="true">
        <div class="slot-history-backdrop" data-close-slot-history></div>
        <div class="slot-history-dialog" role="dialog" aria-modal="true" aria-labelledby="slotHistoryTitle">
          <div class="slot-history-head">
            <h3 id="slotHistoryTitle">Slot History</h3>
            <button type="button" class="slot-history-close" data-close-slot-history aria-label="Close slot history">x</button>
          </div>
          <p id="slotHistoryMeta" class="helper-text" style="margin:0 0 0.75rem;">Loading slot history...</p>
          <div id="slotHistoryList" class="slot-history-list">
            <div class="empty-state" style="padding:1rem;"><p>Loading slot history...</p></div>
          </div>
        </div>
      </div>

    <section class="dashboard-grid">
      <article class="panel">
        <div class="section-head">
          <h2>Student Gate Entry and Exit Records</h2>
          <p>Latest verified movements captured from campus gates.</p>
        </div>
        <div class="table-tools">
          <label for="movementSearch" class="sr-only">Search student name or plate</label>
          <input id="movementSearch" type="search"
            placeholder="Search by name, plate, or student number..." />
          <p id="movementSearchCount" class="helper-text">Showing <%= safeMovementLogs.length %> records</p>
        </div>
        <div class="table-wrap desktop-only-table">
          <table id="movementTable">
            <thead>
              <tr>
                <th>Date/Time</th>
                <th>Student</th>
                <th>Plate</th>
                <th>Sticker</th>
                <th>Result</th>
                <th>Movement</th>
                <th>Gate</th>
              </tr>
            </thead>
            <tbody>
              <% if (safeMovementLogs.length===0) { %>
                <tr id="movementEmptyRow" style="box-shadow: none;">
                  <td colspan="7" style="background: transparent; border: none;">
                    <div class="empty-state">
                      <div class="empty-state-icon">📋</div>
                      <p>No scan records yet.</p>
                    </div>
                  </td>
                </tr>
                <% } %>
                  <% safeMovementLogs.forEach(scan=> { %>
                    <tr class="movement-row">
                      <td style="color:var(--muted); font-size:0.8rem;">
                        <%= new Date(scan.scanned_at).toLocaleString('en-US', { hour: 'numeric', minute: 'numeric' }) %>
                      </td>
                      <td>
                        <strong><%= scan.student_number || "-" %></strong><br><small><%= scan.full_name || "" %></small>
                      </td>
                      <td>
                        <%= scan.plate_number || "-" %>
                      </td>
                      <td>
                        <%= scan.sticker_code || "-" %>
                      </td>
                      <td><span class="badge badge-<%= (scan.result || " INVALID").toLowerCase() %>"><%= scan.result %></span></td>
                      <td><span class="badge badge-<%= (scan.action || " ").toLowerCase() %>"><%= scan.action %></span></td>
                      <td>
                        <%= scan.gate_name || "-" %>
                      </td>
                    </tr>
                    <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Mobile-Ready Cards for Movement Logs -->
        <div class="mobile-data-list" id="movementCards">
          <% if (safeMovementLogs.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">📋</div>
              <p>No scan records yet.</p>
            </div>
          <% } %>
          <% safeMovementLogs.forEach(scan => { %>
            <div class="mobile-data-card" data-searchable="<%= (scan.full_name || '').toLowerCase() %> <%= (scan.plate_number || '').toLowerCase() %> <%= (scan.student_number || '').toLowerCase() %>">
              <div class="card-header">
                <div class="card-title text-truncate" style="max-width: 60%;"><%= scan.full_name || "Guest" %></div>
                <span class="badge badge-<%= (scan.action || ' ').toLowerCase() %>"><%= scan.action %></span>
              </div>
              <div class="card-body">
                <div class="card-item">🚗 <strong>Plate:</strong> <%= scan.plate_number || "-" %></div>
                <div class="card-item">🪪 <strong>Sticker:</strong> <%= scan.sticker_code || "-" %></div>
                <div class="card-item">🛡️ <strong>Status:</strong> <span class="badge badge-<%= (scan.result || 'INVALID').toLowerCase() %>"><%= scan.result %></span></div>
                <div class="card-item">📅 <strong>Time:</strong> <%= new Date(scan.scanned_at).toLocaleTimeString() %></div>
              </div>
            </div>
          <% }) %>
        </div>
      </article>

      <article class="panel">
        <div class="section-head">
          <h2>Latest Updates</h2>
          <p>Recent gate activity snapshots.</p>
        </div>
        <div class="updates-list">
          <% if (safeMovementLogs.length===0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🔔</div>
              <p>No updates yet.</p>
            </div>
            <% } %>
              <% safeMovementLogs.slice(0, 8).forEach(scan=> { %>
                <div class="update-item">
                  <span
                    class="update-dot <%= (scan.result || 'invalid').toLowerCase() %> <%= (scan.action || 'verify').toLowerCase() %>"></span>
                  <div>
                    <p>
                      <strong>
                        <%= scan.full_name || "Unknown Student" %>
                      </strong>
                      <span class="update-action <%= (scan.action || 'verify').toLowerCase() %>">
                        <%= scan.action || "VERIFY" %>
                      </span>
                    </p>
                    <p class="helper-text">
                      <%= scan.gate_name || "Main Gate" %> — <%= new Date(scan.scanned_at).toLocaleTimeString() %>
                    </p>
                  </div>
                </div>
                <% }) %>
        </div>
      </article>
    </section>

    <script>
      (() => {
        const searchInput = document.getElementById("movementSearch");
        const table = document.getElementById("movementTable");
        const countLabel = document.getElementById("movementSearchCount");

        function applySearch() {
          if (!searchInput || !table || !countLabel) return;
          const q = searchInput.value.trim().toLowerCase();
          const rows = Array.from(table.querySelectorAll("tbody tr")).filter(r => r.id !== 'movementEmptyRow');
          let tableVisible = 0;
          rows.forEach(row => {
            const match = !q || row.textContent.toLowerCase().includes(q);
            row.style.display = match ? "" : "none";
            if (match) tableVisible++;
          });
          
          const cardsList = document.getElementById("movementCards");
          const cardItems = cardsList ? Array.from(cardsList.querySelectorAll(".mobile-data-card")) : [];
          const emptyCardState = cardsList ? cardsList.querySelector(".empty-state") : null;
          let cardsVisible = 0;
          
          cardItems.forEach(card => {
            const searchable = card.dataset.searchable.toLowerCase();
            const match = !q || searchable.includes(q);
            card.style.display = match ? "flex" : "none";
            if (match) cardsVisible++;
          });

          if (emptyCardState) emptyCardState.style.display = (cardsVisible === 0 && cardItems.length > 0) ? "block" : "none";
          countLabel.textContent = q ? `Found ${tableVisible || cardsVisible} records` : `Showing ${rows.length || cardItems.length} records`;
        }
        if (searchInput) searchInput.addEventListener("input", applySearch);

        function toPHT(dateStr) {
          return new Date(dateStr).toLocaleString('en-US', { timeZone: 'Asia/Manila' });
        }

        const insideBody = document.getElementById("insideVehiclesBody");
        const insideCount = document.getElementById("currentlyInsideCount");
        const lastUpdatedEl = document.getElementById("insideLastUpdated");
        const refreshBtn = document.getElementById("refreshInsideBtn");
        const parkingSlotsMetaEl = document.getElementById("parkingSlotsMeta");
        const parkingSlotsListEl = document.getElementById("parkingSlotsList");
        const slotHistoryModal = document.getElementById("slotHistoryModal");
        const slotHistoryTitle = document.getElementById("slotHistoryTitle");
        const slotHistoryMeta = document.getElementById("slotHistoryMeta");
        const slotHistoryList = document.getElementById("slotHistoryList");
        const overstayCountEl = document.getElementById("overstayAlertCount");
        const overstayListEl = document.getElementById("overstayAlertList");
        const overstayLimitMetaEl = document.getElementById("overstayLimitMeta");
        const overstayNoticeEl = document.getElementById("overstayNotice");
        const overstayLimitHours = Number(<%- JSON.stringify(safeOverstayLimitHours) %>) || 4;
        const overstayLimitLabel = Number.isInteger(overstayLimitHours)
          ? `${overstayLimitHours}`
          : overstayLimitHours.toFixed(1).replace(/\.0$/, "");
        const seenOverstayIds = new Set(
          <%- JSON.stringify(safeOverstayAlerts.map((item) => String(item.sticker_id || "")).filter(Boolean)) %>
        );
        let overstayNoticeTimer = null;
        if (slotHistoryModal && slotHistoryModal.parentElement !== document.body) {
          document.body.appendChild(slotHistoryModal);
        }

        window.forceExit = async function(stickerId, btn) {
          if (!confirm("Force exit this vehicle?")) return;
          btn.disabled = true;
          btn.textContent = "...";
          try {
            const res = await fetch("/api/force-exit", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ sticker_id: stickerId })
            });
            const data = await res.json();
            if (data.ok) refreshDashboard();
            else { alert(data.message); btn.disabled = false; btn.textContent = "Force Exit"; }
          } catch (e) { alert("Error"); btn.disabled = false; btn.textContent = "Force Exit"; }
        };

        function getDurationLabel(item) {
          if (item && item.duration_label) return item.duration_label;
          const minutes = Math.max(0, Number(item?.minutes_inside) || 0);
          const days = Math.floor(minutes / 1440);
          const hours = Math.floor((minutes % 1440) / 60);
          const mins = minutes % 60;
          const parts = [];
          if (days > 0) parts.push(`${days}d`);
          if (hours > 0 || days > 0) parts.push(`${hours}h`);
          parts.push(`${mins}m`);
          return parts.join(" ");
        }

        function getOverstayText(item) {
          if (!item || !item.is_overstay) return "";
          if (item.overstay_label) return item.overstay_label;
          const overstayMinutes = Math.max(0, Number(item.overstay_minutes) || 0);
          if (!overstayMinutes) return "Over limit";
          return `+${getDurationLabel({ minutes_inside: overstayMinutes })} over limit`;
        }

        function renderInsideRow(item) {
          const duration = getDurationLabel(item);
          const overstayLabel = getOverstayText(item);
          const statusChip = item.is_overstay
            ? `<span class="badge badge-overstay">OVERSTAY</span>`
            : `<span class="badge badge-inside">INSIDE</span>`;
          return `<tr class="${item.is_overstay ? "inside-row-overstay" : ""}">
        <td><strong>${item.student_number || "-"}</strong></td>
        <td>${item.full_name || "-"}</td>
        <td><span class="badge" style="background:#f1f5f9; color:#334155; border:1px solid #cbd5e1;">${item.plate_number || "-"}</span></td>
        <td><span class="badge badge-active">${item.sticker_code || "-"}</span></td>
        <td>${item.parking_slot || "-"}</td>
        <td>${item.entry_gate || "-"}</td>
        <td>${duration}</td>
        <td>${statusChip}${overstayLabel ? `<div class="table-alert-sub">${overstayLabel}</div>` : ""}</td>
        <td style="text-align:right;"><button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit</button></td>
      </tr>`;
        }

        function renderInsideCard(item) {
          const duration = getDurationLabel(item);
          const overstayLabel = getOverstayText(item);
          return `<div class="mobile-data-card ${item.is_overstay ? "overstay-card" : ""}" data-sticker-id="${item.sticker_id}">
            <div class="card-header"><div class="card-title">${item.full_name || "Unknown"}</div>${item.is_overstay ? `<span class="badge badge-overstay">OVERSTAY</span>` : `<span class="badge badge-inside">INSIDE</span>`}</div>
            <div class="card-body">
              <div class="card-item">Plate: <strong>${item.plate_number || "-"}</strong></div>
              <div class="card-item">Slot: <strong>${item.parking_slot || "-"}</strong></div>
              <div class="card-item">Gate: <strong>${item.entry_gate || "-"}</strong></div>
              <div class="card-item">In: <strong>${item.entered_at ? new Date(item.entered_at).toLocaleTimeString() : "-"}</strong></div>
              <div class="card-item">Duration: <strong>${duration}</strong></div>
              ${overstayLabel ? `<div class="card-item overstay-card-alert"><strong>Alert:</strong> ${overstayLabel}</div>` : ""}
            </div>
            <div class="card-actions"><button type="button" class="danger btn-mobile-touch force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit Vehicle</button></div>
          </div>`;
        }

        function renderOverstayAlertItem(item) {
          return `<div class="overstay-alert-item" data-sticker-id="${item.sticker_id || ""}">
            <div class="overstay-alert-main">
              <p class="overstay-alert-title">
                <strong>${item.full_name || "Unknown Student"}</strong>
                <span>${item.plate_number || "-"}</span>
                <span>${item.parking_slot || "-"}</span>
              </p>
              <p class="helper-text">Entered ${item.entered_at ? toPHT(item.entered_at) : "-"} | Stayed <strong>${getDurationLabel(item)}</strong>${item.is_overstay ? ` (${getOverstayText(item)})` : ""}</p>
            </div>
            <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit</button>
          </div>`;
        }

        function renderEmptyOverstayAlerts() {
          return `<div class="overstay-empty">No active overstay alerts.</div>`;
        }

        function showOverstayNotice(message) {
          if (!overstayNoticeEl) return;
          overstayNoticeEl.textContent = message;
          overstayNoticeEl.style.display = "flex";
          if (overstayNoticeTimer) clearTimeout(overstayNoticeTimer);
          overstayNoticeTimer = setTimeout(() => {
            overstayNoticeEl.style.display = "none";
          }, 6500);
        }

        function syncOverstayAlerts(overstayRows) {
          if (overstayListEl) {
            overstayListEl.innerHTML = overstayRows.length
              ? overstayRows.map(renderOverstayAlertItem).join("")
              : renderEmptyOverstayAlerts();
          }

          const currentIds = new Set();
          const newlyOverstayed = [];
          overstayRows.forEach((row) => {
            const key = String(row.sticker_id || "");
            if (!key) return;
            currentIds.add(key);
            if (!seenOverstayIds.has(key)) newlyOverstayed.push(row);
          });
          seenOverstayIds.clear();
          currentIds.forEach((id) => seenOverstayIds.add(id));

          if (newlyOverstayed.length > 0) {
            const lead = newlyOverstayed[0];
            const names = newlyOverstayed.length === 1
              ? (lead.full_name || "A student")
              : `${newlyOverstayed.length} vehicles`;
            const message = `Overstay alert: ${names} exceeded the ${overstayLimitLabel}-hour limit.`;
            showOverstayNotice(message);
            if ("Notification" in window && Notification.permission === "granted") {
              try {
                new Notification("NAAP Parking Overstay Alert", { body: message });
              } catch (err) {
                console.warn("Browser notification failed:", err);
              }
            }
          }
        }

        function renderEmptyInside() {
          return `<div class="empty-state"><div class="empty-state-icon">🚗</div><p>No vehicles inside.</p></div>`;
        }
        function renderParkingSlotCard(slot) {
          const occupancy = slot.occupancy || "available";
          const status = occupancy.toUpperCase();
          const primaryDetail = occupancy === "occupied"
            ? `Plate: <strong>${slot.occupied_by_plate || "-"}</strong>`
            : occupancy === "available"
            ? "Open for entry assignment"
            : "Slot currently unavailable";
          const secondaryDetail = occupancy === "occupied"
            ? `Student: <strong>${slot.occupied_by_name || "Unknown"}</strong>`
            : "";
          return `<div class="parking-slot-card ${occupancy}" data-slot-code="${slot.slot_code || ""}" role="button" tabindex="0" aria-label="View history for slot ${slot.slot_code || ""}">
            <div class="parking-slot-head">
              <span class="parking-slot-code">${slot.slot_code || "-"}</span>
              <span class="parking-slot-status">${status}</span>
            </div>
            <div class="parking-slot-zone">${slot.zone || "General"}</div>
            <div class="parking-slot-detail">${primaryDetail}</div>
            ${secondaryDetail ? `<div class="parking-slot-detail">${secondaryDetail}</div>` : ""}
          </div>`;
        }

        function renderEmptyParkingSlots() {
          return `<div class="empty-state" style="padding:1.25rem 1rem;"><p>No parking slots configured.</p></div>`;
        }

        const movementTbody = table ? table.querySelector("tbody") : null;
        const movementCards = document.getElementById("movementCards");
        const latestUpdates = document.querySelector(".updates-list");

        function renderMovementRow(scan) {
          const result = (scan.result || "INVALID").toLowerCase();
          const action = (scan.action || " ").toLowerCase();
          return `<tr class="movement-row">
        <td>${toPHT(scan.scanned_at)}</td>
        <td><strong>${scan.student_number || "-"}</strong><br><small>${scan.full_name || ""}</small></td>
        <td>${scan.plate_number || "-"}</td>
        <td>${scan.sticker_code || "-"}</td>
        <td><span class="badge badge-${result}">${scan.result || "-"}</span></td>
        <td><span class="badge badge-${action}">${scan.action || "-"}</span></td>
        <td>${scan.gate_name || "-"}</td>
      </tr>`;
        }

        function renderMovementCard(scan) {
          const result = (scan.result || "INVALID").toLowerCase();
          const action = (scan.action || " ").toLowerCase();
          return `<div class="mobile-data-card" data-searchable="${scan.full_name} ${scan.plate_number} ${scan.student_number}">
            <div class="card-header"><div class="card-title text-truncate" style="max-width:60%;">${scan.full_name || "Guest"}</div><span class="badge badge-${action}">${scan.action || "VERIFY"}</span></div>
            <div class="card-body">
              <div class="card-item">🚗 <strong>Plate:</strong> ${scan.plate_number || "-"}</div>
              <div class="card-item">🛡️ <strong>Status:</strong> <span class="badge badge-${result}">${scan.result}</span></div>
              <div class="card-item">📅 <strong>Time:</strong> ${new Date(scan.scanned_at).toLocaleTimeString()}</div>
            </div>
          </div>`;
        }
        function renderEmptySlotHistory(message) {
          return `<div class="empty-state" style="padding:1rem;"><p>${message}</p></div>`;
        }

        function renderSlotHistoryCard(item) {
          const parkedAt = item.parked_at || item.scanned_at;
          const exitedAtText = item.exited_at ? toPHT(item.exited_at) : "Still parked";
          const durationText = item.duration_label || "-";
          const statusChip = item.is_ongoing
            ? `<span class="badge" style="background:#dcfce7; color:#166534; border:1px solid #86efac;">ONGOING</span>`
            : `<span class="badge" style="background:#f1f5f9; color:#334155; border:1px solid #cbd5e1;">COMPLETED</span>`;
          return `<div class="slot-history-card">
            <div class="slot-history-card-head">
              <strong>${item.full_name || "Unknown Student"}</strong>
              <span class="badge" style="background:#f1f5f9; color:#334155; border:1px solid #cbd5e1;">${item.parking_slot || "-"}</span>
            </div>
            <div>${statusChip}</div>
            <div class="slot-history-card-meta">Student No: <strong>${item.student_number || "-"}</strong></div>
            <div class="slot-history-card-meta">Plate: <strong>${item.plate_number || "-"}</strong></div>
            <div class="slot-history-card-meta">Entry Gate: <strong>${item.entry_gate || item.gate || "-"}</strong></div>
            <div class="slot-history-card-meta">Parked At: <strong>${parkedAt ? toPHT(parkedAt) : "-"}</strong></div>
            <div class="slot-history-card-meta">Exited At: <strong>${exitedAtText}</strong></div>
            <div class="slot-history-card-meta">Duration: <strong>${durationText}</strong></div>
          </div>`;
        }

        function closeSlotHistoryModal() {
          if (!slotHistoryModal) return;
          slotHistoryModal.classList.remove("open");
          slotHistoryModal.setAttribute("aria-hidden", "true");
          document.body.classList.remove("modal-open");
        }

        async function openSlotHistoryModal(slotCode) {
          if (!slotCode || !slotHistoryModal) return;
          slotHistoryModal.classList.add("open");
          slotHistoryModal.setAttribute("aria-hidden", "false");
          document.body.classList.add("modal-open");
          if (slotHistoryTitle) slotHistoryTitle.textContent = `Slot ${slotCode} History`;
          if (slotHistoryMeta) slotHistoryMeta.textContent = "Loading slot history...";
          if (slotHistoryList) slotHistoryList.innerHTML = renderEmptySlotHistory("Loading slot history...");

          try {
            const resp = await fetch(`/api/parking-slot-history?slot_code=${encodeURIComponent(slotCode)}`);
            const data = await resp.json();
            if (!data.ok) throw new Error(data.message || "Failed to load slot history.");
            const rows = Array.isArray(data.rows) ? data.rows : [];
            if (slotHistoryList) {
              slotHistoryList.innerHTML = rows.length
                ? rows.map(renderSlotHistoryCard).join("")
                : renderEmptySlotHistory(`No parking history found for slot ${slotCode}.`);
            }
            if (slotHistoryMeta) {
              slotHistoryMeta.textContent = `${rows.length} parking entr${rows.length === 1 ? "y" : "ies"} found for slot ${slotCode}`;
            }
          } catch (error) {
            if (slotHistoryList) slotHistoryList.innerHTML = renderEmptySlotHistory(error.message || "Unable to load slot history.");
            if (slotHistoryMeta) slotHistoryMeta.textContent = error.message || "Unable to load slot history.";
          }
        }

        function attachParkingSlotHandlers() {
          const cards = Array.from(document.querySelectorAll(".parking-slot-card"));
          cards.forEach((card) => {
            const slotCode = card.dataset.slotCode || "";
            card.onclick = () => openSlotHistoryModal(slotCode);
            card.onkeydown = (event) => {
              if (event.key === "Enter" || event.key === " ") {
                event.preventDefault();
                openSlotHistoryModal(slotCode);
              }
            };
          });
        }
        function renderUpdateItem(scan) {
          const result = (scan.result || "invalid").toLowerCase();
          const action = (scan.action || "verify").toLowerCase();
          return `<div class="update-item">
        <span class="update-dot ${result} ${action}"></span>
        <div><p><strong>${scan.full_name || "Unknown Student"}</strong> <span class="update-action ${action}">${scan.action || "VERIFY"}</span></p>
          <p class="helper-text">${scan.gate_name || "Main Gate"} — ${toPHT(scan.scanned_at)}</p></div>
      </div>`;
        }

        const statIds = {
          students: document.querySelectorAll('.hero-card p')[0],
          vehicles: document.querySelectorAll('.hero-card p')[1],
          activeStickers: document.querySelectorAll('.hero-card p')[2],
          currentlyInside: insideCount,
          overstayAlerts: overstayCountEl
        };

        async function refreshDashboard() {
          try {
            const resp = await fetch("/api/dashboard-stats");
            const data = await resp.json();
            if (!data.ok) return;

            const m = data.metrics || {};
            if (statIds.students) statIds.students.textContent = m.students ?? "-";
            if (statIds.vehicles) statIds.vehicles.textContent = m.vehicles ?? "-";
            if (statIds.activeStickers) statIds.activeStickers.textContent = m.activeStickers ?? "-";
            if (insideCount) insideCount.textContent = m.currentlyInside ?? "-";
            const vehicles = data.insideVehicles || [];
            const overstayRows = Array.isArray(data.overstayAlerts)
              ? data.overstayAlerts
              : vehicles.filter((item) => item.is_overstay);
            const limitLabelFromApi = data.overstayLimitLabel || overstayLimitLabel;
            if (statIds.overstayAlerts) {
              statIds.overstayAlerts.textContent = typeof m.overstayAlerts === "number"
                ? m.overstayAlerts
                : overstayRows.length;
            }
            syncOverstayAlerts(overstayRows);
            if (overstayLimitMetaEl) {
              overstayLimitMetaEl.textContent = `Limit: ${limitLabelFromApi} hour(s)`;
            }
            const insideCardsList = document.getElementById("insideVehiclesCards");
            if (insideBody) {
              insideBody.innerHTML = vehicles.length
                ? vehicles.map(renderInsideRow).join("")
                : `<tr id="insideEmptyRow"><td colspan="9">${renderEmptyInside()}</td></tr>`;
            }
            if (insideCardsList) {
               insideCardsList.innerHTML = vehicles.length
                ? vehicles.map(renderInsideCard).join("")
                : renderEmptyInside();
            }

            const parkingSlots = Array.isArray(data.parkingSlots) ? data.parkingSlots : [];
            const slotSummary = data.parkingSlotSummary || {};
            if (parkingSlotsListEl) {
              parkingSlotsListEl.innerHTML = parkingSlots.length
                ? parkingSlots.map(renderParkingSlotCard).join("")
                : renderEmptyParkingSlots();
            }
            if (parkingSlotsMetaEl) {
              const availableCount = typeof slotSummary.available === "number"
                ? slotSummary.available
                : parkingSlots.filter(slot => slot.occupancy === "available").length;
              const occupiedCount = typeof slotSummary.occupied === "number"
                ? slotSummary.occupied
                : parkingSlots.filter(slot => slot.occupancy === "occupied").length;
              const disabledCount = typeof slotSummary.disabled === "number"
                ? slotSummary.disabled
                : parkingSlots.filter(slot => slot.occupancy === "disabled").length;
              const totalCount = typeof slotSummary.total === "number"
                ? slotSummary.total
                : parkingSlots.length;
              parkingSlotsMetaEl.textContent = `${availableCount} available | ${occupiedCount} occupied | ${disabledCount} disabled | ${totalCount} total`;
            }
            attachParkingSlotHandlers();

            const logs = data.movementLogs || [];
            if (movementTbody) {
              movementTbody.innerHTML = logs.length
                ? logs.map(renderMovementRow).join("")
                : `<tr id="movementEmptyRow"><td colspan="7"><div class="empty-state"><div class="empty-state-icon">📋</div><p>No scan records yet.</p></div></td></tr>`;
            }
            if (movementCards) {
               movementCards.innerHTML = logs.length
                ? logs.map(renderMovementCard).join("")
                : `<div class="empty-state"><div class="empty-state-icon">📋</div><p>No scan records.</p></div>`;
            }
            applySearch();

            if (latestUpdates) {
              latestUpdates.innerHTML = logs.length
                ? logs.slice(0, 8).map(renderUpdateItem).join("")
                : `<div class="empty-state"><div class="empty-state-icon">🔔</div><p>No updates yet.</p></div>`;
            }

            if (lastUpdatedEl) lastUpdatedEl.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
          } catch (err) { console.error(err); }
        }

        refreshDashboard();
        setInterval(refreshDashboard, 20000);
        if (refreshBtn) refreshBtn.addEventListener("click", refreshDashboard);
        attachParkingSlotHandlers();
        if (slotHistoryModal) {
          slotHistoryModal.querySelectorAll("[data-close-slot-history]").forEach((el) => {
            el.addEventListener("click", closeSlotHistoryModal);
          });
        }
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closeSlotHistoryModal();
        });
      })();
    </script>
    <%- include("partials/footer") %>

