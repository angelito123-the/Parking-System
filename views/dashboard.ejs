<%- include("partials/header") %>
<%
  const safeMetrics = typeof metrics === "object" && metrics ? metrics : {};
  const rawMovementLogs = typeof movementLogs !== "undefined" ? movementLogs : [];
  const safeMovementLogs = Array.isArray(rawMovementLogs) ? rawMovementLogs : [];
  const rawInsideVehicles = typeof insideVehicles !== "undefined" ? insideVehicles : [];
  const safeInsideVehicles = Array.isArray(rawInsideVehicles) ? rawInsideVehicles : [];
%>

<section class="cards">
  <article class="card">
    <h3>Total Students</h3>
    <p><%= safeMetrics.students || 0 %></p>
  </article>
  <article class="card">
    <h3>Registered Vehicles</h3>
    <p><%= safeMetrics.vehicles || 0 %></p>
  </article>
  <article class="card">
    <h3>Active Stickers</h3>
    <p><%= safeMetrics.activeStickers || 0 %></p>
  </article>
  <article class="card">
    <h3>Today's Entries</h3>
    <p><%= safeMetrics.todayEntries || 0 %></p>
  </article>
  <article class="card">
    <h3>Today's Exits</h3>
    <p><%= safeMetrics.todayExits || 0 %></p>
  </article>
  <article class="card">
    <h3>Currently Inside</h3>
    <p id="currentlyInsideCount"><%= safeMetrics.currentlyInside || 0 %></p>
  </article>
</section>

<section class="panel">
  <div class="section-head">
    <h2>Currently Inside Vehicles</h2>
    <p>Live roster of vehicles currently inside campus based on latest valid movement.</p>
  </div>
  <div class="refresh-row" style="margin-bottom: 0.75rem;">
    <span id="insideLastUpdated" class="helper-text">Loading...</span>
    <button type="button" class="refresh-btn" id="refreshInsideBtn">↻ Refresh</button>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Student Name</th>
          <th>Plate</th>
          <th>Sticker</th>
          <th>Entry Gate</th>
          <th>Entered At</th>
          <th>Minutes Inside</th>
        </tr>
      </thead>
      <tbody id="insideVehiclesBody">
        <% if (safeInsideVehicles.length === 0) { %>
          <tr id="insideEmptyRow">
            <td colspan="7">
              <div class="empty-state">
                <div class="empty-state-icon">🚗</div>
                <p>No vehicles currently inside campus.</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% safeInsideVehicles.forEach(item => { %>
          <tr>
            <td><%= item.student_number || "-" %></td>
            <td><%= item.full_name || "-" %></td>
            <td><%= item.plate_number || "-" %></td>
            <td><%= item.sticker_code || "-" %></td>
            <td><%= item.entry_gate || "-" %></td>
            <td><%= new Date(item.entered_at).toLocaleString('en-US', { timeZone: 'Asia/Manila' }) %></td>
            <td><%= Number(item.minutes_inside || 0) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <div class="section-head">
      <h2>Student Gate Entry and Exit Records</h2>
      <p>Latest verified movements captured from campus gates.</p>
    </div>
    <div class="table-tools">
      <label for="movementSearch" class="sr-only">Search student name or plate</label>
      <input
        id="movementSearch"
        type="search"
        placeholder="Search by student name, plate, student number, or sticker..."
      />
      <p id="movementSearchCount" class="helper-text">Showing <%= safeMovementLogs.length %> records</p>
    </div>
    <div class="table-wrap">
      <table id="movementTable">
        <thead>
          <tr>
            <th>Date/Time</th>
            <th>Student Number</th>
            <th>Student Name</th>
            <th>Plate</th>
            <th>Sticker</th>
            <th>Result</th>
            <th>Movement</th>
            <th>Gate</th>
          </tr>
        </thead>
        <tbody>
          <% if (safeMovementLogs.length === 0) { %>
            <tr>
              <td colspan="8">
                <div class="empty-state">
                  <div class="empty-state-icon">📋</div>
                  <p>No scan records yet.</p>
                </div>
              </td>
            </tr>
          <% } %>
          <% safeMovementLogs.forEach(scan => { %>
            <tr>
              <td><%= new Date(scan.scanned_at).toLocaleString('en-US', { timeZone: 'Asia/Manila' }) %></td>
              <td><%= scan.student_number || "-" %></td>
              <td><%= scan.full_name || "-" %></td>
              <td><%= scan.plate_number || "-" %></td>
              <td><%= scan.sticker_code || "-" %></td>
              <td><span class="badge badge-<%= (scan.result || "INVALID").toLowerCase() %>"><%= scan.result || "-" %></span></td>
              <td><span class="badge badge-action"><%= scan.action || "-" %></span></td>
              <td><%= scan.gate || "-" %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="section-head">
      <h2>Latest Updates</h2>
      <p>Most recent gate activity snapshots.</p>
    </div>
    <div class="updates-list">
      <% if (safeMovementLogs.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">🔔</div>
          <p>No updates yet.</p>
        </div>
      <% } %>
      <% safeMovementLogs.slice(0, 8).forEach(scan => { %>
        <div class="update-item">
          <span class="update-dot <%= (scan.result || 'invalid').toLowerCase() %> <%= (scan.action || 'verify').toLowerCase() %>"></span>
          <div>
            <p>
              <strong><%= scan.full_name || "Unknown Student" %></strong>
              <span class="update-action <%= (scan.action || 'verify').toLowerCase() %>"><%= scan.action || "VERIFY" %></span>
            </p>
            <p class="helper-text"><%= scan.gate || "Main Gate" %> — <%= new Date(scan.scanned_at).toLocaleString('en-US', { timeZone: 'Asia/Manila' }) %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </article>
</section>

<script>
  (() => {
    // ── Movement search ──────────────────────────────────────────────
    const searchInput = document.getElementById("movementSearch");
    const table = document.getElementById("movementTable");
    const countLabel = document.getElementById("movementSearchCount");

    function applySearch() {
      if (!searchInput || !table || !countLabel) return;
      const q = searchInput.value.trim().toLowerCase();
      const rows = Array.from(table.querySelectorAll("tbody tr")).filter(r => r.children.length > 1);
      let visible = 0;
      rows.forEach(row => {
        const match = !q || row.textContent.toLowerCase().includes(q);
        row.style.display = match ? "" : "none";
        if (match) visible++;
      });
      countLabel.textContent = q ? `Showing ${visible} matching records` : `Showing ${rows.length} records`;
    }
    if (searchInput) searchInput.addEventListener("input", applySearch);

    // ── PHT formatter ────────────────────────────────────────────────
    function toPHT(dateStr) {
      return new Date(dateStr).toLocaleString('en-US', { timeZone: 'Asia/Manila' });
    }

    // ── Currently Inside table ────────────────────────────────────────
    const insideBody    = document.getElementById("insideVehiclesBody");
    const insideCount   = document.getElementById("currentlyInsideCount");
    const lastUpdatedEl = document.getElementById("insideLastUpdated");
    const refreshBtn    = document.getElementById("refreshInsideBtn");

    function renderInsideRow(item) {
      const enteredAt = item.entered_at ? toPHT(item.entered_at) : "-";
      return `<tr>
        <td>${item.student_number || "-"}</td>
        <td>${item.full_name || "-"}</td>
        <td>${item.plate_number || "-"}</td>
        <td>${item.sticker_code || "-"}</td>
        <td>${item.entry_gate || "-"}</td>
        <td>${enteredAt}</td>
        <td>${Number(item.minutes_inside || 0)}</td>
      </tr>`;
    }

    function renderEmptyInside() {
      return `<tr><td colspan="7">
        <div class="empty-state">
          <div class="empty-state-icon">🚗</div>
          <p>No vehicles currently inside campus.</p>
        </div>
      </td></tr>`;
    }

    // ── Movement table ────────────────────────────────────────────────
    const movementTbody   = table ? table.querySelector("tbody") : null;
    const latestUpdates   = document.querySelector(".updates-list");

    function renderMovementRow(scan) {
      const result  = (scan.result  || "INVALID").toLowerCase();
      const action  = (scan.action  || "VERIFY").toLowerCase();
      return `<tr>
        <td>${toPHT(scan.scanned_at)}</td>
        <td>${scan.student_number || "-"}</td>
        <td>${scan.full_name || "-"}</td>
        <td>${scan.plate_number || "-"}</td>
        <td>${scan.sticker_code || "-"}</td>
        <td><span class="badge badge-${result}">${scan.result || "-"}</span></td>
        <td><span class="badge badge-action">${scan.action || "-"}</span></td>
        <td>${scan.gate || "-"}</td>
      </tr>`;
    }

    function renderUpdateItem(scan) {
      const result = (scan.result || "invalid").toLowerCase();
      const action = (scan.action || "verify").toLowerCase();
      return `<div class="update-item">
        <span class="update-dot ${result} ${action}"></span>
        <div>
          <p><strong>${scan.full_name || "Unknown Student"}</strong>
            <span class="update-action ${action}">${scan.action || "VERIFY"}</span>
          </p>
          <p class="helper-text">${scan.gate || "Main Gate"} — ${toPHT(scan.scanned_at)}</p>
        </div>
      </div>`;
    }

    // ── Stat card IDs ─────────────────────────────────────────────────
    const statIds = {
      students:       document.querySelectorAll('.card p')[0],
      vehicles:       document.querySelectorAll('.card p')[1],
      activeStickers: document.querySelectorAll('.card p')[2],
      todayEntries:   document.querySelectorAll('.card p')[3],
      todayExits:     document.querySelectorAll('.card p')[4],
      currentlyInside: insideCount
    };

    // ── Full dashboard refresh ────────────────────────────────────────
    async function refreshDashboard() {
      try {
        const resp = await fetch("/api/dashboard-stats");
        const data = await resp.json();
        if (!data.ok) return;

        // Update stat cards
        const m = data.metrics || {};
        if (statIds.students)       statIds.students.textContent       = m.students       ?? "-";
        if (statIds.vehicles)       statIds.vehicles.textContent       = m.vehicles       ?? "-";
        if (statIds.activeStickers) statIds.activeStickers.textContent = m.activeStickers ?? "-";
        if (statIds.todayEntries)   statIds.todayEntries.textContent   = m.todayEntries   ?? "-";
        if (statIds.todayExits)     statIds.todayExits.textContent     = m.todayExits     ?? "-";
        if (insideCount)            insideCount.textContent            = m.currentlyInside ?? "-";

        // Update inside vehicles
        const vehicles = data.insideVehicles || [];
        if (insideBody) {
          insideBody.innerHTML = vehicles.length
            ? vehicles.map(renderInsideRow).join("")
            : renderEmptyInside();
        }

        // Update movement table
        const logs = data.movementLogs || [];
        if (movementTbody) {
          movementTbody.innerHTML = logs.length
            ? logs.map(renderMovementRow).join("")
            : `<tr><td colspan="8"><div class="empty-state"><div class="empty-state-icon">📋</div><p>No scan records yet.</p></div></td></tr>`;
          applySearch();
        }

        // Update latest updates sidebar
        if (latestUpdates) {
          latestUpdates.innerHTML = logs.length
            ? logs.slice(0, 8).map(renderUpdateItem).join("")
            : `<div class="empty-state"><div class="empty-state-icon">🔔</div><p>No updates yet.</p></div>`;
        }

        if (lastUpdatedEl) {
          lastUpdatedEl.textContent = `Last updated: ${new Date().toLocaleTimeString('en-US', { timeZone: 'Asia/Manila' })}`;
        }
      } catch (err) {
        if (lastUpdatedEl) lastUpdatedEl.textContent = "Refresh failed — retrying...";
      }
    }

    // Run every 20 seconds
    refreshDashboard();
    setInterval(refreshDashboard, 20000);

    if (refreshBtn) refreshBtn.addEventListener("click", refreshDashboard);
  })();
</script>

<%- include("partials/footer") %>
