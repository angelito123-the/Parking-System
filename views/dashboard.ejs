<%- include("partials/header") %>
<%
  const safeMetrics = typeof metrics === "object" && metrics ? metrics : {};
  const safeInsideVehicles = Array.isArray(insideVehicles) ? insideVehicles : [];
  const safeOverstayAlerts = Array.isArray(overstayAlerts) ? overstayAlerts : [];
  const safeOverstayLimitHours = Number(
    typeof overstayLimitHours !== "undefined"
      ? overstayLimitHours
      : (safeMetrics.overstayLimitHours || 4)
  ) || 4;
  const safeOverstayLimitLabel = Number.isInteger(safeOverstayLimitHours)
    ? `${safeOverstayLimitHours}`
    : safeOverstayLimitHours.toFixed(1).replace(/\.0$/, "");
%>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Administrator Command Center</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Total Students</h3>
      <p id="metricStudents"><%= safeMetrics.students || 0 %></p>
    </div>
    <div class="hero-card">
      <h3>Registered Vehicles</h3>
      <p id="metricVehicles"><%= safeMetrics.vehicles || 0 %></p>
    </div>
    <div class="hero-card" style="background: rgba(59, 130, 246, 0.22); border-color: rgba(147, 197, 253, 0.45);">
      <h3>Currently Inside</h3>
      <p id="metricInside"><%= safeMetrics.currentlyInside || 0 %></p>
    </div>
    <div class="hero-card" style="background: rgba(190, 18, 60, 0.22); border-color: rgba(251, 113, 133, 0.45);">
      <h3>Overstay Alerts</h3>
      <p id="metricOverstay"><%= safeMetrics.overstayAlerts || safeOverstayAlerts.length || 0 %></p>
    </div>
  </div>
</section>

<div class="overlap-wrapper" style="display:grid; gap:1.35rem;">
  <section class="panel quick-links-panel">
    <div class="section-head">
      <h2>Daily Workflow</h2>
      <p>Follow this order to keep operations smooth from registration to gate audit.</p>
    </div>
    <div class="quick-links-grid workflow-grid">
      <a href="/students" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 1</span>
        <h3>Register Student & Vehicle</h3>
        <p>Create or update student and vehicle details.</p>
      </a>
      <a href="/stickers" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 2</span>
        <h3>Issue QR Sticker</h3>
        <p>Generate a valid sticker linked to the vehicle.</p>
      </a>
      <a href="/scanner" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 3</span>
        <h3>Gate Verification</h3>
        <p>Scan QR and confirm ENTRY/EXIT from the console.</p>
      </a>
      <a href="/admin/slots" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 4</span>
        <h3>Assign & Monitor Slots</h3>
        <p>Track occupancy and open per-slot history quickly.</p>
      </a>
      <a href="/admin/updates" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 5</span>
        <h3>Watch Live Updates</h3>
        <p>See overstay alerts and recent gate activity in real time.</p>
      </a>
      <a href="/admin/records" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 6</span>
        <h3>Review Records</h3>
        <p>Search logs for reporting, audits, and incident checks.</p>
      </a>
    </div>
  </section>

  <section class="panel alert-summary-panel">
    <div class="section-head">
      <h2>Security Alerts Snapshot</h2>
      <p>Operational notifications for QR validation, zone capacity, pending approvals, and suspicious activity.</p>
    </div>
    <div class="alert-summary-grid">
      <article class="alert-summary-card tone-danger">
        <p class="alert-summary-label">Invalid QR Attempts Today</p>
        <p id="metricInvalidQrAttempts" class="alert-summary-value"><%= safeMetrics.invalidQrAttemptsToday || 0 %></p>
      </article>
      <article class="alert-summary-card tone-warning">
        <p class="alert-summary-label">Full Parking Zones</p>
        <p id="metricFullParkingZones" class="alert-summary-value"><%= safeMetrics.fullParkingZones || 0 %></p>
      </article>
      <article class="alert-summary-card tone-info">
        <p class="alert-summary-label">Pending Approvals</p>
        <p id="metricPendingApprovals" class="alert-summary-value"><%= safeMetrics.pendingApprovals || 0 %></p>
      </article>
      <article class="alert-summary-card tone-strong">
        <p class="alert-summary-label">Suspicious Scans</p>
        <p id="metricSuspiciousScans" class="alert-summary-value"><%= safeMetrics.suspiciousScans || 0 %></p>
      </article>
    </div>
    <div class="alert-summary-footer">
      <a href="/admin/alerts" class="btn-sm">Open Notifications & Alerts</a>
    </div>
  </section>

  <section class="panel admin-overview-panel">
    <div class="section-head">
      <h2>Overview of Inside Vehicles</h2>
      <p>Live roster of vehicles currently inside campus.</p>
    </div>
    <div class="refresh-row" style="margin-bottom: 0.75rem;">
      <span id="insideLastUpdated" class="helper-text">Last updated: --</span>
      <button type="button" class="refresh-btn btn-sm" id="refreshInsideBtn">Refresh</button>
    </div>
    <div id="overstayNotice" class="flash flash-error overstay-notice" style="display:none; margin-bottom:0.85rem;"></div>
    <div class="overstay-panel" style="margin-bottom: 1rem;">
      <div class="overstay-panel-head">
        <strong>Overstay Watch</strong>
        <span id="overstayLimitMeta" class="helper-text">Limit: <%= safeOverstayLimitLabel %> hour(s)</span>
      </div>
      <div id="overstayAlertList" class="overstay-alert-list">
        <% if (!safeOverstayAlerts.length) { %>
          <div class="overstay-empty">No active overstay alerts.</div>
        <% } %>
        <% safeOverstayAlerts.forEach((item) => { %>
          <div class="overstay-alert-item" data-sticker-id="<%= item.sticker_id %>">
            <div class="overstay-alert-main">
              <p class="overstay-alert-title">
                <strong><%= item.full_name || "Unknown Student" %></strong>
                <span><%= item.plate_number || "-" %></span>
                <span><%= item.parking_slot || "-" %></span>
              </p>
              <p class="helper-text">
                Entered <%= new Date(item.entered_at).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %>
                | Stayed <strong><%= item.duration_label || "-" %></strong>
                <% if (item.overstay_label) { %>
                  (<%= item.overstay_label %>)
                <% } %>
              </p>
            </div>
            <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit</button>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="table-wrap desktop-only-table ops-table-shell">
      <table>
        <thead>
          <tr>
            <th>Student No.</th>
            <th>Name</th>
            <th>Plate</th>
            <th>Sticker</th>
            <th>Slot</th>
            <th>Gate</th>
            <th>Duration</th>
            <th>Status</th>
            <th style="text-align:right; padding-right:1.2rem;">Action</th>
          </tr>
        </thead>
        <tbody id="insideVehiclesBody">
          <% if (!safeInsideVehicles.length) { %>
            <tr id="insideEmptyRow" style="box-shadow: none;">
              <td colspan="9" style="background: transparent; border: none;">
                <div class="empty-state">
                  <div class="empty-state-icon">🚗</div>
                  <p>No vehicles currently inside campus.</p>
                </div>
              </td>
            </tr>
          <% } %>
          <% safeInsideVehicles.forEach((item) => { %>
            <tr class="<%= item.is_overstay ? 'inside-row-overstay' : '' %>">
              <td><strong><%= item.student_number || "-" %></strong></td>
              <td><%= item.full_name || "-" %></td>
              <td><span class="badge badge-soft badge-plate"><%= item.plate_number || "-" %></span></td>
              <td><span class="badge badge-active"><%= item.sticker_code || "-" %></span></td>
              <td><%= item.parking_slot || "-" %></td>
              <td><%= item.entry_gate || "-" %></td>
              <td><%= item.duration_label || "-" %></td>
              <td>
                <% if (item.is_overstay) { %>
                  <span class="badge badge-overstay">Overstay</span>
                <% } else { %>
                  <span class="badge badge-inside">Inside</span>
                <% } %>
              </td>
              <td style="text-align:right;">
                <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mobile-data-list" id="insideVehiclesCards">
      <% if (!safeInsideVehicles.length) { %>
        <div class="empty-state">
          <div class="empty-state-icon">🚗</div>
          <p>No vehicles inside campus.</p>
        </div>
      <% } %>
      <% safeInsideVehicles.forEach((item) => { %>
        <div class="mobile-data-card <%= item.is_overstay ? 'overstay-card' : '' %>" data-sticker-id="<%= item.sticker_id %>">
          <div class="card-header">
            <div class="card-title"><%= item.full_name || "Unknown" %></div>
            <% if (item.is_overstay) { %>
              <span class="badge badge-overstay">Overstay</span>
            <% } else { %>
              <span class="badge badge-inside">Inside</span>
            <% } %>
          </div>
          <div class="card-body">
            <div class="card-item">Plate: <strong><%= item.plate_number || "-" %></strong></div>
            <div class="card-item">Slot: <strong><%= item.parking_slot || "-" %></strong></div>
            <div class="card-item">Gate: <strong><%= item.entry_gate || "-" %></strong></div>
            <div class="card-item">In: <strong><%= new Date(item.entered_at).toLocaleTimeString() %></strong></div>
            <div class="card-item">Duration: <strong><%= item.duration_label || "-" %></strong></div>
            <% if (item.overstay_label) { %>
              <div class="card-item overstay-card-alert"><strong>Alert:</strong> <%= item.overstay_label %></div>
            <% } %>
          </div>
          <div class="card-actions">
            <button type="button" class="danger btn-mobile-touch force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit Vehicle</button>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
</div>

<script>
  (() => {
    const insideBody = document.getElementById("insideVehiclesBody");
    const insideCards = document.getElementById("insideVehiclesCards");
    const metricStudents = document.getElementById("metricStudents");
    const metricVehicles = document.getElementById("metricVehicles");
    const metricInside = document.getElementById("metricInside");
    const metricOverstay = document.getElementById("metricOverstay");
    const metricInvalidQrAttempts = document.getElementById("metricInvalidQrAttempts");
    const metricFullParkingZones = document.getElementById("metricFullParkingZones");
    const metricPendingApprovals = document.getElementById("metricPendingApprovals");
    const metricSuspiciousScans = document.getElementById("metricSuspiciousScans");
    const overstayListEl = document.getElementById("overstayAlertList");
    const overstayLimitMetaEl = document.getElementById("overstayLimitMeta");
    const overstayNoticeEl = document.getElementById("overstayNotice");
    const lastUpdatedEl = document.getElementById("insideLastUpdated");
    const refreshBtn = document.getElementById("refreshInsideBtn");
    const seenOverstayIds = new Set(
      <%- JSON.stringify(safeOverstayAlerts.map((item) => String(item.sticker_id || "")).filter(Boolean)) %>
    );
    const overstayLimitHours = Number(<%- JSON.stringify(safeOverstayLimitHours) %>) || 4;
    const overstayLimitLabel = Number.isInteger(overstayLimitHours)
      ? String(overstayLimitHours)
      : overstayLimitHours.toFixed(1).replace(/\.0$/, "");
    let overstayNoticeTimer = null;

    function toPht(value) {
      return new Date(value).toLocaleString("en-US", { timeZone: "Asia/Manila" });
    }

    function getDurationLabel(item) {
      if (item && item.duration_label) return item.duration_label;
      const minutes = Math.max(0, Number(item?.minutes_inside) || 0);
      const days = Math.floor(minutes / 1440);
      const hours = Math.floor((minutes % 1440) / 60);
      const mins = minutes % 60;
      const parts = [];
      if (days > 0) parts.push(`${days}d`);
      if (hours > 0 || days > 0) parts.push(`${hours}h`);
      parts.push(`${mins}m`);
      return parts.join(" ");
    }

    function getOverstayText(item) {
      if (!item || !item.is_overstay) return "";
      if (item.overstay_label) return item.overstay_label;
      const overstayMinutes = Math.max(0, Number(item.overstay_minutes) || 0);
      if (!overstayMinutes) return "Over limit";
      return `+${getDurationLabel({ minutes_inside: overstayMinutes })} over limit`;
    }

    window.forceExit = async function forceExit(stickerId, button) {
      if (!confirm("Force exit this vehicle?")) return;
      if (button) {
        button.disabled = true;
        button.textContent = "...";
      }
      try {
        const resp = await fetch("/api/force-exit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ sticker_id: stickerId })
        });
        const data = await resp.json();
        if (!data.ok) {
          alert(data.message || "Unable to force exit this vehicle.");
          if (button) {
            button.disabled = false;
            button.textContent = "Force Exit";
          }
          return;
        }
        refreshOverview();
      } catch (error) {
        alert("Unable to force exit this vehicle right now.");
        if (button) {
          button.disabled = false;
          button.textContent = "Force Exit";
        }
      }
    };

    function renderInsideRow(item) {
      const duration = getDurationLabel(item);
      const overstayLabel = getOverstayText(item);
      const statusChip = item.is_overstay
        ? `<span class="badge badge-overstay">OVERSTAY</span>`
        : `<span class="badge badge-inside">INSIDE</span>`;
      return `<tr class="${item.is_overstay ? "inside-row-overstay" : ""}">
        <td><strong>${item.student_number || "-"}</strong></td>
        <td>${item.full_name || "-"}</td>
        <td><span class="badge badge-soft badge-plate">${item.plate_number || "-"}</span></td>
        <td><span class="badge badge-active">${item.sticker_code || "-"}</span></td>
        <td>${item.parking_slot || "-"}</td>
        <td>${item.entry_gate || "-"}</td>
        <td>${duration}</td>
        <td>${statusChip}${overstayLabel ? `<div class="table-alert-sub">${overstayLabel}</div>` : ""}</td>
        <td style="text-align:right;"><button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit</button></td>
      </tr>`;
    }

    function renderInsideCard(item) {
      const duration = getDurationLabel(item);
      const overstayLabel = getOverstayText(item);
      return `<div class="mobile-data-card ${item.is_overstay ? "overstay-card" : ""}" data-sticker-id="${item.sticker_id}">
        <div class="card-header"><div class="card-title">${item.full_name || "Unknown"}</div>${item.is_overstay ? `<span class="badge badge-overstay">OVERSTAY</span>` : `<span class="badge badge-inside">INSIDE</span>`}</div>
        <div class="card-body">
          <div class="card-item">Plate: <strong>${item.plate_number || "-"}</strong></div>
          <div class="card-item">Slot: <strong>${item.parking_slot || "-"}</strong></div>
          <div class="card-item">Gate: <strong>${item.entry_gate || "-"}</strong></div>
          <div class="card-item">In: <strong>${item.entered_at ? new Date(item.entered_at).toLocaleTimeString() : "-"}</strong></div>
          <div class="card-item">Duration: <strong>${duration}</strong></div>
          ${overstayLabel ? `<div class="card-item overstay-card-alert"><strong>Alert:</strong> ${overstayLabel}</div>` : ""}
        </div>
        <div class="card-actions"><button type="button" class="danger btn-mobile-touch force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit Vehicle</button></div>
      </div>`;
    }

    function renderOverstayAlert(item) {
      return `<div class="overstay-alert-item" data-sticker-id="${item.sticker_id || ""}">
        <div class="overstay-alert-main">
          <p class="overstay-alert-title">
            <strong>${item.full_name || "Unknown Student"}</strong>
            <span>${item.plate_number || "-"}</span>
            <span>${item.parking_slot || "-"}</span>
          </p>
          <p class="helper-text">Entered ${item.entered_at ? toPht(item.entered_at) : "-"} | Stayed <strong>${getDurationLabel(item)}</strong>${item.is_overstay ? ` (${getOverstayText(item)})` : ""}</p>
        </div>
        <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit</button>
      </div>`;
    }

    function renderEmptyInside() {
      return `<div class="empty-state"><div class="empty-state-icon">🚗</div><p>No vehicles currently inside campus.</p></div>`;
    }

    function showOverstayNotice(message) {
      if (!overstayNoticeEl) return;
      overstayNoticeEl.textContent = message;
      overstayNoticeEl.style.display = "flex";
      if (overstayNoticeTimer) clearTimeout(overstayNoticeTimer);
      overstayNoticeTimer = setTimeout(() => {
        overstayNoticeEl.style.display = "none";
      }, 6500);
    }

    function syncOverstayAlerts(rows) {
      if (overstayListEl) {
        overstayListEl.innerHTML = rows.length
          ? rows.map(renderOverstayAlert).join("")
          : `<div class="overstay-empty">No active overstay alerts.</div>`;
      }

      const currentIds = new Set();
      const newlyOverstayed = [];
      rows.forEach((row) => {
        const key = String(row.sticker_id || "");
        if (!key) return;
        currentIds.add(key);
        if (!seenOverstayIds.has(key)) newlyOverstayed.push(row);
      });
      seenOverstayIds.clear();
      currentIds.forEach((id) => seenOverstayIds.add(id));

      if (newlyOverstayed.length > 0) {
        const lead = newlyOverstayed[0];
        const names = newlyOverstayed.length === 1
          ? (lead.full_name || "A student")
          : `${newlyOverstayed.length} vehicles`;
        const message = `Overstay alert: ${names} exceeded the ${overstayLimitLabel}-hour limit.`;
        showOverstayNotice(message);
      }
    }

    async function refreshOverview() {
      try {
        const resp = await fetch("/api/dashboard-stats", { credentials: "same-origin" });
        const data = await resp.json();
        if (!data.ok) return;

        const metrics = data.metrics || {};
        if (metricStudents) metricStudents.textContent = metrics.students ?? "-";
        if (metricVehicles) metricVehicles.textContent = metrics.vehicles ?? "-";
        if (metricInside) metricInside.textContent = metrics.currentlyInside ?? "-";
        if (metricInvalidQrAttempts) metricInvalidQrAttempts.textContent = metrics.invalidQrAttemptsToday ?? "-";
        if (metricFullParkingZones) metricFullParkingZones.textContent = metrics.fullParkingZones ?? "-";
        if (metricPendingApprovals) metricPendingApprovals.textContent = metrics.pendingApprovals ?? "-";
        if (metricSuspiciousScans) metricSuspiciousScans.textContent = metrics.suspiciousScans ?? "-";

        const vehicles = Array.isArray(data.insideVehicles) ? data.insideVehicles : [];
        const overstayRows = Array.isArray(data.overstayAlerts)
          ? data.overstayAlerts
          : vehicles.filter((item) => item.is_overstay);
        if (metricOverstay) {
          metricOverstay.textContent = typeof metrics.overstayAlerts === "number"
            ? metrics.overstayAlerts
            : overstayRows.length;
        }

        if (insideBody) {
          insideBody.innerHTML = vehicles.length
            ? vehicles.map(renderInsideRow).join("")
            : `<tr id="insideEmptyRow"><td colspan="9">${renderEmptyInside()}</td></tr>`;
        }
        if (insideCards) {
          insideCards.innerHTML = vehicles.length
            ? vehicles.map(renderInsideCard).join("")
            : renderEmptyInside();
        }

        syncOverstayAlerts(overstayRows);
        if (overstayLimitMetaEl) {
          const label = data.overstayLimitLabel || overstayLimitLabel;
          overstayLimitMetaEl.textContent = `Limit: ${label} hour(s)`;
        }
        if (lastUpdatedEl) {
          lastUpdatedEl.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
        }
      } catch (error) {
        console.error("Admin overview refresh failed:", error);
      }
    }

    refreshOverview();
    if (refreshBtn) refreshBtn.addEventListener("click", refreshOverview);
    setInterval(refreshOverview, 20000);
  })();
</script>

<%- include("partials/footer") %>
