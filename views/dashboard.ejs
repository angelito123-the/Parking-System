<%- include("partials/header") %>
  <% const safeMetrics=typeof metrics==="object" && metrics ? metrics : {}; const rawMovementLogs=typeof movementLogs
    !=="undefined" ? movementLogs : []; const safeMovementLogs=Array.isArray(rawMovementLogs) ? rawMovementLogs : [];
    const rawInsideVehicles=typeof insideVehicles !=="undefined" ? insideVehicles : []; const
    safeInsideVehicles=Array.isArray(rawInsideVehicles) ? rawInsideVehicles : []; const
    rawParkingSlots=typeof parkingSlots !=="undefined" ? parkingSlots : []; const
    safeParkingSlots=Array.isArray(rawParkingSlots) ? rawParkingSlots : []; const
    safeParkingSlotSummary=typeof parkingSlotSummary==="object" && parkingSlotSummary ? parkingSlotSummary : {
      total: safeParkingSlots.length,
      available: safeParkingSlots.filter(slot => slot.occupancy === "available").length,
      occupied: safeParkingSlots.filter(slot => slot.occupancy === "occupied").length,
      disabled: safeParkingSlots.filter(slot => slot.occupancy === "disabled").length
    }; %>
    <% const nowPht = new Date(); const todayDate = `${nowPht.getFullYear()}-${String(nowPht.getMonth()+1).padStart(2, '0')}-${String(nowPht.getDate()).padStart(2, '0')}`; %>

    <section class="dashboard-hero">
      <div class="hero-greeting">
        <h2>Welcome Back,</h2>
        <h1>NAAP Guard</h1>
      </div>
      <div class="hero-cards">
        <div class="hero-card">
          <h3>Total Students</h3>
          <p><%= safeMetrics.students || 0 %></p>
        </div>
        <div class="hero-card">
          <h3>Registered Vehicles</h3>
          <p><%= safeMetrics.vehicles || 0 %></p>
        </div>
        <div class="hero-card">
          <h3>Active Stickers</h3>
          <p id="activeStickersCount"><%= safeMetrics.activeStickers || 0 %></p>
        </div>
        <div class="hero-card" style="background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.4);">
          <h3>Currently Inside</h3>
          <p id="currentlyInsideCount"><%= safeMetrics.currentlyInside || 0 %></p>
        </div>
      </div>
    </section>

    <div class="overlap-wrapper">
      <section class="panel" style="border:none; box-shadow:none; padding:0; margin-bottom: 2.5rem; background: transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Overview of Inside Vehicles</h2>
          <p>Live roster of vehicles currently inside campus.</p>
        </div>
        <div class="refresh-row" style="margin-bottom: 0.75rem;">
          <span id="insideLastUpdated" class="helper-text">Loading...</span>
          <button type="button" class="refresh-btn btn-sm" id="refreshInsideBtn" style="background: var(--surface-soft); color: var(--text); border: 1px solid var(--line);">↻ Refresh</button>
        </div>
        <div class="table-wrap desktop-only-table">
          <table>
            <thead>
              <tr>
                <th>Student No.</th>
                <th>Name</th>
                <th>Plate</th>
                <th>Sticker</th>
                <th>Slot</th>
                <th>Gate</th>
                <th style="text-align: right; padding-right: 1.5rem;">Action</th>
              </tr>
            </thead>
            <tbody id="insideVehiclesBody">
              <% if (safeInsideVehicles.length === 0) { %>
                <tr id="insideEmptyRow" style="box-shadow: none;">
                  <td colspan="7" style="background: transparent; border: none;">
                    <div class="empty-state">
                      <div class="empty-state-icon">🚗</div>
                      <p>No vehicles currently inside campus.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              <% safeInsideVehicles.forEach(item => { %>
                <tr>
                  <td><strong><%= item.student_number || "-" %></strong></td>
                  <td><%= item.full_name || "-" %></td>
                  <td><span class="badge" style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1;"><%= item.plate_number || "-" %></span></td>
                  <td><span class="badge badge-active"><%= item.sticker_code || "-" %></span></td>
                  <td><%= item.parking_slot || "-" %></td>
                  <td><%= item.entry_gate || "-" %></td>
                  <td style="text-align: right;">
                    <button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit</button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Mobile-Ready Cards for Inside Vehicles -->
        <div class="mobile-data-list" id="insideVehiclesCards">
          <% if (safeInsideVehicles.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🚗</div>
              <p>No vehicles inside campus.</p>
            </div>
          <% } %>
          <% safeInsideVehicles.forEach(item => { %>
            <div class="mobile-data-card" data-sticker-id="<%= item.sticker_id %>">
              <div class="card-header">
                <div class="card-title"><%= item.full_name || "Unknown" %></div>
                <span class="badge badge-active"><%= item.sticker_code || "-" %></span>
              </div>
              <div class="card-body">
                <div class="card-item">🚗 <strong>Plate:</strong> <%= item.plate_number || "-" %></div>
                <div class="card-item">🅿 <strong>Slot:</strong> <%= item.parking_slot || "-" %></div>
                <div class="card-item">🚪 <strong>Gate:</strong> <%= item.entry_gate || "-" %></div>
                <div class="card-item">⏰ <strong>In:</strong> <%= new Date(item.entered_at).toLocaleTimeString() %></div>
              </div>
              <div class="card-actions">
                <button type="button" class="danger btn-mobile-touch force-exit-btn" onclick="window.forceExit('<%= item.sticker_id %>', this)">Force Exit Vehicle</button>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

      <section class="panel" style="border:none; box-shadow:none; padding:0; margin-bottom: 2rem; background: transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Parking Slot Monitoring</h2>
          <p>See exactly which vehicle is parked in each occupied slot.</p>
        </div>
        <div class="refresh-row" style="margin-bottom: 0.75rem;">
          <span id="parkingSlotsMeta" class="helper-text">
            <%= safeParkingSlotSummary.available %> available | <%= safeParkingSlotSummary.occupied %> occupied | <%= safeParkingSlotSummary.disabled %> disabled | <%= safeParkingSlotSummary.total %> total
          </span>
        </div>
        <div id="parkingSlotsList" class="parking-slots-grid">
          <% if (safeParkingSlots.length === 0) { %>
            <div class="empty-state" style="padding:1.25rem 1rem;">
              <p>No parking slots configured.</p>
            </div>
          <% } %>
          <% safeParkingSlots.forEach(slot => { %>
            <div class="parking-slot-card <%= slot.occupancy || 'available' %>">
              <div class="parking-slot-head">
                <span class="parking-slot-code"><%= slot.slot_code || "-" %></span>
                <span class="parking-slot-status"><%= (slot.occupancy || "available").toUpperCase() %></span>
              </div>
              <div class="parking-slot-zone"><%= slot.zone || "General" %></div>
              <% if (slot.occupancy === "occupied") { %>
                <div class="parking-slot-detail">Plate: <strong><%= slot.occupied_by_plate || "-" %></strong></div>
                <div class="parking-slot-detail">Student: <strong><%= slot.occupied_by_name || "Unknown" %></strong></div>
              <% } else if (slot.occupancy === "available") { %>
                <div class="parking-slot-detail">Open for entry assignment</div>
              <% } else { %>
                <div class="parking-slot-detail">Slot currently unavailable</div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>

      <section class="panel" style="border:none; box-shadow:none; padding:0; margin-bottom: 2rem; background: transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Parking History by Day and Time</h2>
          <p>Track which students parked within a specific date and time range.</p>
        </div>
        <form id="parkingHistoryFilterForm" class="filters-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr)); margin-bottom: 0.75rem;">
          <div>
            <label for="parkingHistoryDate">Date</label>
            <input id="parkingHistoryDate" type="date" value="<%= todayDate %>" />
          </div>
          <div>
            <label for="parkingHistoryFromTime">From</label>
            <input id="parkingHistoryFromTime" type="time" value="00:00" />
          </div>
          <div>
            <label for="parkingHistoryToTime">To</label>
            <input id="parkingHistoryToTime" type="time" value="23:59" />
          </div>
          <div class="filters-actions">
            <button type="submit" class="btn-sm" style="background: var(--blue-mid); color: #fff;">Load History</button>
          </div>
        </form>
        <div class="refresh-row" style="margin-bottom: 0.75rem;">
          <span id="parkingHistoryMeta" class="helper-text">Loading parking history...</span>
        </div>

        <div class="table-wrap desktop-only-table">
          <table>
            <thead>
              <tr>
                <th>Date/Time</th>
                <th>Student</th>
                <th>Plate</th>
                <th>Slot</th>
                <th>Gate</th>
              </tr>
            </thead>
            <tbody id="parkingHistoryBody">
              <tr style="box-shadow: none;">
                <td colspan="5" style="background: transparent; border: none;">
                  <div class="empty-state" style="padding:1rem;">
                    <p>Loading parking history...</p>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mobile-data-list" id="parkingHistoryCards">
          <div class="empty-state" style="padding:1rem;">
            <p>Loading parking history...</p>
          </div>
        </div>
      </section>

    <section class="dashboard-grid">
      <article class="panel">
        <div class="section-head">
          <h2>Student Gate Entry and Exit Records</h2>
          <p>Latest verified movements captured from campus gates.</p>
        </div>
        <div class="table-tools">
          <label for="movementSearch" class="sr-only">Search student name or plate</label>
          <input id="movementSearch" type="search"
            placeholder="Search by name, plate, or student number..." />
          <p id="movementSearchCount" class="helper-text">Showing <%= safeMovementLogs.length %> records</p>
        </div>
        <div class="table-wrap desktop-only-table">
          <table id="movementTable">
            <thead>
              <tr>
                <th>Date/Time</th>
                <th>Student</th>
                <th>Plate</th>
                <th>Sticker</th>
                <th>Result</th>
                <th>Movement</th>
                <th>Gate</th>
              </tr>
            </thead>
            <tbody>
              <% if (safeMovementLogs.length===0) { %>
                <tr id="movementEmptyRow" style="box-shadow: none;">
                  <td colspan="7" style="background: transparent; border: none;">
                    <div class="empty-state">
                      <div class="empty-state-icon">📋</div>
                      <p>No scan records yet.</p>
                    </div>
                  </td>
                </tr>
                <% } %>
                  <% safeMovementLogs.forEach(scan=> { %>
                    <tr class="movement-row">
                      <td style="color:var(--muted); font-size:0.8rem;">
                        <%= new Date(scan.scanned_at).toLocaleString('en-US', { hour: 'numeric', minute: 'numeric' }) %>
                      </td>
                      <td>
                        <strong><%= scan.student_number || "-" %></strong><br><small><%= scan.full_name || "" %></small>
                      </td>
                      <td>
                        <%= scan.plate_number || "-" %>
                      </td>
                      <td>
                        <%= scan.sticker_code || "-" %>
                      </td>
                      <td><span class="badge badge-<%= (scan.result || " INVALID").toLowerCase() %>"><%= scan.result %></span></td>
                      <td><span class="badge badge-<%= (scan.action || " ").toLowerCase() %>"><%= scan.action %></span></td>
                      <td>
                        <%= scan.gate_name || "-" %>
                      </td>
                    </tr>
                    <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Mobile-Ready Cards for Movement Logs -->
        <div class="mobile-data-list" id="movementCards">
          <% if (safeMovementLogs.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">📋</div>
              <p>No scan records yet.</p>
            </div>
          <% } %>
          <% safeMovementLogs.forEach(scan => { %>
            <div class="mobile-data-card" data-searchable="<%= (scan.full_name || '').toLowerCase() %> <%= (scan.plate_number || '').toLowerCase() %> <%= (scan.student_number || '').toLowerCase() %>">
              <div class="card-header">
                <div class="card-title text-truncate" style="max-width: 60%;"><%= scan.full_name || "Guest" %></div>
                <span class="badge badge-<%= (scan.action || ' ').toLowerCase() %>"><%= scan.action %></span>
              </div>
              <div class="card-body">
                <div class="card-item">🚗 <strong>Plate:</strong> <%= scan.plate_number || "-" %></div>
                <div class="card-item">🪪 <strong>Sticker:</strong> <%= scan.sticker_code || "-" %></div>
                <div class="card-item">🛡️ <strong>Status:</strong> <span class="badge badge-<%= (scan.result || 'INVALID').toLowerCase() %>"><%= scan.result %></span></div>
                <div class="card-item">📅 <strong>Time:</strong> <%= new Date(scan.scanned_at).toLocaleTimeString() %></div>
              </div>
            </div>
          <% }) %>
        </div>
      </article>

      <article class="panel">
        <div class="section-head">
          <h2>Latest Updates</h2>
          <p>Recent gate activity snapshots.</p>
        </div>
        <div class="updates-list">
          <% if (safeMovementLogs.length===0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🔔</div>
              <p>No updates yet.</p>
            </div>
            <% } %>
              <% safeMovementLogs.slice(0, 8).forEach(scan=> { %>
                <div class="update-item">
                  <span
                    class="update-dot <%= (scan.result || 'invalid').toLowerCase() %> <%= (scan.action || 'verify').toLowerCase() %>"></span>
                  <div>
                    <p>
                      <strong>
                        <%= scan.full_name || "Unknown Student" %>
                      </strong>
                      <span class="update-action <%= (scan.action || 'verify').toLowerCase() %>">
                        <%= scan.action || "VERIFY" %>
                      </span>
                    </p>
                    <p class="helper-text">
                      <%= scan.gate_name || "Main Gate" %> — <%= new Date(scan.scanned_at).toLocaleTimeString() %>
                    </p>
                  </div>
                </div>
                <% }) %>
        </div>
      </article>
    </section>

    <script>
      (() => {
        const searchInput = document.getElementById("movementSearch");
        const table = document.getElementById("movementTable");
        const countLabel = document.getElementById("movementSearchCount");

        function applySearch() {
          if (!searchInput || !table || !countLabel) return;
          const q = searchInput.value.trim().toLowerCase();
          const rows = Array.from(table.querySelectorAll("tbody tr")).filter(r => r.id !== 'movementEmptyRow');
          let tableVisible = 0;
          rows.forEach(row => {
            const match = !q || row.textContent.toLowerCase().includes(q);
            row.style.display = match ? "" : "none";
            if (match) tableVisible++;
          });
          
          const cardsList = document.getElementById("movementCards");
          const cardItems = cardsList ? Array.from(cardsList.querySelectorAll(".mobile-data-card")) : [];
          const emptyCardState = cardsList ? cardsList.querySelector(".empty-state") : null;
          let cardsVisible = 0;
          
          cardItems.forEach(card => {
            const searchable = card.dataset.searchable.toLowerCase();
            const match = !q || searchable.includes(q);
            card.style.display = match ? "flex" : "none";
            if (match) cardsVisible++;
          });

          if (emptyCardState) emptyCardState.style.display = (cardsVisible === 0 && cardItems.length > 0) ? "block" : "none";
          countLabel.textContent = q ? `Found ${tableVisible || cardsVisible} records` : `Showing ${rows.length || cardItems.length} records`;
        }
        if (searchInput) searchInput.addEventListener("input", applySearch);

        function toPHT(dateStr) {
          return new Date(dateStr).toLocaleString('en-US', { timeZone: 'Asia/Manila' });
        }

        const insideBody = document.getElementById("insideVehiclesBody");
        const insideCount = document.getElementById("currentlyInsideCount");
        const lastUpdatedEl = document.getElementById("insideLastUpdated");
        const refreshBtn = document.getElementById("refreshInsideBtn");
        const parkingSlotsMetaEl = document.getElementById("parkingSlotsMeta");
        const parkingSlotsListEl = document.getElementById("parkingSlotsList");
        const parkingHistoryForm = document.getElementById("parkingHistoryFilterForm");
        const parkingHistoryDate = document.getElementById("parkingHistoryDate");
        const parkingHistoryFromTime = document.getElementById("parkingHistoryFromTime");
        const parkingHistoryToTime = document.getElementById("parkingHistoryToTime");
        const parkingHistoryMeta = document.getElementById("parkingHistoryMeta");
        const parkingHistoryBody = document.getElementById("parkingHistoryBody");
        const parkingHistoryCards = document.getElementById("parkingHistoryCards");

        window.forceExit = async function(stickerId, btn) {
          if (!confirm("Force exit this vehicle?")) return;
          btn.disabled = true;
          btn.textContent = "...";
          try {
            const res = await fetch("/api/force-exit", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ sticker_id: stickerId })
            });
            const data = await res.json();
            if (data.ok) refreshDashboard();
            else { alert(data.message); btn.disabled = false; btn.textContent = "Force Exit"; }
          } catch (e) { alert("Error"); btn.disabled = false; btn.textContent = "Force Exit"; }
        };

        function renderInsideRow(item) {
          return `<tr>
        <td><strong>${item.student_number || "-"}</strong></td>
        <td>${item.full_name || "-"}</td>
        <td><span class="badge" style="background:#f1f5f9; color:#334155; border:1px solid #cbd5e1;">${item.plate_number || "-"}</span></td>
        <td><span class="badge badge-active">${item.sticker_code || "-"}</span></td>
        <td>${item.parking_slot || "-"}</td>
        <td>${item.entry_gate || "-"}</td>
        <td style="text-align:right;"><button type="button" class="btn-sm danger force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit</button></td>
      </tr>`;
        }

        function renderInsideCard(item) {
          return `<div class="mobile-data-card" data-sticker-id="${item.sticker_id}">
            <div class="card-header"><div class="card-title">${item.full_name || "Unknown"}</div><span class="badge badge-active">${item.sticker_code || "-"}</span></div>
            <div class="card-body">
              <div class="card-item">🚗 <strong>Plate:</strong> ${item.plate_number || "-"}</div>
              <div class="card-item">🚪 <strong>Gate:</strong> ${item.entry_gate || "-"}</div>
              <div class="card-item">⏰ <strong>PHT:</strong> ${item.entered_at ? new Date(item.entered_at).toLocaleTimeString() : "-"}</div>
            </div>
            <div class="card-actions"><button type="button" class="danger btn-mobile-touch force-exit-btn" onclick="window.forceExit('${item.sticker_id}', this)">Force Exit Vehicle</button></div>
          </div>`;
        }

        function renderEmptyInside() {
          return `<div class="empty-state"><div class="empty-state-icon">🚗</div><p>No vehicles inside.</p></div>`;
        }

        function renderParkingSlotCard(slot) {
          const occupancy = slot.occupancy || "available";
          const status = occupancy.toUpperCase();
          const primaryDetail = occupancy === "occupied"
            ? `Plate: <strong>${slot.occupied_by_plate || "-"}</strong>`
            : occupancy === "available"
            ? "Open for entry assignment"
            : "Slot currently unavailable";
          const secondaryDetail = occupancy === "occupied"
            ? `Student: <strong>${slot.occupied_by_name || "Unknown"}</strong>`
            : "";
          return `<div class="parking-slot-card ${occupancy}">
            <div class="parking-slot-head">
              <span class="parking-slot-code">${slot.slot_code || "-"}</span>
              <span class="parking-slot-status">${status}</span>
            </div>
            <div class="parking-slot-zone">${slot.zone || "General"}</div>
            <div class="parking-slot-detail">${primaryDetail}</div>
            ${secondaryDetail ? `<div class="parking-slot-detail">${secondaryDetail}</div>` : ""}
          </div>`;
        }

        function renderEmptyParkingSlots() {
          return `<div class="empty-state" style="padding:1.25rem 1rem;"><p>No parking slots configured.</p></div>`;
        }

        const movementTbody = table ? table.querySelector("tbody") : null;
        const movementCards = document.getElementById("movementCards");
        const latestUpdates = document.querySelector(".updates-list");

        function renderMovementRow(scan) {
          const result = (scan.result || "INVALID").toLowerCase();
          const action = (scan.action || " ").toLowerCase();
          return `<tr class="movement-row">
        <td>${toPHT(scan.scanned_at)}</td>
        <td><strong>${scan.student_number || "-"}</strong><br><small>${scan.full_name || ""}</small></td>
        <td>${scan.plate_number || "-"}</td>
        <td>${scan.sticker_code || "-"}</td>
        <td><span class="badge badge-${result}">${scan.result || "-"}</span></td>
        <td><span class="badge badge-${action}">${scan.action || "-"}</span></td>
        <td>${scan.gate_name || "-"}</td>
      </tr>`;
        }

        function renderMovementCard(scan) {
          const result = (scan.result || "INVALID").toLowerCase();
          const action = (scan.action || " ").toLowerCase();
          return `<div class="mobile-data-card" data-searchable="${scan.full_name} ${scan.plate_number} ${scan.student_number}">
            <div class="card-header"><div class="card-title text-truncate" style="max-width:60%;">${scan.full_name || "Guest"}</div><span class="badge badge-${action}">${scan.action || "VERIFY"}</span></div>
            <div class="card-body">
              <div class="card-item">🚗 <strong>Plate:</strong> ${scan.plate_number || "-"}</div>
              <div class="card-item">🛡️ <strong>Status:</strong> <span class="badge badge-${result}">${scan.result}</span></div>
              <div class="card-item">📅 <strong>Time:</strong> ${new Date(scan.scanned_at).toLocaleTimeString()}</div>
            </div>
          </div>`;
        }

        function renderParkingHistoryRow(item) {
          return `<tr>
            <td style="color:var(--muted); font-size:0.8rem;">${toPHT(item.scanned_at)}</td>
            <td><strong>${item.student_number || "-"}</strong><br><small>${item.full_name || ""}</small></td>
            <td>${item.plate_number || "-"}</td>
            <td>${item.parking_slot || "-"}</td>
            <td>${item.gate || "-"}</td>
          </tr>`;
        }

        function renderParkingHistoryCard(item) {
          return `<div class="mobile-data-card">
            <div class="card-header">
              <div class="card-title text-truncate" style="max-width:65%;">${item.full_name || "Unknown Student"}</div>
              <span class="badge" style="background:#f1f5f9; color:#334155; border:1px solid #cbd5e1;">${item.parking_slot || "-"}</span>
            </div>
            <div class="card-body">
              <div class="card-item">ðŸ†” <strong>Student No:</strong> ${item.student_number || "-"}</div>
              <div class="card-item">ðŸš— <strong>Plate:</strong> ${item.plate_number || "-"}</div>
              <div class="card-item">ðŸšª <strong>Gate:</strong> ${item.gate || "-"}</div>
              <div class="card-item">ðŸ“… <strong>Parked At:</strong> ${toPHT(item.scanned_at)}</div>
            </div>
          </div>`;
        }

        function renderEmptyParkingHistory(message) {
          return `<div class="empty-state" style="padding:1rem;"><p>${message}</p></div>`;
        }

        async function loadParkingHistory() {
          if (!parkingHistoryDate || !parkingHistoryFromTime || !parkingHistoryToTime) return;
          const date = parkingHistoryDate.value;
          const fromTime = parkingHistoryFromTime.value || "00:00";
          const toTime = parkingHistoryToTime.value || "23:59";

          if (!date) {
            if (parkingHistoryMeta) parkingHistoryMeta.textContent = "Please choose a date.";
            return;
          }

          if (fromTime > toTime) {
            if (parkingHistoryMeta) parkingHistoryMeta.textContent = "Invalid time range: 'From' time must be earlier than 'To' time.";
            return;
          }

          if (parkingHistoryMeta) parkingHistoryMeta.textContent = "Loading parking history...";

          try {
            const query = new URLSearchParams({
              date,
              from_time: fromTime,
              to_time: toTime
            }).toString();
            const resp = await fetch(`/api/parking-history?${query}`);
            const data = await resp.json();
            if (!data.ok) throw new Error(data.message || "Failed to load parking history.");

            const rows = Array.isArray(data.rows) ? data.rows : [];
            if (parkingHistoryBody) {
              parkingHistoryBody.innerHTML = rows.length
                ? rows.map(renderParkingHistoryRow).join("")
                : `<tr style="box-shadow:none;"><td colspan="5" style="background:transparent; border:none;">${renderEmptyParkingHistory("No parking records found for this day/time.")}</td></tr>`;
            }
            if (parkingHistoryCards) {
              parkingHistoryCards.innerHTML = rows.length
                ? rows.map(renderParkingHistoryCard).join("")
                : renderEmptyParkingHistory("No parking records found for this day/time.");
            }
            if (parkingHistoryMeta) {
              parkingHistoryMeta.textContent = `${rows.length} parking entr${rows.length === 1 ? "y" : "ies"} on ${date} from ${fromTime} to ${toTime}`;
            }
          } catch (error) {
            if (parkingHistoryBody) {
              parkingHistoryBody.innerHTML = `<tr style="box-shadow:none;"><td colspan="5" style="background:transparent; border:none;">${renderEmptyParkingHistory(error.message || "Unable to load parking history.")}</td></tr>`;
            }
            if (parkingHistoryCards) {
              parkingHistoryCards.innerHTML = renderEmptyParkingHistory(error.message || "Unable to load parking history.");
            }
            if (parkingHistoryMeta) parkingHistoryMeta.textContent = error.message || "Unable to load parking history.";
          }
        }

        function renderUpdateItem(scan) {
          const result = (scan.result || "invalid").toLowerCase();
          const action = (scan.action || "verify").toLowerCase();
          return `<div class="update-item">
        <span class="update-dot ${result} ${action}"></span>
        <div><p><strong>${scan.full_name || "Unknown Student"}</strong> <span class="update-action ${action}">${scan.action || "VERIFY"}</span></p>
          <p class="helper-text">${scan.gate_name || "Main Gate"} — ${toPHT(scan.scanned_at)}</p></div>
      </div>`;
        }

        const statIds = {
          students: document.querySelectorAll('.hero-card p')[0],
          vehicles: document.querySelectorAll('.hero-card p')[1],
          activeStickers: document.querySelectorAll('.hero-card p')[2],
          currentlyInside: insideCount
        };

        async function refreshDashboard() {
          try {
            const resp = await fetch("/api/dashboard-stats");
            const data = await resp.json();
            if (!data.ok) return;

            const m = data.metrics || {};
            if (statIds.students) statIds.students.textContent = m.students ?? "-";
            if (statIds.vehicles) statIds.vehicles.textContent = m.vehicles ?? "-";
            if (statIds.activeStickers) statIds.activeStickers.textContent = m.activeStickers ?? "-";
            if (insideCount) insideCount.textContent = m.currentlyInside ?? "-";

            const vehicles = data.insideVehicles || [];
            const insideCardsList = document.getElementById("insideVehiclesCards");
            if (insideBody) {
              insideBody.innerHTML = vehicles.length
                ? vehicles.map(renderInsideRow).join("")
                : `<tr id="insideEmptyRow"><td colspan="7">${renderEmptyInside()}</td></tr>`;
            }
            if (insideCardsList) {
               insideCardsList.innerHTML = vehicles.length
                ? vehicles.map(renderInsideCard).join("")
                : renderEmptyInside();
            }

            const parkingSlots = Array.isArray(data.parkingSlots) ? data.parkingSlots : [];
            const slotSummary = data.parkingSlotSummary || {};
            if (parkingSlotsListEl) {
              parkingSlotsListEl.innerHTML = parkingSlots.length
                ? parkingSlots.map(renderParkingSlotCard).join("")
                : renderEmptyParkingSlots();
            }
            if (parkingSlotsMetaEl) {
              const availableCount = typeof slotSummary.available === "number"
                ? slotSummary.available
                : parkingSlots.filter(slot => slot.occupancy === "available").length;
              const occupiedCount = typeof slotSummary.occupied === "number"
                ? slotSummary.occupied
                : parkingSlots.filter(slot => slot.occupancy === "occupied").length;
              const disabledCount = typeof slotSummary.disabled === "number"
                ? slotSummary.disabled
                : parkingSlots.filter(slot => slot.occupancy === "disabled").length;
              const totalCount = typeof slotSummary.total === "number"
                ? slotSummary.total
                : parkingSlots.length;
              parkingSlotsMetaEl.textContent = `${availableCount} available | ${occupiedCount} occupied | ${disabledCount} disabled | ${totalCount} total`;
            }

            const logs = data.movementLogs || [];
            if (movementTbody) {
              movementTbody.innerHTML = logs.length
                ? logs.map(renderMovementRow).join("")
                : `<tr id="movementEmptyRow"><td colspan="7"><div class="empty-state"><div class="empty-state-icon">📋</div><p>No scan records yet.</p></div></td></tr>`;
            }
            if (movementCards) {
               movementCards.innerHTML = logs.length
                ? logs.map(renderMovementCard).join("")
                : `<div class="empty-state"><div class="empty-state-icon">📋</div><p>No scan records.</p></div>`;
            }
            applySearch();

            if (latestUpdates) {
              latestUpdates.innerHTML = logs.length
                ? logs.slice(0, 8).map(renderUpdateItem).join("")
                : `<div class="empty-state"><div class="empty-state-icon">🔔</div><p>No updates yet.</p></div>`;
            }

            if (lastUpdatedEl) lastUpdatedEl.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
          } catch (err) { console.error(err); }
        }

        refreshDashboard();
        setInterval(refreshDashboard, 20000);
        if (refreshBtn) refreshBtn.addEventListener("click", refreshDashboard);
        if (parkingHistoryForm) {
          parkingHistoryForm.addEventListener("submit", (event) => {
            event.preventDefault();
            loadParkingHistory();
          });
        }
        loadParkingHistory();
      })();
    </script>
    <%- include("partials/footer") %>
