<%- include("partials/header") %>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Phone Camera Scanner</h1>
  </div>
  <p style="color: rgba(255,255,255,0.82); margin-top: 0.5rem;">
    Scan using phone camera, then forward ENTRY requests to the laptop monitor for slot assignment.
  </p>
</section>

<div class="overlap-wrapper auto-gate-shell" data-scan-cooldown="<%= scanCooldownSeconds %>">
  <section class="panel auto-gate-camera-panel">
    <div class="auto-gate-toolbar">
      <div>
        <h3>Live Camera Feed</h3>
        <p>Place the phone at the gate and keep the QR sticker within the frame.</p>
      </div>
      <div class="auto-gate-controls">
        <div>
          <label for="autoGateSelect">Gate</label>
          <select id="autoGateSelect">
            <option value="Main Gate">Main Gate</option>
            <option value="Side Gate">Side Gate</option>
            <option value="North Gate">North Gate</option>
            <option value="South Gate">South Gate</option>
          </select>
        </div>
        <button type="button" id="toggleAutoCameraBtn" class="auto-camera-toggle">Stop Camera</button>
      </div>
    </div>

    <div class="auto-indicator-row">
      <span id="chipAutoState" class="auto-chip state-live">Auto-Scan Active</span>
      <span id="chipCameraState" class="auto-chip state-live">Camera Ready</span>
      <span id="chipMlState" class="auto-chip state-idle">ML Detect: Warmup</span>
      <span id="chipRiskState" class="auto-chip state-idle">Risk: Unchecked</span>
      <span id="chipStabilityState" class="auto-chip state-idle">Stable Read: 0/2</span>
      <span id="chipCooldownState" class="auto-chip state-idle">Cooldown: Ready</span>
    </div>

    <div id="autoCameraWrapper" class="auto-camera-wrapper">
      <div id="autoQrReader"></div>

      <div id="cameraHud" class="auto-camera-hud" aria-hidden="true">
        <div class="hud-corners">
          <span class="corner tl"></span>
          <span class="corner tr"></span>
          <span class="corner bl"></span>
          <span class="corner br"></span>
        </div>
        <div class="scan-line"></div>
        <p class="hud-label">Align QR sticker inside frame</p>
      </div>

      <div id="processingOverlay" class="auto-processing-overlay" hidden>
        <div class="processing-box">
          <span class="processing-spinner" aria-hidden="true"></span>
          <p>Processing scan...</p>
        </div>
      </div>

      <p id="autoCameraStatus" class="auto-camera-status">Initializing rear camera...</p>
    </div>

    <p class="helper-text" style="margin-top:0.55rem;">
      ENTRY scans are queued for laptop guard confirmation. EXIT scans are saved automatically.
    </p>
  </section>

  <section class="panel auto-gate-result-panel">
    <div class="section-head">
      <h2>Detection Result</h2>
      <p>Review scan status. ENTRY is sent to laptop monitor for slot assignment.</p>
    </div>

    <div id="autoResultCard" class="auto-result-card state-idle">
      <h3 id="autoResultTitle">Waiting for QR detection</h3>
      <p id="autoResultMessage">Point the camera to a student vehicle QR sticker.</p>
      <div id="autoResultMeta" class="auto-result-meta"></div>
    </div>

    <div id="entryConfirmPanel" class="entry-confirm-panel" style="display:none;">
      <div class="entry-confirm-head">
        <h3>Confirm Entry Assignment</h3>
        <p>Guard confirmation is required before saving ENTRY.</p>
      </div>

      <div id="entryStickerDetails" class="entry-sticker-grid"></div>

      <div class="auto-slot-header">
        <strong>Available Parking Slots</strong>
        <span id="autoSlotStatus" class="helper-text">Loading slot map...</span>
      </div>
      <div id="autoSlotMap" class="auto-slot-map"></div>
      <p id="entryConfirmHint" class="helper-text"></p>

      <div class="entry-confirm-actions">
        <button type="button" id="confirmEntryBtn" class="entry-confirm-btn" disabled>Confirm ENTRY</button>
        <button type="button" id="cancelEntryBtn" class="entry-cancel-btn">Cancel</button>
      </div>
    </div>

    <div class="auto-session-panel">
      <div class="auto-session-head">
        <h3>Session Events</h3>
        <p>Latest activity in this browser session.</p>
      </div>
      <div id="sessionEventEmpty" class="auto-session-empty">No events yet.</div>
      <div id="sessionEventList" class="auto-session-list"></div>
    </div>

    <div class="auto-fallback-actions">
      <a href="/scanner" class="link-btn">Open Laptop Guard Monitor</a>
      <button type="button" id="resumeScannerBtn" class="auto-resume-btn">Resume Scanner</button>
    </div>
  </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
<script src="/js/qr-behavior-classifier.js"></script>
<script src="/js/ml-qr-detector.js"></script>
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script>
  (() => {
    const shell = document.querySelector(".auto-gate-shell");
    const cooldownSeconds = Number(shell?.dataset.scanCooldown || 10);
    const deferEntryConfirmation = true;

    const STABLE_READ_MIN_HITS = 2;
    const STABLE_READ_WINDOW_MS = 1400;
    const LOCAL_DEDUP_FLOOR_MS = 2500;

    const gateSelect = document.getElementById("autoGateSelect");
    const toggleCameraBtn = document.getElementById("toggleAutoCameraBtn");
    const resumeScannerBtn = document.getElementById("resumeScannerBtn");
    const cameraStatus = document.getElementById("autoCameraStatus");
    const processingOverlay = document.getElementById("processingOverlay");

    const chipAutoState = document.getElementById("chipAutoState");
    const chipCameraState = document.getElementById("chipCameraState");
    const chipMlState = document.getElementById("chipMlState");
    const chipRiskState = document.getElementById("chipRiskState");
    const chipStabilityState = document.getElementById("chipStabilityState");
    const chipCooldownState = document.getElementById("chipCooldownState");

    const resultCard = document.getElementById("autoResultCard");
    const resultTitle = document.getElementById("autoResultTitle");
    const resultMessage = document.getElementById("autoResultMessage");
    const resultMeta = document.getElementById("autoResultMeta");

    const entryConfirmPanel = document.getElementById("entryConfirmPanel");
    const entryStickerDetails = document.getElementById("entryStickerDetails");
    const autoSlotStatus = document.getElementById("autoSlotStatus");
    const autoSlotMap = document.getElementById("autoSlotMap");
    const entryConfirmHint = document.getElementById("entryConfirmHint");
    const confirmEntryBtn = document.getElementById("confirmEntryBtn");
    const cancelEntryBtn = document.getElementById("cancelEntryBtn");

    const sessionEventEmpty = document.getElementById("sessionEventEmpty");
    const sessionEventList = document.getElementById("sessionEventList");

    if (deferEntryConfirmation && entryConfirmPanel) {
      entryConfirmPanel.style.display = "none";
    }

    let html5QrCode = null;
    let cameraStarted = false;
    let processingScan = false;

    const QR_STATE = {
      UNKNOWN: (typeof Html5QrcodeScannerState !== "undefined" && Html5QrcodeScannerState?.UNKNOWN !== undefined)
        ? Html5QrcodeScannerState.UNKNOWN
        : 0,
      NOT_STARTED: (typeof Html5QrcodeScannerState !== "undefined" && Html5QrcodeScannerState?.NOT_STARTED !== undefined)
        ? Html5QrcodeScannerState.NOT_STARTED
        : 1,
      SCANNING: (typeof Html5QrcodeScannerState !== "undefined" && Html5QrcodeScannerState?.SCANNING !== undefined)
        ? Html5QrcodeScannerState.SCANNING
        : 2,
      PAUSED: (typeof Html5QrcodeScannerState !== "undefined" && Html5QrcodeScannerState?.PAUSED !== undefined)
        ? Html5QrcodeScannerState.PAUSED
        : 3
    };

    let selectedSlotId = null;
    let pendingToken = null;
    let pendingSticker = null;
    let pendingSlotOverview = null;

    let lastRiskAssessment = null;
    let latestMlMeta = null;

    let stableCandidateToken = "";
    let stableCandidateHits = 0;
    let stableCandidateFirstSeenMs = 0;

    const localCooldownUntilMs = new Map();
    const sessionEvents = [];

    function setChip(element, text, state) {
      if (!element) return;
      element.textContent = text;
      element.className = `auto-chip state-${state}`;
    }

    function setRiskChip(risk) {
      if (!risk || !chipRiskState) {
        setChip(chipRiskState, "Risk: Unchecked", "idle");
        return;
      }
      const scorePercent = Math.round((Number(risk.riskScore) || 0) * 100);
      if (risk.riskLevel === "high") {
        setChip(chipRiskState, `Risk: High (${scorePercent}%)`, "error");
        return;
      }
      if (risk.riskLevel === "medium") {
        setChip(chipRiskState, `Risk: Medium (${scorePercent}%)`, "warning");
        return;
      }
      setChip(chipRiskState, `Risk: Low (${scorePercent}%)`, "live");
    }

    function normalizeRiskAssessment(riskPayload, fallbackRisk = null) {
      if (!riskPayload || typeof riskPayload !== "object") {
        return fallbackRisk || null;
      }
      const level = String(
        riskPayload.riskLevel
        || riskPayload.risk_level
        || fallbackRisk?.riskLevel
        || "low"
      ).toLowerCase();
      const normalizedLevel = level === "high" || level === "medium" || level === "low"
        ? level
        : "low";
      const scoreRaw = Number(
        riskPayload.riskScore
        ?? riskPayload.risk_score
        ?? fallbackRisk?.riskScore
        ?? 0
      );
      const score = Math.max(0, Math.min(1, Number.isFinite(scoreRaw) ? scoreRaw : 0));
      const reasons = Array.isArray(riskPayload.reasons)
        ? riskPayload.reasons
        : (Array.isArray(riskPayload.risk_reasons) ? riskPayload.risk_reasons : []);
      return {
        riskLevel: normalizedLevel,
        riskScore: Math.round(score * 1000) / 1000,
        reasons: reasons
          .map((item) => String(item || "").trim())
          .filter(Boolean)
          .slice(0, 3)
      };
    }

    function classifyQrBehavior(rawValue) {
      if (!window.QRBehaviorClassifier || typeof window.QRBehaviorClassifier.classify !== "function") {
        return {
          riskScore: 0,
          riskLevel: "low",
          reasons: ["Behavior classifier unavailable."],
          features: {}
        };
      }
      return window.QRBehaviorClassifier.classify(rawValue);
    }

    function renderRiskMeta(risk) {
      if (!risk) return "";
      const reasons = Array.isArray(risk.reasons) ? risk.reasons : [];
      const leadReason = reasons[0] || "No anomaly reason available.";
      return `
        <p><strong>Risk:</strong> ${(risk.riskLevel || "low").toUpperCase()} (${Math.round((Number(risk.riskScore) || 0) * 100)}%)</p>
        <p><strong>Signal:</strong> ${leadReason}</p>
      `;
    }

    function renderMlMeta(meta) {
      if (!meta) return "";
      const confidence = Number(meta.ml_confidence ?? meta.confidence ?? 0);
      const processMs = Number(meta.process_ms ?? meta.processMs ?? 0);
      return `
        <p><strong>Detection Confidence:</strong> ${Math.round(confidence * 100)}%</p>
        <p><strong>Frame Process:</strong> ${processMs > 0 ? `${Math.round(processMs)}ms` : "N/A"}</p>
      `;
    }

    function updateMlChip(meta) {
      latestMlMeta = meta || null;
      if (!meta) {
        setChip(chipMlState, "ML Detect: Idle", "idle");
        return;
      }

      const confidence = Number(meta.confidence || meta.ml_confidence || 0);
      const confidencePercent = Math.round(confidence * 100);
      if (confidence >= 0.58) {
        setChip(chipMlState, `ML Detect: ${confidencePercent}%`, "live");
      } else if (confidence >= 0.4) {
        setChip(chipMlState, `ML Detect: ${confidencePercent}%`, "warning");
      } else {
        setChip(chipMlState, `ML Detect: ${confidencePercent}%`, "idle");
      }
    }

    function updateStabilityChip() {
      const hits = Math.max(0, Math.min(STABLE_READ_MIN_HITS, stableCandidateHits));
      setChip(chipStabilityState, `Stable Read: ${hits}/${STABLE_READ_MIN_HITS}`, hits >= STABLE_READ_MIN_HITS ? "live" : "idle");
    }

    function updateCooldownChip() {
      const now = Date.now();
      let nearestRemainingMs = 0;
      for (const until of localCooldownUntilMs.values()) {
        if (until > now) {
          const remaining = until - now;
          if (!nearestRemainingMs || remaining < nearestRemainingMs) {
            nearestRemainingMs = remaining;
          }
        }
      }

      if (!nearestRemainingMs) {
        setChip(chipCooldownState, "Cooldown: Ready", "idle");
        return;
      }

      const seconds = Math.max(1, Math.ceil(nearestRemainingMs / 1000));
      setChip(chipCooldownState, `Cooldown: ${seconds}s`, "warning");
    }

    setInterval(updateCooldownChip, 350);

    function setCameraStatus(message, kind = "neutral") {
      if (!cameraStatus) return;
      cameraStatus.textContent = message;
      cameraStatus.classList.remove("status-ok", "status-error");
      if (kind === "ok") cameraStatus.classList.add("status-ok");
      if (kind === "error") cameraStatus.classList.add("status-error");
    }

    function setProcessingOverlay(visible) {
      if (!processingOverlay) return;
      processingOverlay.hidden = !visible;
    }

    function setResultState(state, title, message, detailsHtml = "") {
      resultCard.className = `auto-result-card state-${state}`;
      resultTitle.textContent = title;
      resultMessage.textContent = message;
      resultMeta.innerHTML = detailsHtml || "";
    }

    function formatTime(date) {
      return new Intl.DateTimeFormat("en-PH", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      }).format(date);
    }

    function pushSessionEvent(kind, status, title, detail) {
      sessionEvents.unshift({
        kind,
        status,
        title,
        detail,
        at: new Date()
      });
      if (sessionEvents.length > 10) sessionEvents.pop();
      renderSessionEvents();
    }

    function renderSessionEvents() {
      if (!sessionEvents.length) {
        sessionEventEmpty.style.display = "";
        sessionEventList.innerHTML = "";
        return;
      }

      sessionEventEmpty.style.display = "none";
      sessionEventList.innerHTML = sessionEvents.map((event) => {
        const statusClass = event.status || "idle";
        return `
          <article class="session-event ${statusClass}">
            <div class="session-event-main">
              <h4>${event.title}</h4>
              <p>${event.detail || ""}</p>
            </div>
            <div class="session-event-meta">
              <span class="tag">${event.kind}</span>
              <time>${formatTime(event.at)}</time>
            </div>
          </article>
        `;
      }).join("");
    }

    function playTone(type = "ok") {
      try {
        const AudioCtx = window.AudioContext || window.webkitAudioContext;
        if (!AudioCtx) return;
        const ctx = new AudioCtx();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);

        if (type === "ok") {
          osc.frequency.setValueAtTime(760, ctx.currentTime);
          gain.gain.setValueAtTime(0.0001, ctx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.12, ctx.currentTime + 0.02);
          gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.2);
          osc.start();
          osc.stop(ctx.currentTime + 0.22);
          return;
        }

        osc.frequency.setValueAtTime(260, ctx.currentTime);
        gain.gain.setValueAtTime(0.0001, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.1, ctx.currentTime + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.3);
        osc.start();
        osc.stop(ctx.currentTime + 0.32);
      } catch (_error) {
        // Silent fallback
      }
    }

    function extractToken(decodedText) {
      const raw = String(decodedText || "").trim();
      if (!raw) return "";
      try {
        const url = new URL(raw);
        const parts = url.pathname.split("/").filter(Boolean);
        if (parts.length >= 2 && parts[0] === "verify") {
          return parts[1];
        }
      } catch (_error) {
        return raw;
      }
      return raw;
    }

    function captureSnapshotDataUrl() {
      const video = document.querySelector("#autoQrReader video");
      if (!video || !video.videoWidth || !video.videoHeight) return "";

      // Downscale snapshots to keep API payload small and reliable on mobile data.
      const maxEdge = 960;
      const sourceWidth = video.videoWidth;
      const sourceHeight = video.videoHeight;
      const scale = Math.min(1, maxEdge / Math.max(sourceWidth, sourceHeight));

      const canvas = document.createElement("canvas");
      canvas.width = Math.max(1, Math.round(sourceWidth * scale));
      canvas.height = Math.max(1, Math.round(sourceHeight * scale));
      const ctx = canvas.getContext("2d", { willReadFrequently: false });
      if (!ctx) return "";
      ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
      return canvas.toDataURL("image/jpeg", 0.72);
    }

    async function postJson(url, payload) {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify(payload)
      });

      const contentType = response.headers.get("content-type") || "";
      let data = { ok: false, message: "Invalid server response." };

      if (contentType.includes("application/json")) {
        try {
          data = await response.json();
        } catch (_jsonError) {
          data = { ok: false, message: "Invalid server response." };
        }
      } else {
        const responseText = await response.text();
        const redirectedToLogin = response.redirected && /\/login(?:[/?#]|$)/i.test(response.url || "");
        if (response.status === 401 || redirectedToLogin) {
          data = { ok: false, message: "Session expired. Please log in again on this device." };
        } else if (!responseText.trim()) {
          data = { ok: false, message: `Empty server response (${response.status}).` };
        } else {
          data = { ok: false, message: `Server returned an unexpected response (${response.status}).` };
        }
      }

      if (!response.ok || !contentType.includes("application/json")) {
        throw new Error(data.message || `Request failed (${response.status})`);
      }

      return data;
    }

    function groupSlotsByZone(slots) {
      return (slots || []).reduce((acc, slot) => {
        const zone = slot.zone || "General";
        if (!acc[zone]) acc[zone] = [];
        acc[zone].push(slot);
        return acc;
      }, {});
    }

    function renderSlotMap() {
      const slots = Array.isArray(pendingSlotOverview?.slots) ? pendingSlotOverview.slots : [];
      const summary = pendingSlotOverview?.summary || { total: 0, available: 0, occupied: 0, disabled: 0 };

      if (!slots.length) {
        autoSlotMap.innerHTML = '<div class="flash flash-error" style="margin:0;">No parking slots available right now.</div>';
        autoSlotStatus.textContent = "No slots configured";
        confirmEntryBtn.disabled = true;
        return;
      }

      const grouped = groupSlotsByZone(slots);
      autoSlotStatus.textContent = `${summary.available || 0} available of ${summary.total || slots.length}`;

      autoSlotMap.innerHTML = `
        <div class="auto-slot-summary">
          <span>Available: <strong>${summary.available || 0}</strong></span>
          <span>Occupied: <strong>${summary.occupied || 0}</strong></span>
          <span>Disabled: <strong>${summary.disabled || 0}</strong></span>
        </div>
        ${Object.keys(grouped).map((zone) => `
          <div class="auto-zone-block">
            <p class="auto-zone-title">${zone}</p>
            <div class="auto-zone-grid">
              ${grouped[zone].map((slot) => {
                const selected = String(selectedSlotId || "") === String(slot.id);
                const occupancy = slot.occupancy || "available";
                const selectable = occupancy === "available";
                const occupant = slot.occupied_by_name
                  ? `<small>${slot.occupied_by_name}</small>`
                  : "<small></small>";
                return `
                  <button
                    type="button"
                    class="auto-slot-btn ${occupancy} ${selected ? "selected" : ""}"
                    data-slot-id="${slot.id}"
                    data-slot-code="${slot.slot_code}"
                    ${selectable ? "" : "disabled"}>
                    <span>${slot.slot_code}</span>
                    ${occupant}
                  </button>
                `;
              }).join("")}
            </div>
          </div>
        `).join("")}
      `;

      autoSlotMap.querySelectorAll(".auto-slot-btn.available").forEach((button) => {
        button.addEventListener("click", () => {
          selectedSlotId = button.dataset.slotId;
          renderSlotMap();
          confirmEntryBtn.disabled = false;
          entryConfirmHint.textContent = `Selected slot: ${button.dataset.slotCode}`;
        });
      });
    }

    function renderEntryDetails(sticker) {
      const safe = sticker || {};
      entryStickerDetails.innerHTML = `
        <div><span>Authorized</span><strong>Yes</strong></div>
        <div><span>Student</span><strong>${safe.full_name || "-"}</strong></div>
        <div><span>Student ID</span><strong>${safe.student_number || "-"}</strong></div>
        <div><span>Plate Number</span><strong>${safe.plate_number || "-"}</strong></div>
        <div><span>Vehicle Type</span><strong>${safe.vehicle_type || safe.vehicle_model || "-"}</strong></div>
      `;
    }

    function hideEntryPanel() {
      pendingToken = null;
      pendingSticker = null;
      pendingSlotOverview = null;
      selectedSlotId = null;
      confirmEntryBtn.disabled = true;
      cancelEntryBtn.disabled = false;
      entryConfirmHint.textContent = "";
      entryStickerDetails.innerHTML = "";
      autoSlotMap.innerHTML = "";
      entryConfirmPanel.style.display = "none";
    }

    function setLocalCooldown(token, milliseconds) {
      if (!token) return;
      const until = Date.now() + Math.max(0, milliseconds);
      localCooldownUntilMs.set(token, until);
      updateCooldownChip();
    }

    function getLocalCooldownRemainingMs(token) {
      if (!token) return 0;
      const until = localCooldownUntilMs.get(token) || 0;
      const remaining = until - Date.now();
      return remaining > 0 ? remaining : 0;
    }

    function resetStability() {
      stableCandidateToken = "";
      stableCandidateHits = 0;
      stableCandidateFirstSeenMs = 0;
      updateStabilityChip();
    }

    async function pauseScanner() {
      if (!html5QrCode || !cameraStarted) return;
      try {
        await html5QrCode.pause();
      } catch (_error) {
        // ignore pause race conditions
      }
    }

    function getScannerState() {
      if (!html5QrCode || typeof html5QrCode.getState !== "function") return QR_STATE.UNKNOWN;
      try {
        return html5QrCode.getState();
      } catch (_error) {
        return QR_STATE.UNKNOWN;
      }
    }

    async function hardRestartScanner() {
      if (html5QrCode) {
        try {
          await html5QrCode.stop();
        } catch (_stopError) {
          // ignore stop race conditions
        }
        try {
          await html5QrCode.clear();
        } catch (_clearError) {
          // ignore clear race conditions
        }
      }

      html5QrCode = null;
      cameraStarted = false;
      toggleCameraBtn.textContent = "Stop Camera";
      resetStability();
      setCameraStatus("Reinitializing camera...", "ok");
      setChip(chipCameraState, "Reinitializing", "warning");
      setChip(chipAutoState, "Recovering Scanner", "warning");
      setChip(chipMlState, "ML Detect: Reinit", "warning");

      await startCamera();
    }

    async function resumeScanner(delayMs = 0) {
      const waitMs = Math.max(0, Number(delayMs) || 0);
      if (waitMs) {
        await new Promise((resolve) => window.setTimeout(resolve, waitMs));
      }

      if (!html5QrCode || !cameraStarted) {
        await startCamera();
        return;
      }

      const state = getScannerState();

      try {
        if (state === QR_STATE.SCANNING) {
          setCameraStatus("Scanner active", "ok");
          setChip(chipAutoState, "Auto-Scan Active", "live");
          setChip(chipCameraState, "Camera Ready", "live");
          resetStability();
          return;
        }

        if (state === QR_STATE.PAUSED) {
          await html5QrCode.resume();
          setCameraStatus("Scanner active", "ok");
          setChip(chipAutoState, "Auto-Scan Active", "live");
          setChip(chipCameraState, "Camera Ready", "live");
          resetStability();
          return;
        }

        await hardRestartScanner();
      } catch (_error) {
        setCameraStatus("Scanner resume failed. Reinitializing...", "error");
        await hardRestartScanner();
      }
    }

    async function fetchLatestSlotOverview() {
      const resp = await fetch("/api/parking-slot-overview");
      const data = await resp.json();
      if (!data.ok) {
        throw new Error(data.message || "Failed to load parking slots.");
      }
      return {
        slots: Array.isArray(data.slots) ? data.slots : [],
        summary: data.summary || { total: 0, available: 0, occupied: 0, disabled: 0 }
      };
    }

    async function processStableToken(token, decodedText, decodeMeta = null) {
      processingScan = true;
      setProcessingOverlay(true);
      setChip(chipAutoState, "Processing", "warning");
      await pauseScanner();
      lastRiskAssessment = classifyQrBehavior(decodedText || token);
      setRiskChip(lastRiskAssessment);
      if (lastRiskAssessment?.riskLevel === "high") {
        pushSessionEvent(
          "RISK",
          "warning",
          "High-risk QR content flagged",
          (lastRiskAssessment.reasons && lastRiskAssessment.reasons[0]) || "Suspicious payload pattern detected."
        );
      } else if (lastRiskAssessment?.riskLevel === "medium") {
        pushSessionEvent(
          "RISK",
          "warning",
          "Medium-risk QR content",
          (lastRiskAssessment.reasons && lastRiskAssessment.reasons[0]) || "Potentially unusual payload detected."
        );
      }
      if (decodeMeta) {
        updateMlChip({
          confidence: decodeMeta.ml_confidence ?? decodeMeta.confidence,
          processMs: decodeMeta.process_ms,
          model: decodeMeta.model || null
        });
      }
      setResultState("processing", "Processing QR scan", "Verifying sticker and determining movement...");

      try {
        const payload = {
          token,
          gate: gateSelect.value,
          defer_entry_confirmation: deferEntryConfirmation,
          snapshot_data_url: captureSnapshotDataUrl(),
          behavior_risk_level: lastRiskAssessment?.riskLevel || null,
          behavior_risk_score: Number(lastRiskAssessment?.riskScore || 0),
          behavior_risk_reasons: Array.isArray(lastRiskAssessment?.reasons)
            ? lastRiskAssessment.reasons.slice(0, 3)
            : [],
          detection_confidence: Number(decodeMeta?.ml_confidence || decodeMeta?.confidence || 0),
          detection_model: decodeMeta?.model || (window.MLQrCodeScanner ? "MLQrCodeScanner" : "html5-qrcode")
        };

        const data = await postJson("/api/auto-scan/detect", payload);
        lastRiskAssessment = normalizeRiskAssessment(data.behavior_risk, lastRiskAssessment);
        setRiskChip(lastRiskAssessment);

        if (data.duplicate_scan) {
          hideEntryPanel();
          const waitSeconds = Math.max(1, cooldownSeconds - Number(data.seconds_since_last_scan || 0));
          setLocalCooldown(token, waitSeconds * 1000);
          setResultState(
            "warning",
            "Duplicate scan ignored",
            data.message || `Please wait ${waitSeconds} seconds before scanning this sticker again.`,
            `${renderMlMeta(decodeMeta)}${renderRiskMeta(lastRiskAssessment)}`
          );
          pushSessionEvent("DUPLICATE", "warning", "Duplicate blocked", `Cooldown active (${waitSeconds}s)`);
          playTone("warn");
          await resumeScanner(900);
          return;
        }

        if (!data.ok) {
          hideEntryPanel();
          setLocalCooldown(token, LOCAL_DEDUP_FLOOR_MS);
          const statusLabel = (data.result || "INVALID").toUpperCase();
          setResultState(
            "invalid",
            `Unauthorized (${statusLabel})`,
            data.message || "QR sticker is not valid.",
            `${data.sticker ? `<p><strong>Student:</strong> ${data.sticker.full_name || "-"}</p>` : ""}${renderMlMeta(decodeMeta)}${renderRiskMeta(lastRiskAssessment)}`
          );
          pushSessionEvent("VERIFY", "error", `Scan rejected (${statusLabel})`, data.message || "Unauthorized sticker");
          playTone("warn");
          await resumeScanner(1100);
          return;
        }

        if (data.action === "EXIT" && data.movement_saved) {
          hideEntryPanel();
          setLocalCooldown(token, cooldownSeconds * 1000);
          setResultState(
            "success",
            "EXIT recorded",
            data.message || "Vehicle exit logged successfully.",
            `
              <p><strong>Student:</strong> ${data.sticker?.full_name || "-"}</p>
              <p><strong>Plate:</strong> ${data.sticker?.plate_number || "-"}</p>
              <p><strong>Released Slot:</strong> ${data.released_slot || "N/A"}</p>
              ${renderMlMeta(decodeMeta)}
              ${renderRiskMeta(lastRiskAssessment)}
            `
          );
          pushSessionEvent("EXIT", "ok", "Exit saved", `${data.sticker?.plate_number || "Unknown plate"} at ${gateSelect.value}`);
          playTone("ok");
          await resumeScanner(1200);
          return;
        }

        if (data.action === "ENTRY" && data.queued_for_guard) {
          hideEntryPanel();
          setLocalCooldown(token, cooldownSeconds * 1000);
          setResultState(
            "success",
            "ENTRY sent to laptop monitor",
            data.message || "Waiting for guard slot assignment on monitor console.",
            `
              <p><strong>Student:</strong> ${data.sticker?.full_name || "-"}</p>
              <p><strong>Plate:</strong> ${data.sticker?.plate_number || "-"}</p>
              <p><strong>Gate:</strong> ${gateSelect.value}</p>
              <p><strong>Queue ID:</strong> ${data.pending_entry_id || "-"}</p>
              ${renderMlMeta(decodeMeta)}
              ${renderRiskMeta(lastRiskAssessment)}
            `
          );
          setChip(chipAutoState, "Queued for Guard", "warning");
          pushSessionEvent(
            "ENTRY",
            "ok",
            "Entry queued for laptop guard",
            `${data.sticker?.plate_number || "Unknown plate"} at ${gateSelect.value}`
          );
          playTone("ok");
          await resumeScanner(850);
          return;
        }

        if (data.action === "ENTRY" && data.requires_confirmation) {
          pendingToken = token;
          pendingSticker = data.sticker || null;
          pendingSlotOverview = data.parkingSlotOverview || { slots: [], summary: { total: 0, available: 0, occupied: 0, disabled: 0 } };
          selectedSlotId = null;
          confirmEntryBtn.disabled = true;

          renderEntryDetails(pendingSticker);
          renderSlotMap();
          entryConfirmPanel.style.display = "block";

          setResultState(
            "entry",
            "ENTRY detected - guard confirmation required",
            data.message || "Select a parking slot and confirm to save ENTRY.",
            `
              <p><strong>Student:</strong> ${pendingSticker?.full_name || "-"}</p>
              <p><strong>Plate:</strong> ${pendingSticker?.plate_number || "-"}</p>
              <p><strong>Vehicle Type:</strong> ${pendingSticker?.vehicle_type || pendingSticker?.vehicle_model || "-"}</p>
              ${renderMlMeta(decodeMeta)}
              ${renderRiskMeta(lastRiskAssessment)}
            `
          );
          setChip(chipAutoState, "Awaiting Guard", "warning");
          pushSessionEvent("ENTRY", "warning", "Entry pending confirmation", `${pendingSticker?.plate_number || "Unknown plate"} waiting for slot assignment`);
          playTone("ok");
          return;
        }

        hideEntryPanel();
        setResultState("warning", "Scan completed", data.message || "No action was recorded.", `${renderMlMeta(decodeMeta)}${renderRiskMeta(lastRiskAssessment)}`);
        pushSessionEvent("VERIFY", "warning", "No movement saved", data.message || "Review scanner result");
        await resumeScanner(900);
      } catch (error) {
        hideEntryPanel();
        setResultState("error", "Scan failed", error.message || "Unable to process this scan right now.", `${renderMlMeta(decodeMeta)}${renderRiskMeta(lastRiskAssessment)}`);
        setCameraStatus(error.message || "Scan failed", "error");
        pushSessionEvent("ERROR", "error", "Scan processing error", error.message || "Unknown scanner error");
        playTone("warn");
        await resumeScanner(1200);
      } finally {
        processingScan = false;
        setProcessingOverlay(false);
      }
    }

    async function handleDecodedText(decodedText, decodeMeta = null) {
      if (!cameraStarted || processingScan) return;
      if (entryConfirmPanel.style.display !== "none") return;

      if (decodeMeta) {
        updateMlChip({
          confidence: decodeMeta.ml_confidence ?? decodeMeta.confidence,
          processMs: decodeMeta.process_ms,
          model: decodeMeta.model || null
        });
      }

      const token = extractToken(decodedText);
      if (!token) return;

      const remainingCooldown = getLocalCooldownRemainingMs(token);
      if (remainingCooldown > 0) {
        const seconds = Math.max(1, Math.ceil(remainingCooldown / 1000));
        setChip(chipCooldownState, `Cooldown: ${seconds}s`, "warning");
        return;
      }

      const now = Date.now();
      if (token !== stableCandidateToken || now - stableCandidateFirstSeenMs > STABLE_READ_WINDOW_MS) {
        stableCandidateToken = token;
        stableCandidateHits = 1;
        stableCandidateFirstSeenMs = now;
        updateStabilityChip();
        setCameraStatus("Detecting stable QR read...", "ok");
        return;
      }

      stableCandidateHits += 1;
      updateStabilityChip();

      if (stableCandidateHits < STABLE_READ_MIN_HITS) {
        return;
      }

      resetStability();
      setLocalCooldown(token, LOCAL_DEDUP_FLOOR_MS);
      await processStableToken(token, decodedText, decodeMeta);
    }

    async function startCamera() {
      if (!html5QrCode) {
        if (window.MLQrCodeScanner) {
          html5QrCode = new window.MLQrCodeScanner("autoQrReader", {
            targetFps: 30,
            confidenceThreshold: 0.58,
            maxProcessWidth: 640,
            perspectiveSize: 280,
            onMlMetrics: (metrics) => {
              updateMlChip({
                confidence: metrics?.confidence,
                processMs: metrics?.processMs,
                model: metrics?.usedDetector ? "BarcodeDetector+jsQR" : "jsQR-fallback"
              });
            }
          });
          setChip(chipMlState, "ML Detect: Enabled", "live");
        } else {
          html5QrCode = new Html5Qrcode("autoQrReader");
          setChip(chipMlState, "ML Detect: Fallback", "warning");
        }
      }

      const config = {
        fps: 30,
        qrbox: { width: 260, height: 260 },
        aspectRatio: 1.333333,
        disableFlip: false
      };

      const onFailure = () => {
        // Keep scanning silently for unreadable frames.
      };

      setCameraStatus("Requesting camera permission...");
      setChip(chipCameraState, "Opening Camera", "warning");

      try {
        await html5QrCode.start(
          { facingMode: { exact: "environment" } },
          config,
          handleDecodedText,
          onFailure
        );
        cameraStarted = true;
        toggleCameraBtn.textContent = "Stop Camera";
        setCameraStatus("Rear camera active", "ok");
        setChip(chipAutoState, "Auto-Scan Active", "live");
        setChip(chipCameraState, "Camera Ready", "live");
        if (!window.MLQrCodeScanner) {
          setChip(chipMlState, "ML Detect: Fallback", "warning");
        }
        setResultState("idle", "Waiting for QR detection", "Point the camera to a student vehicle QR sticker.");
        return;
      } catch (_rearError) {
        // Fallback below.
      }

      try {
        const getCamerasFn = typeof html5QrCode.constructor.getCameras === "function"
          ? html5QrCode.constructor.getCameras.bind(html5QrCode.constructor)
          : (typeof Html5Qrcode !== "undefined" && typeof Html5Qrcode.getCameras === "function"
            ? Html5Qrcode.getCameras.bind(Html5Qrcode)
            : null);

        const devices = getCamerasFn ? await getCamerasFn() : [];
        if (!devices || devices.length === 0) {
          throw new Error("No camera found on this device.");
        }
        const rear = devices.find((d) => /back|rear|environment/i.test(d.label)) || devices[0];
        await html5QrCode.start(rear.id, config, handleDecodedText, onFailure);
        cameraStarted = true;
        toggleCameraBtn.textContent = "Stop Camera";
        setCameraStatus("Camera active", "ok");
        setChip(chipAutoState, "Auto-Scan Active", "live");
        setChip(chipCameraState, "Camera Ready", "live");
        if (!window.MLQrCodeScanner) {
          setChip(chipMlState, "ML Detect: Fallback", "warning");
        }
        setResultState("idle", "Waiting for QR detection", "Point the camera to a student vehicle QR sticker.");
      } catch (error) {
        cameraStarted = false;
        toggleCameraBtn.textContent = "Start Camera";
        const message = String(error && error.message ? error.message : error);
        const prettyMessage = /permission|denied/i.test(message)
          ? "Camera permission denied. Allow camera access and retry."
          : message;
        setCameraStatus(prettyMessage, "error");
        setChip(chipCameraState, "Camera Error", "error");
        setChip(chipAutoState, "Scanner Stopped", "idle");
        setChip(chipMlState, "ML Detect: Offline", "error");
        setResultState("error", "Camera unavailable", prettyMessage);
        pushSessionEvent("ERROR", "error", "Camera unavailable", prettyMessage);
      }
    }

    async function stopCamera() {
      if (!html5QrCode && !cameraStarted) return;

      if (html5QrCode) {
        try {
          await html5QrCode.stop();
        } catch (_stopError) {
          // ignore stop race conditions
        }

        try {
          await html5QrCode.clear();
        } catch (_clearError) {
          // ignore clear race conditions
        }
      }

      html5QrCode = null;
      cameraStarted = false;
      toggleCameraBtn.textContent = "Start Camera";
      setCameraStatus("Camera stopped");
      setChip(chipCameraState, "Camera Stopped", "idle");
      setChip(chipAutoState, "Scanner Stopped", "idle");
      setChip(chipMlState, "ML Detect: Idle", "idle");
      setChip(chipRiskState, "Risk: Unchecked", "idle");
      resetStability();
      setProcessingOverlay(false);
    }

    toggleCameraBtn.addEventListener("click", async () => {
      if (cameraStarted) {
        await stopCamera();
      } else {
        await startCamera();
      }
    });

    resumeScannerBtn.addEventListener("click", async () => {
      hideEntryPanel();
      setResultState("idle", "Scanner resumed", "Waiting for the next QR scan.");
      pushSessionEvent("SYSTEM", "ok", "Scanner resumed", `Gate: ${gateSelect.value}`);
      if (!cameraStarted) {
        await startCamera();
      } else {
        await resumeScanner(0);
      }
    });

    cancelEntryBtn.addEventListener("click", async () => {
      const plate = pendingSticker?.plate_number || "Unknown plate";
      hideEntryPanel();
      setResultState("idle", "Entry confirmation cancelled", "Waiting for the next QR scan.");
      setChip(chipAutoState, "Auto-Scan Active", "live");
      pushSessionEvent("ENTRY", "warning", "Entry cancelled", `${plate} was not recorded`);
      await resumeScanner(500);
    });

    confirmEntryBtn.addEventListener("click", async () => {
      if (!pendingToken) {
        entryConfirmHint.textContent = "No pending entry to confirm.";
        return;
      }
      if (!selectedSlotId) {
        entryConfirmHint.textContent = "Please select a parking slot before confirming ENTRY.";
        return;
      }

      confirmEntryBtn.disabled = true;
      cancelEntryBtn.disabled = true;
      entryConfirmHint.textContent = "Saving entry record...";
      setProcessingOverlay(true);

      try {
        const payload = {
          token: pendingToken,
          gate: gateSelect.value,
          slot_id: selectedSlotId,
          snapshot_data_url: captureSnapshotDataUrl(),
          behavior_risk_level: lastRiskAssessment?.riskLevel || null,
          behavior_risk_score: Number(lastRiskAssessment?.riskScore || 0),
          behavior_risk_reasons: Array.isArray(lastRiskAssessment?.reasons)
            ? lastRiskAssessment.reasons.slice(0, 3)
            : [],
          detection_confidence: Number(latestMlMeta?.confidence || latestMlMeta?.ml_confidence || 0),
          detection_model: latestMlMeta?.model || (window.MLQrCodeScanner ? "MLQrCodeScanner" : "html5-qrcode")
        };

        const data = await postJson("/api/auto-scan/confirm-entry", payload);
        if (!data.ok) {
          throw new Error(data.message || "Failed to save entry.");
        }
        lastRiskAssessment = normalizeRiskAssessment(data.behavior_risk, lastRiskAssessment);
        setRiskChip(lastRiskAssessment);

        setLocalCooldown(pendingToken, cooldownSeconds * 1000);

        hideEntryPanel();
        setResultState(
          "success",
          "ENTRY recorded",
          data.message || "Entry logged successfully.",
          `
            <p><strong>Student:</strong> ${data.sticker?.full_name || "-"}</p>
            <p><strong>Plate:</strong> ${data.sticker?.plate_number || "-"}</p>
            <p><strong>Assigned Slot:</strong> ${data.parking_slot || "-"}</p>
            <p><strong>Assigned Area:</strong> ${data.assigned_area || "-"}</p>
            ${renderRiskMeta(lastRiskAssessment)}
          `
        );

        setChip(chipAutoState, "Auto-Scan Active", "live");
        pushSessionEvent("ENTRY", "ok", "Entry saved", `${data.sticker?.plate_number || "Unknown plate"} assigned to ${data.parking_slot || "N/A"}`);
        playTone("ok");
        await resumeScanner(1100);
      } catch (error) {
        entryConfirmHint.textContent = error.message || "Failed to save entry.";
        confirmEntryBtn.disabled = false;
        cancelEntryBtn.disabled = false;
        pushSessionEvent("ENTRY", "error", "Entry save failed", error.message || "Unknown error");
        playTone("warn");

        try {
          pendingSlotOverview = await fetchLatestSlotOverview();
          renderSlotMap();
        } catch (_loadError) {
          // keep current map if refresh fails
        }
      } finally {
        setProcessingOverlay(false);
      }
    });

    renderSessionEvents();
    updateStabilityChip();
    updateCooldownChip();
    setRiskChip(null);
    updateMlChip(null);
    startCamera();
  })();
</script>

