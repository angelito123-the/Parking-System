<%- include("partials/header") %>

<%
  const safeMetrics = typeof metrics === "object" && metrics ? metrics : {};
  const safeInsideVehicles = Array.isArray(insideVehicles) ? insideVehicles : [];
  const safeOverstayAlerts = Array.isArray(overstayAlerts) ? overstayAlerts : [];
  const safeVisitorLogs = Array.isArray(visitorLogs) ? visitorLogs : [];
  const summary = typeof parkingSlotSummary === "object" && parkingSlotSummary
    ? parkingSlotSummary
    : { total: 0, available: 0, occupied: 0, disabled: 0 };
%>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Security Operations</h2>
    <h1>Guard Dashboard</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Today Entries</h3>
      <p><%= safeMetrics.todayEntries || 0 %></p>
    </div>
    <div class="hero-card">
      <h3>Today Exits</h3>
      <p><%= safeMetrics.todayExits || 0 %></p>
    </div>
    <div class="hero-card">
      <h3>Inside Campus</h3>
      <p><%= safeMetrics.currentlyInside || 0 %></p>
    </div>
    <div class="hero-card" style="background: rgba(190, 18, 60, 0.22); border-color: rgba(251, 113, 133, 0.45);">
      <h3>Alert Notifications</h3>
      <p><%= safeMetrics.overstayAlerts || 0 %></p>
    </div>
    <div class="hero-card">
      <h3>Pending Approvals</h3>
      <p><%= safeMetrics.pendingApprovals || 0 %></p>
    </div>
  </div>
</section>

<div class="overlap-wrapper" style="display:grid; gap:1.4rem;">
  <section class="panel quick-links-panel">
    <div class="section-head">
      <h2>Guard Workflow</h2>
      <p>Follow this sequence to process vehicles quickly with fewer errors.</p>
    </div>
    <div class="quick-links-grid workflow-grid">
      <a href="/scanner/auto" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 1</span>
        <h3>Open Phone Camera</h3>
        <p>Start automatic QR capture at the gate camera station.</p>
      </a>
      <a href="/scanner" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 2</span>
        <h3>Confirm Entry and Assign Slot</h3>
        <p>Review pending scans and approve parking slot assignment.</p>
      </a>
      <a href="/guard" class="quick-link-card workflow-card">
        <span class="workflow-step">Step 3</span>
        <h3>Monitor Queue and Alerts</h3>
        <p>Track phone status, queue health, and overstay notifications.</p>
      </a>
    </div>
  </section>

  <section class="panel queue-health-panel">
    <div class="section-head">
      <h2>Queue Health</h2>
      <p>Live status of the phone camera feed used for gate QR detection.</p>
    </div>
    <div class="queue-health-grid">
      <article class="queue-health-card">
        <p class="queue-health-label">Phone Status</p>
        <p>
          <span id="guardHealthStatusBadge" class="queue-health-badge state-offline">Offline</span>
        </p>
        <p id="guardHealthSummary" class="queue-health-value">Waiting for heartbeat...</p>
      </article>
      <article class="queue-health-card">
        <p class="queue-health-label">Last Heartbeat</p>
        <p id="guardHealthLastHeartbeat" class="queue-health-value">-</p>
      </article>
      <article class="queue-health-card">
        <p class="queue-health-label">Last Scan Received</p>
        <p id="guardHealthLastScan" class="queue-health-value">-</p>
      </article>
      <article class="queue-health-card">
        <p class="queue-health-label">Device / Gate</p>
        <p id="guardHealthDevice" class="queue-health-value">-</p>
        <p id="guardHealthGate" class="queue-health-subvalue">-</p>
      </article>
    </div>
    <p id="guardHealthHint" class="helper-text" style="margin-top:0.55rem;">
      Open <a href="/scanner/auto" class="link-btn">Phone Camera Scan</a> on the phone to start heartbeat updates.
    </p>
  </section>

  <section class="panel remote-queue-panel">
    <div class="section-head">
      <h2>Gate Console Assignment</h2>
      <p>Choose parking slots for phone-scanned ENTRY requests from this guard dashboard.</p>
    </div>
    <div class="remote-queue-toolbar">
      <p id="guardQueueStatus" class="helper-text">Loading pending phone entries...</p>
      <button type="button" id="guardQueueRefreshBtn" class="btn-sm">Refresh List</button>
    </div>
    <div id="guardQueueLiveAlert" class="remote-queue-live-alert" hidden></div>
    <div id="guardQueueEmpty" class="empty-state" style="padding:1rem;">
      <p>No pending phone entry requests right now.</p>
    </div>
    <div id="guardQueueList" class="remote-queue-list"></div>
    <p class="helper-text" style="margin-top:0.65rem;">
      Need full controls? <a href="/scanner" class="link-btn">Open Gate Console</a>
    </p>
  </section>

  <section class="panel">
    <div class="section-head">
      <h2>Current Occupancy</h2>
      <p>
        <%= summary.available || 0 %> available |
        <%= summary.occupied || 0 %> occupied |
        <%= summary.disabled || 0 %> disabled |
        <%= summary.total || 0 %> total
      </p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Student</th>
            <th>Plate</th>
            <th>Slot</th>
            <th>Gate</th>
            <th>Duration</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (!safeInsideVehicles.length) { %>
            <tr>
              <td colspan="6">
                <div class="empty-state">
                  <p>No vehicles currently inside.</p>
                </div>
              </td>
            </tr>
          <% } %>
          <% safeInsideVehicles.forEach((item) => { %>
            <tr>
              <td>
                <strong><%= item.full_name || "-" %></strong><br />
                <small><%= item.student_number || "-" %></small>
              </td>
              <td><%= item.plate_number || "-" %></td>
              <td><%= item.parking_slot || "-" %></td>
              <td><%= item.entry_gate || "-" %></td>
              <td><%= item.duration_label || "-" %></td>
              <td>
                <% if (item.is_overstay) { %>
                  <span class="badge badge-overstay">Overstay</span>
                <% } else { %>
                  <span class="badge badge-inside">Inside</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <h2>Alert Notifications</h2>
      <p>Vehicles parked beyond <%= overstayLimitLabel || "4" %> hour(s).</p>
    </div>
    <div class="updates-list">
      <% if (!safeOverstayAlerts.length) { %>
        <div class="empty-state"><p>No active alerts right now.</p></div>
      <% } %>
      <% safeOverstayAlerts.forEach((item) => { %>
        <div class="update-item">
          <span class="update-dot invalid"></span>
          <div>
            <p>
              <strong><%= item.full_name || "Unknown Student" %></strong>
              <span class="badge badge-overstay">Overstay</span>
            </p>
            <p class="helper-text">
              <%= item.plate_number || "-" %> | Slot <%= item.parking_slot || "-" %> |
              <%= item.overstay_label || "Over limit" %>
            </p>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <h2>Visitor Logs</h2>
      <p>Latest valid gate movements.</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date/Time</th>
            <th>Student</th>
            <th>Plate</th>
            <th>Slot</th>
            <th>Gate</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (!safeVisitorLogs.length) { %>
            <tr>
              <td colspan="6">
                <div class="empty-state"><p>No logs available yet.</p></div>
              </td>
            </tr>
          <% } %>
          <% safeVisitorLogs.forEach((log) => { %>
            <tr>
              <td><%= new Date(log.scanned_at).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %></td>
              <td>
                <strong><%= log.full_name || "-" %></strong><br />
                <small><%= log.student_number || "-" %></small>
              </td>
              <td><%= log.plate_number || "-" %></td>
              <td><%= log.parking_slot || "-" %></td>
              <td><%= log.gate || "-" %></td>
              <td>
                <span class="badge badge-<%= String(log.action || '').toLowerCase() %>"><%= log.action || "-" %></span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</div>

<div id="guardEntryModal" class="slot-history-modal" aria-hidden="true">
  <div class="slot-history-backdrop" data-guard-close></div>
  <article class="slot-history-dialog remote-entry-dialog" role="dialog" aria-modal="true" aria-labelledby="guardEntryModalTitle">
    <div class="slot-history-head">
      <h3 id="guardEntryModalTitle">Confirm Phone Camera Entry</h3>
      <button type="button" id="guardEntryCloseBtn" class="slot-history-close" aria-label="Close">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6l12 12"></path>
          <path d="M18 6 6 18"></path>
        </svg>
      </button>
    </div>
    <p id="guardEntryMeta" class="helper-text" style="margin-bottom:0.65rem;"></p>

    <div id="guardEntrySnapshotWrap" class="remote-entry-snapshot" style="display:none;">
      <img id="guardEntrySnapshotImg" alt="Phone camera snapshot proof" />
    </div>

    <div class="auto-slot-header" style="margin-top:0.35rem;">
      <strong>Assign Parking Slot</strong>
      <span id="guardSlotStatus" class="helper-text">Loading slot map...</span>
    </div>
    <div id="guardSlotQuickStrip" class="guard-slot-quick-strip"></div>
    <div id="guardSlotMap" class="guard-slot-map"></div>
    <p id="guardEntryHint" class="helper-text" style="margin-top:0.4rem;"></p>

    <div class="remote-entry-actions">
      <button type="button" id="guardEntryConfirmBtn" class="btn-sm">Confirm ENTRY</button>
      <button type="button" id="guardEntryCancelBtn" class="btn-sm danger">Cancel Request</button>
    </div>
  </article>
</div>

<script>
  (() => {
    const queueStatus = document.getElementById("guardQueueStatus");
    const queueRefreshBtn = document.getElementById("guardQueueRefreshBtn");
    const queueLiveAlert = document.getElementById("guardQueueLiveAlert");
    const queueEmpty = document.getElementById("guardQueueEmpty");
    const queueList = document.getElementById("guardQueueList");
    const healthStatusBadge = document.getElementById("guardHealthStatusBadge");
    const healthSummary = document.getElementById("guardHealthSummary");
    const healthLastHeartbeat = document.getElementById("guardHealthLastHeartbeat");
    const healthLastScan = document.getElementById("guardHealthLastScan");
    const healthDevice = document.getElementById("guardHealthDevice");
    const healthGate = document.getElementById("guardHealthGate");
    const healthHint = document.getElementById("guardHealthHint");

    const guardEntryModal = document.getElementById("guardEntryModal");
    const guardEntryCloseBtn = document.getElementById("guardEntryCloseBtn");
    const guardEntryMeta = document.getElementById("guardEntryMeta");
    const guardEntrySnapshotWrap = document.getElementById("guardEntrySnapshotWrap");
    const guardEntrySnapshotImg = document.getElementById("guardEntrySnapshotImg");
    const guardSlotStatus = document.getElementById("guardSlotStatus");
    const guardSlotQuickStrip = document.getElementById("guardSlotQuickStrip");
    const guardSlotMap = document.getElementById("guardSlotMap");
    const guardEntryHint = document.getElementById("guardEntryHint");
    const guardEntryConfirmBtn = document.getElementById("guardEntryConfirmBtn");
    const guardEntryCancelBtn = document.getElementById("guardEntryCancelBtn");

    let pendingEntries = [];
    let activeEntryId = null;
    let latestEntryId = 0;
    let didInitialLoad = false;
    let lastAutoOpenedEntryId = 0;
    let liveAlertTimer = null;
    let selectedSlotId = null;
    let slotOverview = { slots: [], summary: { total: 0, available: 0, occupied: 0, disabled: 0 } };
    let healthOnlineWindowSeconds = 18;
    let liveEventSource = null;
    let liveReconnectTimer = null;
    let fallbackPollTimer = null;
    let queueRefreshTimer = null;
    let isLiveConnected = false;

    function escapeHtml(value) {
      return String(value == null ? "" : value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function formatQueuedAt(value) {
      const dt = new Date(value);
      if (Number.isNaN(dt.getTime())) return "-";
      return new Intl.DateTimeFormat("en-PH", {
        month: "short",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit"
      }).format(dt);
    }

    function formatDateTime(value) {
      const dt = new Date(value);
      if (Number.isNaN(dt.getTime())) return "-";
      return new Intl.DateTimeFormat("en-PH", {
        month: "short",
        day: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      }).format(dt);
    }

    function formatRelativeSeconds(seconds) {
      const safeSeconds = Number(seconds);
      if (!Number.isFinite(safeSeconds)) return "just now";
      const rounded = Math.max(0, Math.floor(safeSeconds));
      if (rounded < 60) return `${rounded}s ago`;
      const minutes = Math.floor(rounded / 60);
      if (minutes < 60) return `${minutes}m ago`;
      const hours = Math.floor(minutes / 60);
      if (hours < 24) return `${hours}h ago`;
      const days = Math.floor(hours / 24);
      return `${days}d ago`;
    }

    function applyHealthState(payload) {
      if (!healthStatusBadge || !healthSummary || !healthLastHeartbeat || !healthLastScan || !healthDevice || !healthGate) {
        return;
      }

      const primary = payload?.primary || null;
      const onlineDevices = Number(payload?.online_devices || 0);
      const totalDevices = Number(payload?.total_devices || 0);
      const isOnline = Boolean(primary?.is_online);

      if (!primary) {
        healthStatusBadge.className = "queue-health-badge state-offline";
        healthStatusBadge.textContent = "Offline";
        healthSummary.textContent = "No phone heartbeat received yet.";
        healthLastHeartbeat.textContent = "-";
        healthLastScan.textContent = "-";
        healthDevice.textContent = "-";
        healthGate.textContent = "-";
        if (healthHint) {
          healthHint.textContent = "Open Phone Camera Scan on the gate phone to start live heartbeat updates.";
        }
        return;
      }

      healthStatusBadge.className = `queue-health-badge ${isOnline ? "state-online" : "state-offline"}`;
      healthStatusBadge.textContent = isOnline ? "Online" : "Offline";
      healthSummary.textContent = isOnline
        ? `Phone is active (${formatRelativeSeconds(primary.heartbeat_age_seconds)}).`
        : `No heartbeat within ${healthOnlineWindowSeconds}s (${formatRelativeSeconds(primary.heartbeat_age_seconds)}).`;

      healthLastHeartbeat.textContent = primary.last_heartbeat_at
        ? `${formatDateTime(primary.last_heartbeat_at)} (${formatRelativeSeconds(primary.heartbeat_age_seconds)})`
        : "-";
      healthLastScan.textContent = primary.last_scan_received_at
        ? `${formatDateTime(primary.last_scan_received_at)} (${formatRelativeSeconds(primary.scan_age_seconds)})`
        : "No scan received yet";
      healthDevice.textContent = primary.device_id || "-";
      healthGate.textContent = primary.gate_id ? `Gate: ${primary.gate_id}` : "Gate: -";

      if (healthHint) {
        healthHint.textContent = totalDevices > 1
          ? `${onlineDevices}/${totalDevices} phone scanner device(s) online.`
          : (isOnline ? "Phone scanner heartbeat is healthy." : "Phone scanner is offline. Check camera page or connection.");
      }
    }

    async function fetchQueueHealth({ silent = false } = {}) {
      if (!silent && healthSummary) {
        healthSummary.textContent = "Checking phone heartbeat...";
      }

      try {
        const resp = await fetch("/api/auto-scan/health?limit=5", {
          credentials: "same-origin",
          cache: "no-store"
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to load queue health (${resp.status})`);
        }
        healthOnlineWindowSeconds = Math.max(5, Number(data.online_window_seconds) || healthOnlineWindowSeconds);
        applyHealthState(data);
      } catch (error) {
        if (!silent && healthSummary) {
          healthSummary.textContent = error.message || "Unable to load queue health.";
        }
        applyHealthState({ primary: null, total_devices: 0, online_devices: 0 });
      }
    }

    function safeParseJson(raw) {
      try {
        return JSON.parse(raw);
      } catch (_error) {
        return null;
      }
    }

    function scheduleQueueRefresh(delayMs = 120) {
      if (queueRefreshTimer) return;
      queueRefreshTimer = window.setTimeout(async () => {
        queueRefreshTimer = null;
        await fetchPendingEntries({ silent: true });
      }, Math.max(40, Number(delayMs) || 120));
    }

    function stopFallbackPolling() {
      if (fallbackPollTimer) {
        clearInterval(fallbackPollTimer);
        fallbackPollTimer = null;
      }
    }

    function startFallbackPolling() {
      if (fallbackPollTimer) return;
      fallbackPollTimer = window.setInterval(() => {
        if (isLiveConnected) return;
        fetchPendingEntries({ silent: true });
        fetchQueueHealth({ silent: true });
      }, 10000);
    }

    function scheduleLiveReconnect() {
      if (liveReconnectTimer) return;
      liveReconnectTimer = window.setTimeout(() => {
        liveReconnectTimer = null;
        connectLiveEvents();
      }, 2500);
    }

    function closeLiveEvents() {
      if (liveReconnectTimer) {
        clearTimeout(liveReconnectTimer);
        liveReconnectTimer = null;
      }
      if (liveEventSource) {
        try {
          liveEventSource.close();
        } catch (_error) {
          // ignore close race
        }
        liveEventSource = null;
      }
      isLiveConnected = false;
    }

    function connectLiveEvents() {
      if (typeof window.EventSource !== "function") {
        startFallbackPolling();
        if (queueStatus) queueStatus.textContent = "Live updates are not supported in this browser.";
        return;
      }

      if (liveReconnectTimer) {
        clearTimeout(liveReconnectTimer);
        liveReconnectTimer = null;
      }
      if (liveEventSource) {
        try {
          liveEventSource.close();
        } catch (_error) {
          // ignore reconnect race
        }
        liveEventSource = null;
      }

      const source = new EventSource("/api/auto-scan/events");
      liveEventSource = source;

      source.addEventListener("open", () => {
        isLiveConnected = true;
        stopFallbackPolling();
      });

      source.addEventListener("connected", () => {
        scheduleQueueRefresh(70);
      });

      source.addEventListener("queue-health", (event) => {
        const payload = safeParseJson(event.data);
        if (!payload || typeof payload !== "object") return;
        healthOnlineWindowSeconds = Math.max(5, Number(payload.online_window_seconds) || healthOnlineWindowSeconds);
        applyHealthState(payload);
      });

      source.addEventListener("pending-entry-created", () => {
        scheduleQueueRefresh(60);
      });

      source.addEventListener("pending-entry-updated", () => {
        scheduleQueueRefresh(80);
      });

      source.addEventListener("pending-entry-sync", () => {
        scheduleQueueRefresh(100);
      });

      source.addEventListener("error", () => {
        if (liveEventSource !== source) return;
        const wasConnected = isLiveConnected;
        isLiveConnected = false;
        try {
          source.close();
        } catch (_error) {
          // ignore close race
        }
        liveEventSource = null;
        startFallbackPolling();
        if (wasConnected) {
          showLiveAlert("Live updates disconnected. Reconnecting...", "warning", 3200);
        }
        scheduleLiveReconnect();
      });
    }

    function showLiveAlert(message, tone = "success", autoHideMs = 6200) {
      if (!queueLiveAlert) return;
      queueLiveAlert.textContent = message;
      queueLiveAlert.className = `remote-queue-live-alert tone-${tone}`;
      queueLiveAlert.hidden = false;
      if (liveAlertTimer) clearTimeout(liveAlertTimer);
      liveAlertTimer = window.setTimeout(() => {
        queueLiveAlert.hidden = true;
      }, Math.max(1200, Number(autoHideMs) || 6200));
    }

    function groupSlotsByZone(slots) {
      return (slots || []).reduce((acc, slot) => {
        const zone = slot.zone || "General";
        if (!acc[zone]) acc[zone] = [];
        acc[zone].push(slot);
        return acc;
      }, {});
    }

    function renderQuickSlotStrip(overview) {
      if (!guardSlotQuickStrip) return;
      const slots = Array.isArray(overview?.slots) ? overview.slots : [];
      const available = slots
        .filter((slot) => slot.occupancy === "available")
        .slice(0, 16);

      if (!available.length) {
        guardSlotQuickStrip.innerHTML = "";
        return;
      }

      guardSlotQuickStrip.innerHTML = `
        <span class="guard-slot-strip-label">Available now (${available.length}):</span>
        ${available.map((slot) => `<span class="guard-slot-chip">${escapeHtml(slot.slot_code)}</span>`).join("")}
      `;
    }

    function slotStatusLabel(slot) {
      if (slot.occupancy === "occupied") {
        return slot.occupied_by_plate || "Occupied";
      }
      if (slot.occupancy === "disabled") {
        return "Disabled";
      }
      return "Available";
    }

    function renderSlotMap(overview) {
      if (!guardSlotMap || !guardSlotStatus) return;
      const slots = Array.isArray(overview?.slots) ? overview.slots : [];
      const summary = overview?.summary || { total: 0, available: 0, occupied: 0, disabled: 0 };

      renderQuickSlotStrip(overview);

      if (!slots.length) {
        guardSlotMap.innerHTML = `<div class="flash flash-error" style="margin:0;">No parking slots are configured right now.</div>`;
        guardSlotStatus.textContent = "No slots configured";
        guardEntryConfirmBtn.disabled = true;
        return;
      }

      const grouped = groupSlotsByZone(slots);
      const zoneNames = Object.keys(grouped);
      guardSlotStatus.textContent = `${summary.available || 0} available of ${summary.total || slots.length}`;

      guardSlotMap.innerHTML = `
        ${zoneNames.map((zone) => {
          const zoneSlots = grouped[zone];
          const zoneAvailable = zoneSlots.filter((slot) => slot.occupancy === "available").length;
          return `
            <section class="guard-zone-block">
              <header class="guard-zone-head">
                <h4>Zone ${escapeHtml(zone)}</h4>
                <span>${zoneAvailable}/${zoneSlots.length} available</span>
              </header>
              <div class="guard-zone-grid">
                ${zoneSlots.map((slot) => {
                  const occupancy = slot.occupancy || "available";
                  const selectable = occupancy === "available";
                  const selected = String(selectedSlotId) === String(slot.id);
                  const cls = [
                    "guard-slot-btn",
                    `state-${occupancy}`,
                    selected ? "is-selected" : ""
                  ].join(" ").trim();
                  return `
                    <button
                      type="button"
                      class="${cls}"
                      data-slot-id="${slot.id}"
                      data-slot-code="${escapeHtml(slot.slot_code || "-")}"
                      data-selectable="${selectable ? "1" : "0"}"
                      ${selectable ? "" : "disabled"}
                    >
                      <span>${escapeHtml(slot.slot_code || "-")}</span>
                      <small>${escapeHtml(slotStatusLabel(slot))}</small>
                    </button>
                  `;
                }).join("")}
              </div>
            </section>
          `;
        }).join("")}
      `;

      guardSlotMap.querySelectorAll(".guard-slot-btn[data-selectable='1']").forEach((btn) => {
        btn.addEventListener("click", () => {
          selectedSlotId = Number(btn.dataset.slotId);
          renderSlotMap(slotOverview);
          guardEntryHint.textContent = `Selected slot ${btn.dataset.slotCode || "-"}.`;
          guardEntryConfirmBtn.disabled = false;
        });
      });

      if (!selectedSlotId) {
        guardEntryConfirmBtn.disabled = true;
      }
    }

    function closeGuardEntryModal() {
      if (!guardEntryModal) return;
      guardEntryModal.classList.remove("open");
      guardEntryModal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
      activeEntryId = null;
      selectedSlotId = null;
      guardEntryHint.textContent = "";
      if (guardSlotStatus) guardSlotStatus.textContent = "Loading slot map...";
      if (guardSlotQuickStrip) guardSlotQuickStrip.innerHTML = "";
      if (guardSlotMap) guardSlotMap.innerHTML = "";
      guardEntryConfirmBtn.disabled = false;
      guardEntryCancelBtn.disabled = false;
      guardEntrySnapshotWrap.style.display = "none";
      guardEntrySnapshotImg.removeAttribute("src");
    }

    async function loadSlotOverview() {
      const resp = await fetch("/api/parking-slot-overview", { credentials: "same-origin", cache: "no-store" });
      const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
      if (!resp.ok || !data.ok) {
        throw new Error(data.message || `Unable to load slots (${resp.status})`);
      }
      return {
        slots: Array.isArray(data.slots) ? data.slots : [],
        summary: data.summary || { total: 0, available: 0, occupied: 0, disabled: 0 }
      };
    }

    async function openGuardEntryModal(entryId) {
      const entry = pendingEntries.find((row) => String(row.id) === String(entryId));
      if (!entry) return;

      activeEntryId = entry.id;
      selectedSlotId = null;
      guardEntryMeta.textContent = `${entry.full_name || "-"} (${entry.student_number || "-"}) - ${entry.plate_number || "-"} - ${entry.gate_id || "Main Gate"} - ${formatQueuedAt(entry.created_at)}`;
      guardEntryHint.textContent = "Loading available parking slots...";
      guardEntryConfirmBtn.disabled = true;
      guardEntryCancelBtn.disabled = false;
      if (guardSlotStatus) guardSlotStatus.textContent = "Loading slot map...";
      if (guardSlotQuickStrip) guardSlotQuickStrip.innerHTML = "";
      if (guardSlotMap) guardSlotMap.innerHTML = '<div class="helper-text">Loading slot map...</div>';

      if (entry.snapshot_path) {
        guardEntrySnapshotWrap.style.display = "";
        guardEntrySnapshotImg.src = entry.snapshot_path;
      } else {
        guardEntrySnapshotWrap.style.display = "none";
        guardEntrySnapshotImg.removeAttribute("src");
      }

      guardEntryModal.classList.add("open");
      guardEntryModal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");

      try {
        slotOverview = await loadSlotOverview();
        const slots = Array.isArray(slotOverview.slots) ? slotOverview.slots : [];
        const hasAvailable = slots.some((slot) => slot.occupancy === "available");
        if (!slots.length) {
          guardSlotMap.innerHTML = '<div class="flash flash-error" style="margin:0;">No slots configured.</div>';
          if (guardSlotStatus) guardSlotStatus.textContent = "No slots configured";
          guardEntryHint.textContent = "No available slots right now.";
          guardEntryConfirmBtn.disabled = true;
          return;
        }
        renderSlotMap(slotOverview);
        guardEntryHint.textContent = hasAvailable
          ? "Select an available slot to continue."
          : "No available slots right now.";
        guardEntryConfirmBtn.disabled = !hasAvailable;
      } catch (error) {
        if (guardSlotMap) {
          guardSlotMap.innerHTML = `<div class="flash flash-error" style="margin:0;">${escapeHtml(error.message || "Unable to load slots.")}</div>`;
        }
        if (guardSlotStatus) guardSlotStatus.textContent = "Unable to load slots";
        guardEntryHint.textContent = error.message || "Unable to load slots.";
        guardEntryConfirmBtn.disabled = true;
      }
    }

    async function fetchPendingEntries({ silent = false } = {}) {
      if (!queueStatus || !queueList) return;
      if (!silent) queueStatus.textContent = "Loading pending phone entries...";

      try {
        const resp = await fetch("/api/auto-scan/pending-entries?limit=30", {
          credentials: "same-origin",
          cache: "no-store"
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to load pending entries (${resp.status})`);
        }

        pendingEntries = Array.isArray(data.rows) ? data.rows : [];
        const newestEntry = pendingEntries.length ? pendingEntries[0] : null;
        const newestId = newestEntry ? Number(newestEntry.id) : 0;
        const hasNew = didInitialLoad && newestId > latestEntryId;

        if (hasNew) {
          showLiveAlert(`New phone scan: ${newestEntry.full_name || "Unknown student"} (${newestEntry.plate_number || "-"})`, "success", 6500);
          if (!guardEntryModal?.classList.contains("open") && newestId !== lastAutoOpenedEntryId) {
            lastAutoOpenedEntryId = newestId;
            await openGuardEntryModal(newestId);
          }
        }
        latestEntryId = Math.max(latestEntryId, newestId);
        didInitialLoad = true;

        if (!pendingEntries.length) {
          queueEmpty.style.display = "";
          queueList.innerHTML = "";
          queueStatus.textContent = "No pending phone entry requests.";
          return;
        }

        queueEmpty.style.display = "none";
        queueStatus.textContent = `${pendingEntries.length} pending request(s).`;
        queueList.innerHTML = pendingEntries.map((entry) => `
          <article class="remote-queue-card">
            <div class="remote-queue-main">
              <h4>${escapeHtml(entry.full_name || "Unknown Student")}</h4>
              <p>${escapeHtml(entry.student_number || "-")} - ${escapeHtml(entry.plate_number || "-")}</p>
              <p>${escapeHtml(entry.gate_id || "Main Gate")} - ${formatQueuedAt(entry.created_at)}</p>
            </div>
            <div class="remote-queue-actions">
              <span class="badge badge-warning">Pending</span>
              <button type="button" class="btn-sm guard-open-entry-btn" data-entry-id="${entry.id}">Assign & Confirm</button>
            </div>
          </article>
        `).join("");

        queueList.querySelectorAll(".guard-open-entry-btn").forEach((btn) => {
          btn.addEventListener("click", () => openGuardEntryModal(btn.dataset.entryId));
        });
      } catch (error) {
        queueStatus.textContent = error.message || "Unable to load pending entries.";
      }
    }

    async function confirmEntry() {
      if (!activeEntryId) return;
      const slotId = Number(selectedSlotId);
      if (!Number.isInteger(slotId) || slotId <= 0) {
        guardEntryHint.textContent = "Please select a parking slot.";
        return;
      }

      const entry = pendingEntries.find((row) => String(row.id) === String(activeEntryId));
      const gateValue = entry?.gate_id || "Main Gate";

      guardEntryHint.textContent = "Saving entry...";
      guardEntryConfirmBtn.disabled = true;
      guardEntryCancelBtn.disabled = true;

      try {
        const resp = await fetch(`/api/auto-scan/pending-entries/${activeEntryId}/confirm`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ slot_id: slotId, gate: gateValue })
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to confirm entry (${resp.status})`);
        }

        showLiveAlert(`ENTRY confirmed for ${data.sticker?.plate_number || "vehicle"} at ${data.parking_slot || "-"}.`, "success", 5200);
        closeGuardEntryModal();
        await fetchPendingEntries({ silent: true });
      } catch (error) {
        guardEntryHint.textContent = error.message || "Unable to confirm entry.";
        guardEntryConfirmBtn.disabled = false;
        guardEntryCancelBtn.disabled = false;
      }
    }

    async function cancelEntry() {
      if (!activeEntryId) return;
      guardEntryHint.textContent = "Cancelling request...";
      guardEntryConfirmBtn.disabled = true;
      guardEntryCancelBtn.disabled = true;

      try {
        const resp = await fetch(`/api/auto-scan/pending-entries/${activeEntryId}/cancel`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ reason: "Cancelled by guard dashboard." })
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to cancel request (${resp.status})`);
        }
        showLiveAlert("Pending request cancelled.", "warning", 4200);
        closeGuardEntryModal();
        await fetchPendingEntries({ silent: true });
      } catch (error) {
        guardEntryHint.textContent = error.message || "Unable to cancel request.";
        guardEntryConfirmBtn.disabled = false;
        guardEntryCancelBtn.disabled = false;
      }
    }

    queueRefreshBtn?.addEventListener("click", () => {
      fetchPendingEntries({ silent: false });
      fetchQueueHealth({ silent: false });
    });
    guardEntryCloseBtn?.addEventListener("click", closeGuardEntryModal);
    guardEntryConfirmBtn?.addEventListener("click", confirmEntry);
    guardEntryCancelBtn?.addEventListener("click", cancelEntry);
    guardEntryModal?.querySelectorAll("[data-guard-close]").forEach((node) => {
      node.addEventListener("click", closeGuardEntryModal);
    });
    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && guardEntryModal?.classList.contains("open")) {
        closeGuardEntryModal();
      }
    });
    window.addEventListener("beforeunload", () => {
      closeLiveEvents();
      stopFallbackPolling();
      if (queueRefreshTimer) {
        clearTimeout(queueRefreshTimer);
        queueRefreshTimer = null;
      }
    });
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) return;
      if (!isLiveConnected) {
        fetchPendingEntries({ silent: true });
        fetchQueueHealth({ silent: true });
        connectLiveEvents();
      }
    });

    fetchPendingEntries({ silent: false });
    fetchQueueHealth({ silent: false });
    connectLiveEvents();
  })();
</script>

<%- include("partials/footer") %>
