<%- include("partials/header") %>

<% const pageFlash = typeof flash !== 'undefined' ? flash : null; %>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Vehicle Management</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Registered Vehicles</h3>
      <p><%= vehicles.length %></p>
    </div>
  </div>
  <% if (pageFlash) { %>
    <div class="flash flash-<%= pageFlash.type === 'success' ? 'success' : 'error' %>" style="margin-top: 1rem;">
      <%= pageFlash.type === 'success' ? '✅' : '⚠️' %> <%= pageFlash.message %>
    </div>
  <% } %>
</section>

<div class="overlap-wrapper" style="display: grid; gap: 3rem;">
  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
    <div class="section-head">
      <h2 style="font-size: 1.25rem;">Vehicle Registration</h2>
      <p>Bind each vehicle to an authorized student profile.</p>
    </div>
  <form method="post" action="/vehicles" class="form-grid">
    <label for="v_student_id">Student</label>
    <select id="v_student_id" name="student_id" required>
      <option value="">Select student</option>
      <% students.forEach(student => { %>
        <option value="<%= student.id %>"><%= student.student_number %> — <%= student.full_name %></option>
      <% }) %>
    </select>

    <label for="v_plate">Plate Number</label>
    <input id="v_plate" name="plate_number" required placeholder="e.g. ABC 1234" />

    <label for="v_model">Vehicle Model</label>
    <input id="v_model" name="model" placeholder="e.g. Honda Click 125i" />

    <label for="v_color">Color</label>
    <input id="v_color" name="color" placeholder="e.g. Black" />

    <button type="submit">Save Vehicle</button>
  </form>
</section>

  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
    <div class="section-head">
      <h2 style="font-size: 1.25rem;">Vehicle Registry</h2>
      <p>Manage existing records.</p>
    </div>
  <div class="table-wrap desktop-only-table">
    <table>
      <thead>
        <tr>
          <th>Student</th>
          <th>Plate Number</th>
          <th>Model</th>
          <th>Color</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (vehicles.length === 0) { %>
          <tr style="box-shadow: none;">
            <td colspan="5" style="background: transparent; border: none;">
              <div class="empty-state">
                <div class="empty-state-icon">🚗</div>
                <p>No vehicles registered yet. Use the form above to add one.</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% vehicles.forEach(vehicle => { %>
          <tr>
            <td><strong><%= vehicle.student_number %></strong> <span style="color:var(--muted); font-size:0.8rem; margin-left:0.5rem;"><%= vehicle.full_name %></span></td>
            <td><span class="badge" style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1;"><%= vehicle.plate_number %></span></td>
            <td style="color: var(--muted);"><%= vehicle.model || "-" %></td>
            <td style="color: var(--muted);"><%= vehicle.color || "-" %></td>
            <td style="text-align: right; padding-right: 1.5rem;">
              <form method="post" action="/vehicles/<%= vehicle.id %>/delete"
                    onsubmit="return confirm('Delete vehicle <%= vehicle.plate_number %>? This cannot be undone.')"
                    style="margin:0; text-align:right;">
                <button type="submit" class="danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile-Ready Cards -->
  <div class="mobile-data-list">
    <% if (vehicles.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">🚗</div>
        <p>No vehicles registered yet.</p>
      </div>
    <% } %>
    <% vehicles.forEach(vehicle => { %>
      <div class="mobile-data-card">
        <div class="card-header">
          <div class="card-title"><%= vehicle.plate_number %></div>
          <span class="badge" style="background:var(--surface-soft); color:var(--text); border:1px solid var(--line);"><%= vehicle.color || "No Color" %></span>
        </div>
        <div class="card-body">
          <div class="card-item">👤 <strong>Owner:</strong> <%= vehicle.full_name %> (<%= vehicle.student_number %>)</div>
          <div class="card-item">🚘 <strong>Model:</strong> <%= vehicle.model || "-" %></div>
        </div>
        <div class="card-actions">
          <form style="margin:0;" method="post" action="/vehicles/<%= vehicle.id %>/delete"
                onsubmit="return confirm('Delete vehicle <%= vehicle.plate_number %>?')">
            <button type="submit" class="danger btn-mobile-touch">Delete Vehicle</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
  </section>
</div>

<%- include("partials/footer") %>
