<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NAAP Parking - Sign In</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0a3a73;
      --navy-dark: #062852;
      --navy-soft: #d9e9ff;
      --line: #dbe5f3;
      --muted: #5f738d;
      --text: #0f2035;
      --surface: #f7fbff;
      --red: #9f1239;
      --red-bg: #ffe4eb;
    }

    body {
      font-family: "Manrope", sans-serif;
      color: var(--text);
      background:
        radial-gradient(1200px 700px at 12% -8%, rgba(37, 99, 235, 0.2), transparent 60%),
        radial-gradient(900px 520px at 100% 0%, rgba(6, 182, 212, 0.14), transparent 55%),
        linear-gradient(180deg, #eff5fc 0%, #e7eef7 45%, #edf3f9 100%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .login-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 22px;
      width: 100%;
      max-width: 460px;
      overflow: hidden;
      box-shadow:
        0 24px 60px rgba(15, 35, 70, 0.18),
        0 10px 24px rgba(15, 35, 70, 0.1);
      animation: loginEnter 420ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
      transform-origin: center;
      transition: transform 180ms ease, opacity 180ms ease, filter 180ms ease;
    }

    .login-card.is-submitting {
      transform: translateY(-2px) scale(0.995);
      opacity: 0.96;
      filter: saturate(0.92);
    }

    .login-header {
      background:
        radial-gradient(circle at 85% 10%, rgba(125, 211, 252, 0.28), transparent 40%),
        linear-gradient(140deg, var(--navy-dark) 0%, var(--navy) 55%, #0e4b92 100%);
      color: #fff;
      padding: 2rem 2.1rem 1.9rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .login-header::after {
      content: "";
      position: absolute;
      right: -42px;
      bottom: -42px;
      width: 170px;
      height: 170px;
      border-radius: 50%;
      background: rgba(191, 219, 254, 0.12);
      pointer-events: none;
    }

    .login-logo {
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.14);
      border: 2px solid rgba(219, 234, 254, 0.45);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: "Outfit", sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      margin: 0 auto 0.95rem;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.16);
    }

    .login-school {
      font-size: 0.69rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(191, 219, 254, 0.88);
      margin-bottom: 0.38rem;
    }

    .login-title {
      font-family: "Outfit", sans-serif;
      font-size: 1.68rem;
      line-height: 1.15;
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    .login-subtitle {
      font-size: 0.86rem;
      color: rgba(219, 234, 254, 0.88);
      margin-top: 0.3rem;
    }

    .login-body {
      padding: 1.7rem 2rem 1.85rem;
      background: linear-gradient(180deg, #ffffff 0%, var(--surface) 100%);
    }

    .login-error {
      background: var(--red-bg);
      color: var(--red);
      border: 1px solid #fda4af;
      border-radius: 12px;
      padding: 0.8rem 0.95rem;
      font-size: 0.875rem;
      font-weight: 700;
      margin-bottom: 1rem;
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      animation: loginErrorIn 240ms ease-out both;
    }

    .form-group {
      margin-bottom: 0.95rem;
    }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 700;
      color: #15273f;
      margin-bottom: 0.42rem;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    .input-wrap {
      display: grid;
      grid-template-columns: 40px minmax(0, 1fr);
      align-items: center;
      border: 1px solid #c8d5e7;
      border-radius: 12px;
      background: #fff;
      transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .input-wrap:focus-within {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.18);
      transform: translateY(-1px);
    }

    .input-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #5d738e;
      border-right: 1px solid #d9e3f0;
      height: 100%;
    }

    .input-icon svg {
      width: 16px;
      height: 16px;
      stroke: currentColor;
      stroke-width: 2;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    input[type="text"],
    input[type="password"] {
      width: 100%;
      padding: 0.84rem 0.88rem;
      font-family: inherit;
      font-size: 0.96rem;
      border: none;
      border-radius: 12px;
      color: var(--text);
      background: #fff;
      outline: none;
    }

    input::placeholder {
      color: #8aa0b9;
    }

    .login-btn {
      position: relative;
      overflow: hidden;
      width: 100%;
      padding: 0.92rem;
      background: linear-gradient(140deg, #0a3b73 0%, #0e4b92 100%);
      color: #fff;
      font-family: inherit;
      font-size: 1.02rem;
      font-weight: 700;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      margin-top: 0.55rem;
      transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
      box-shadow: 0 10px 22px rgba(10, 58, 115, 0.28);
    }

    .login-btn:hover {
      filter: brightness(1.04);
      transform: translateY(-1px);
      box-shadow: 0 14px 26px rgba(10, 58, 115, 0.34);
    }

    .login-btn:active {
      transform: translateY(0);
      box-shadow: 0 8px 14px rgba(10, 58, 115, 0.24);
    }

    .login-btn.ui-tap-pop {
      animation: tapPop 170ms cubic-bezier(0.22, 0.82, 0.33, 1);
    }

    .login-btn.is-loading {
      pointer-events: none;
      opacity: 0.96;
      filter: saturate(0.96);
    }

    .login-btn.is-loading::after {
      content: "";
      display: inline-block;
      width: 14px;
      height: 14px;
      margin-left: 0.55rem;
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, 0.45);
      border-top-color: #ffffff;
      vertical-align: -2px;
      animation: btnSpin 700ms linear infinite;
    }

    .login-footer {
      text-align: center;
      padding: 0.95rem;
      color: var(--muted);
      font-size: 0.74rem;
      border-top: 1px solid var(--line);
      background: #f7fbff;
    }

    .login-note {
      margin: 0.8rem 0 0;
      color: #5f738d;
      font-size: 0.76rem;
      text-align: center;
    }

    @keyframes loginEnter {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.985);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }

    @keyframes loginErrorIn {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }

    @keyframes tapPop {
      0% { transform: scale(1); }
      45% { transform: scale(0.97); }
      100% { transform: scale(1); }
    }

    @keyframes btnSpin {
      to { transform: rotate(360deg); }
    }

    @media (prefers-reduced-motion: reduce) {
      .login-card,
      .login-error,
      .login-btn.ui-tap-pop,
      .login-btn.is-loading::after {
        animation: none !important;
      }
      .login-card,
      .login-btn {
        transition: none !important;
      }
    }

    @media (max-width: 520px) {
      body {
        padding: 0.8rem;
      }

      .login-card {
        border-radius: 18px;
      }

      .login-header {
        padding: 1.65rem 1.2rem 1.55rem;
      }

      .login-body {
        padding: 1.2rem 1.2rem 1.35rem;
      }

      .login-title {
        font-size: 1.46rem;
      }

      .login-school {
        font-size: 0.62rem;
      }
    }
  </style>
</head>
<body>

  <div class="login-card">
    <div class="login-header">
      <div class="login-logo">N</div>
      <p class="login-school">National Aviation Academy of the Philippines</p>
      <h1 class="login-title">Parking Management</h1>
      <p class="login-subtitle">Role-Based Secure Access</p>
    </div>

    <div class="login-body">
      <% if (locals.error) { %>
        <div class="login-error">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <form method="post" action="/login">
        <div class="form-group">
          <label for="username">Username</label>
          <div class="input-wrap">
            <span class="input-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M20 21a8 8 0 0 0-16 0"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </span>
            <input
              type="text"
              id="username"
              name="username"
              required
              autocomplete="username"
              placeholder="Enter your username"
              value="<%= locals.usernameVal || '' %>"
            />
          </div>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="input-wrap">
            <span class="input-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <rect x="4" y="11" width="16" height="9" rx="2"></rect>
                <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
              </svg>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              placeholder="Enter your password"
            />
          </div>
        </div>
        <button type="submit" class="login-btn">Sign In</button>
      </form>

      <p class="login-note">For authorized Admin and Guard accounts only.</p>
    </div>

    <div class="login-footer">
      NAAP Parking System &mdash; Authorized Personnel Only
    </div>
  </div>

  <script>
    (() => {
      const form = document.querySelector('form[action="/login"]');
      const submitBtn = form ? form.querySelector('.login-btn') : null;
      const loginCard = document.querySelector('.login-card');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!form || !submitBtn) return;

      submitBtn.addEventListener('pointerdown', () => {
        if (prefersReducedMotion) return;
        submitBtn.classList.remove('ui-tap-pop');
        void submitBtn.offsetWidth;
        submitBtn.classList.add('ui-tap-pop');
      });

      submitBtn.addEventListener('animationend', () => {
        submitBtn.classList.remove('ui-tap-pop');
      });

      form.addEventListener('submit', (event) => {
        if (form.dataset.submitting === '1') {
          event.preventDefault();
          return;
        }
        form.dataset.submitting = '1';
        submitBtn.disabled = true;
        submitBtn.classList.add('is-loading');
        submitBtn.setAttribute('aria-busy', 'true');
        submitBtn.textContent = 'Signing In';
        if (!prefersReducedMotion && loginCard) {
          loginCard.classList.add('is-submitting');
        }
      });
    })();
  </script>

</body>
</html>

