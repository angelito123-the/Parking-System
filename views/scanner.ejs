<%- include("partials/header") %>
<% const isGuardQueueMode = String(currentRole || "").toLowerCase() === "guard"; %>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Gate Console HUD</h1>
  </div>
  <p style="color: rgba(255,255,255,0.8); margin-top: 0.5rem;">Stationary operator dashboard. Search for students manually or launch the camera reader.</p>
</section>

<div class="overlap-wrapper" style="display: grid; gap: 2rem;">
  <section class="panel gate-console-panel">
    <div class="gate-console-top">
      <div class="gate-console-headline">
        <h3>Operator Controls</h3>
        <p>Open camera scanning or manually search by student, plate, or sticker details.</p>
        <p style="margin-top:0.4rem;">
          <a href="/scanner/auto" class="link-btn">Open Phone Camera Mode</a>
        </p>
      </div>
      <button id="toggleCameraBtn" type="button" class="gate-camera-btn">
        <span class="gate-camera-btn-title">Launch Camera Scanner</span>
        <span class="gate-camera-btn-sub">Realtime QR verification</span>
      </button>
    </div>

    <div id="cameraWrapper" class="gate-camera-wrapper">
      <div id="qr-reader"></div>
      <p id="cameraStatus" class="gate-camera-status">Camera ready</p>
    </div>

    <div class="gate-search-grid">
      <div>
        <label for="gateSearchInput">Search Manually (Plate, ID, Name)</label>
        <input id="gateSearchInput" type="search" placeholder="e.g. ABC 1234 or 2024-001" autocomplete="off" />
      </div>
      <div>
        <label for="gateNameSelect">Current Gate</label>
        <select id="gateNameSelect">
          <option value="Main Gate">Main Gate</option>
          <option value="Side Gate">Side Gate</option>
          <option value="Manual Verification">Manual Verification</option>
        </select>
      </div>
      <button type="button" id="gateSearchBtn" class="gate-search-btn">Search Record</button>
    </div>
  </section>

  <% if (isGuardQueueMode) { %>
  <section class="panel remote-queue-panel">
    <div class="section-head">
      <h2>Phone Camera Pending Entries</h2>
      <p>ENTRY scans from phone camera appear here. Guard assigns slot and confirms on this laptop.</p>
    </div>
    <div class="remote-queue-toolbar">
      <p id="remoteQueueStatus" class="helper-text">Waiting for phone scans...</p>
      <button type="button" id="remoteQueueRefreshBtn" class="btn-sm">Refresh List</button>
    </div>
    <div id="remoteQueueLiveAlert" class="remote-queue-live-alert" hidden></div>
    <div id="remoteQueueEmpty" class="empty-state" style="padding:1rem;">
      <p>No pending entry requests from phone camera.</p>
    </div>
    <div id="remoteQueueList" class="remote-queue-list"></div>
  </section>
  <% } %>

  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent; border-top: 1px solid var(--line); padding-top: 2rem;">
  <div class="section-head">
    <h2>Scanner Results</h2>
    <p>Select a vehicle to record gate movement.</p>
  </div>
  <div id="gateSearchStatus" class="helper-text" style="margin-bottom: 0.75rem;">Waiting for scan or search...</div>
  <div id="gateResultsContainer"></div>
</section>

  <section class="panel" id="gateLogPanel" style="display:none; border:none; box-shadow:none; padding:0; background:transparent; border-top: 1px solid var(--line); padding-top: 2rem;">
  <div class="section-head">
    <h2>Record Movement</h2>
    <p id="gateLogInfo">Recording for selected vehicle.</p>
  </div>
  <div id="gateLogDetails" style="margin-bottom: 0.75rem;"></div>
  <div id="slotPickerPanel" style="display:none; margin-bottom: 1rem;">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:0.75rem; margin-bottom:0.5rem; flex-wrap:wrap;">
      <strong style="font-size:0.95rem;">Choose Parking Slot</strong>
      <span id="slotPickerStatus" class="helper-text">Loading parking map...</span>
    </div>
    <div id="slotMap" style="background:#f8fafc; border:1px solid var(--line); border-radius:14px; padding:1rem;"></div>
  </div>
  <div id="gateLogFeedback" style="margin-bottom: 1rem;"></div>
  <div id="movementBtnContainer" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
    <button type="button" id="gateEntryBtn" style="
      background: linear-gradient(135deg, #16a34a, #15803d);
      border: none;
      color: #fff;
      padding: 1.25rem 0.5rem;
      font-size: 1rem;
      font-weight: 800;
      font-family: 'Outfit', sans-serif;
      border-radius: 10px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      box-shadow: 0 4px 14px rgba(22, 163, 74, 0.35);
      transition: all 0.15s ease;
    " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(22,163,74,0.45)'" onmouseout="this.style.transform=''; this.style.boxShadow='0 4px 14px rgba(22,163,74,0.35)'">
      <span style="font-size: 2rem; line-height:1;">🟢</span>
      <span>Record ENTRY</span>
    </button>
    <button type="button" id="gateExitBtn" style="
      background: linear-gradient(135deg, #dc2626, #b91c1c);
      border: none;
      color: #fff;
      padding: 1.25rem 0.5rem;
      font-size: 1rem;
      font-weight: 800;
      font-family: 'Outfit', sans-serif;
      border-radius: 10px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      box-shadow: 0 4px 14px rgba(220, 38, 38, 0.35);
      transition: all 0.15s ease;
    " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(220,38,38,0.45)'" onmouseout="this.style.transform=''; this.style.boxShadow='0 4px 14px rgba(220,38,38,0.35)'">
      <span style="font-size: 2rem; line-height:1;">🔴</span>
      <span>Record EXIT</span>
    </button>
  </div>
</section>

  <% if (isGuardQueueMode) { %>
  <div id="remoteEntryModal" class="slot-history-modal" aria-hidden="true">
    <div class="slot-history-backdrop" data-remote-close></div>
    <article class="slot-history-dialog remote-entry-dialog" role="dialog" aria-modal="true" aria-labelledby="remoteEntryModalTitle">
      <div class="slot-history-head">
        <h3 id="remoteEntryModalTitle">Confirm Phone Camera Entry</h3>
        <button type="button" id="remoteEntryCloseBtn" class="slot-history-close" aria-label="Close">×</button>
      </div>
      <p id="remoteEntryMeta" class="helper-text" style="margin-bottom:0.65rem;"></p>

      <div id="remoteEntrySnapshotWrap" class="remote-entry-snapshot" style="display:none;">
        <img id="remoteEntrySnapshotImg" alt="Phone camera snapshot proof" />
      </div>

      <label for="remoteEntrySlotSelect" style="display:block; margin-top:0.35rem; margin-bottom:0.3rem;">Assign Parking Slot</label>
      <select id="remoteEntrySlotSelect"></select>
      <p id="remoteEntryHint" class="helper-text" style="margin-top:0.4rem;"></p>

      <div class="remote-entry-actions">
        <button type="button" id="remoteEntryConfirmBtn" class="btn-sm">Confirm ENTRY</button>
        <button type="button" id="remoteEntryCancelBtn" class="btn-sm danger">Cancel Request</button>
      </div>
    </article>
  </div>
  <% } %>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script>
  (() => {
    const searchInput = document.getElementById("gateSearchInput");
    const gateSelect = document.getElementById("gateNameSelect");
    const searchBtn = document.getElementById("gateSearchBtn");
    const statusEl = document.getElementById("gateSearchStatus");
    const resultsEl = document.getElementById("gateResultsContainer");
    const logPanel = document.getElementById("gateLogPanel");
    const logInfo = document.getElementById("gateLogInfo");
    const logDetails = document.getElementById("gateLogDetails");
    const slotPickerPanel = document.getElementById("slotPickerPanel");
    const slotPickerStatus = document.getElementById("slotPickerStatus");
    const slotMap = document.getElementById("slotMap");
    const logFeedback = document.getElementById("gateLogFeedback");
    const entryBtn = document.getElementById("gateEntryBtn");
    const exitBtn = document.getElementById("gateExitBtn");
    const toggleCameraBtn = document.getElementById("toggleCameraBtn");
    const cameraWrapper = document.getElementById("cameraWrapper");
    const cameraStatus = document.getElementById("cameraStatus");

    const remoteQueueStatus = document.getElementById("remoteQueueStatus");
    const remoteQueueList = document.getElementById("remoteQueueList");
    const remoteQueueEmpty = document.getElementById("remoteQueueEmpty");
    const remoteQueueRefreshBtn = document.getElementById("remoteQueueRefreshBtn");
    const remoteQueueLiveAlert = document.getElementById("remoteQueueLiveAlert");
    const remoteEntryModal = document.getElementById("remoteEntryModal");
    const remoteEntryCloseBtn = document.getElementById("remoteEntryCloseBtn");
    const remoteEntryMeta = document.getElementById("remoteEntryMeta");
    const remoteEntrySnapshotWrap = document.getElementById("remoteEntrySnapshotWrap");
    const remoteEntrySnapshotImg = document.getElementById("remoteEntrySnapshotImg");
    const remoteEntrySlotSelect = document.getElementById("remoteEntrySlotSelect");
    const remoteEntryHint = document.getElementById("remoteEntryHint");
    const remoteEntryConfirmBtn = document.getElementById("remoteEntryConfirmBtn");
    const remoteEntryCancelBtn = document.getElementById("remoteEntryCancelBtn");

    let selectedToken = null;
    let selectedLabel = "";
    let selectedSlotId = null;
    let html5QrCode = null;
    let parkingOverview = { slots: [], summary: { total: 0, available: 0, occupied: 0, disabled: 0 } };
    let remotePendingEntries = [];
    let activeRemoteEntryId = null;
    let remoteSlots = [];
    let latestRemoteEntryId = 0;
    let didInitialRemoteLoad = false;
    let lastAutoOpenedEntryId = 0;
    let remoteQueueAlertTimer = null;
    const guardQueueMode = <%- isGuardQueueMode ? "true" : "false" %>;

    // --- Audio Feedback ---
    function playBeep(type) {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        if (type === 'success') {
          osc.type = 'sine';
          osc.frequency.setValueAtTime(800, ctx.currentTime);
          gain.gain.setValueAtTime(0.5, ctx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.2);
          osc.start(); osc.stop(ctx.currentTime + 0.2);
        } else {
          osc.type = 'sawtooth';
          osc.frequency.setValueAtTime(300, ctx.currentTime);
          osc.frequency.setValueAtTime(150, ctx.currentTime + 0.1);
          gain.gain.setValueAtTime(0.5, ctx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
          osc.start(); osc.stop(ctx.currentTime + 0.3);
        }
      } catch(e) {}
    }

    function escapeHtml(value) {
      return String(value == null ? "" : value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function formatQueuedAt(value) {
      const dt = new Date(value);
      if (Number.isNaN(dt.getTime())) return "-";
      return new Intl.DateTimeFormat("en-PH", {
        month: "short",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit"
      }).format(dt);
    }

    function showRemoteQueueLiveAlert(message, tone = "info", autoHideMs = 5200) {
      if (!remoteQueueLiveAlert) return;
      remoteQueueLiveAlert.textContent = message;
      remoteQueueLiveAlert.className = `remote-queue-live-alert tone-${tone}`;
      remoteQueueLiveAlert.hidden = false;

      if (remoteQueueAlertTimer) {
        clearTimeout(remoteQueueAlertTimer);
      }
      remoteQueueAlertTimer = window.setTimeout(() => {
        remoteQueueLiveAlert.hidden = true;
      }, Math.max(1600, Number(autoHideMs) || 5200));
    }

    function closeRemoteEntryModal() {
      if (!remoteEntryModal) return;
      remoteEntryModal.classList.remove("open");
      remoteEntryModal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
      activeRemoteEntryId = null;
      remoteEntryHint.textContent = "";
      remoteEntrySlotSelect.innerHTML = "";
      remoteEntryConfirmBtn.disabled = false;
      remoteEntryCancelBtn.disabled = false;
      remoteEntrySnapshotWrap.style.display = "none";
      remoteEntrySnapshotImg.removeAttribute("src");
    }

    async function loadRemoteSlots() {
      const resp = await fetch("/api/parking-slots", { credentials: "same-origin", cache: "no-store" });
      const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
      if (!resp.ok || !data.ok) {
        throw new Error(data.message || `Unable to load slots (${resp.status})`);
      }
      remoteSlots = Array.isArray(data.slots) ? data.slots : [];
      return remoteSlots;
    }

    async function openRemoteEntryModal(entryId) {
      const entry = remotePendingEntries.find((row) => String(row.id) === String(entryId));
      if (!entry) return;

      activeRemoteEntryId = entry.id;
      remoteEntryMeta.textContent = `${entry.full_name || "-"} (${entry.student_number || "-"}) • ${entry.plate_number || "-"} • ${entry.gate_id || "Main Gate"} • ${formatQueuedAt(entry.created_at)}`;
      remoteEntryHint.textContent = "Loading available parking slots...";
      remoteEntrySlotSelect.innerHTML = '<option value="">Loading slots...</option>';

      if (entry.snapshot_path) {
        remoteEntrySnapshotWrap.style.display = "";
        remoteEntrySnapshotImg.src = entry.snapshot_path;
      } else {
        remoteEntrySnapshotWrap.style.display = "none";
        remoteEntrySnapshotImg.removeAttribute("src");
      }

      remoteEntryModal.classList.add("open");
      remoteEntryModal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");

      try {
        const slots = await loadRemoteSlots();
        if (!slots.length) {
          remoteEntrySlotSelect.innerHTML = '<option value="">No available slots</option>';
          remoteEntryHint.textContent = "No available slots right now.";
          remoteEntryConfirmBtn.disabled = true;
          return;
        }
        remoteEntryConfirmBtn.disabled = false;
        remoteEntrySlotSelect.innerHTML = [
          '<option value="">Select parking slot...</option>',
          ...slots.map((slot) => `<option value="${slot.id}">${escapeHtml(slot.slot_code)} • ${escapeHtml(slot.zone || "General")}</option>`)
        ].join("");
        remoteEntryHint.textContent = `${slots.length} slot(s) available.`;
      } catch (error) {
        remoteEntrySlotSelect.innerHTML = '<option value="">Unable to load slots</option>';
        remoteEntryHint.textContent = error.message || "Unable to load slots.";
        remoteEntryConfirmBtn.disabled = true;
      }
    }

    async function fetchRemotePendingEntries({ silent = false } = {}) {
      if (!guardQueueMode) return;
      if (!remoteQueueStatus || !remoteQueueList) return;
      if (!silent) {
        remoteQueueStatus.textContent = "Loading pending phone entries...";
      }

      try {
        const resp = await fetch("/api/auto-scan/pending-entries?limit=30", {
          credentials: "same-origin",
          cache: "no-store"
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to load pending entries (${resp.status})`);
        }

        remotePendingEntries = Array.isArray(data.rows) ? data.rows : [];
        const newestEntry = remotePendingEntries.length ? remotePendingEntries[0] : null;
        const newestId = newestEntry ? Number(newestEntry.id) : 0;
        const hasNewEntry = didInitialRemoteLoad && newestId > latestRemoteEntryId;
        if (hasNewEntry) {
          playBeep("success");
          showRemoteQueueLiveAlert(
            `New phone scan: ${newestEntry.full_name || "Unknown student"} (${newestEntry.plate_number || "-"})`,
            "success",
            6200
          );
          if (!remoteEntryModal?.classList.contains("open") && newestId !== lastAutoOpenedEntryId) {
            lastAutoOpenedEntryId = newestId;
            await openRemoteEntryModal(newestId);
          }
        }
        latestRemoteEntryId = Math.max(latestRemoteEntryId, newestId);
        didInitialRemoteLoad = true;

        if (!remotePendingEntries.length) {
          remoteQueueEmpty.style.display = "";
          remoteQueueList.innerHTML = "";
          remoteQueueStatus.textContent = "No pending phone entry requests.";
          return;
        }

        remoteQueueEmpty.style.display = "none";
        remoteQueueStatus.textContent = `${remotePendingEntries.length} pending request(s).`;
        remoteQueueList.innerHTML = remotePendingEntries.map((entry) => `
          <article class="remote-queue-card">
            <div class="remote-queue-main">
              <h4>${escapeHtml(entry.full_name || "Unknown Student")}</h4>
              <p>${escapeHtml(entry.student_number || "-")} • ${escapeHtml(entry.plate_number || "-")}</p>
              <p>${escapeHtml(entry.gate_id || "Main Gate")} • ${formatQueuedAt(entry.created_at)}</p>
            </div>
            <div class="remote-queue-actions">
              <span class="badge badge-warning">Pending</span>
              <button type="button" class="btn-sm remote-open-entry-btn" data-entry-id="${entry.id}">Assign & Confirm</button>
            </div>
          </article>
        `).join("");

        remoteQueueList.querySelectorAll(".remote-open-entry-btn").forEach((btn) => {
          btn.addEventListener("click", () => openRemoteEntryModal(btn.dataset.entryId));
        });
      } catch (error) {
        remoteQueueStatus.textContent = error.message || "Unable to load pending entries.";
      }
    }

    async function confirmRemoteEntry() {
      if (!activeRemoteEntryId) return;
      const slotId = Number(remoteEntrySlotSelect.value);
      if (!Number.isInteger(slotId) || slotId <= 0) {
        remoteEntryHint.textContent = "Please select a parking slot.";
        return;
      }

      const entry = remotePendingEntries.find((row) => String(row.id) === String(activeRemoteEntryId));
      const gateValue = gateSelect?.value || entry?.gate_id || "Main Gate";
      remoteEntryHint.textContent = "Saving entry...";
      remoteEntryConfirmBtn.disabled = true;
      remoteEntryCancelBtn.disabled = true;

      try {
        const resp = await fetch(`/api/auto-scan/pending-entries/${activeRemoteEntryId}/confirm`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ slot_id: slotId, gate: gateValue })
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to confirm entry (${resp.status})`);
        }

        playBeep("success");
        statusEl.textContent = `Confirmed ENTRY for ${data.sticker?.plate_number || "vehicle"} at ${data.parking_slot || "-"}.`;
        closeRemoteEntryModal();
        await fetchRemotePendingEntries({ silent: true });
        await loadParkingSlots().catch(() => null);
      } catch (error) {
        playBeep("error");
        remoteEntryHint.textContent = error.message || "Unable to confirm entry.";
        remoteEntryConfirmBtn.disabled = false;
        remoteEntryCancelBtn.disabled = false;
      }
    }

    async function cancelRemoteEntry() {
      if (!activeRemoteEntryId) return;
      remoteEntryHint.textContent = "Cancelling request...";
      remoteEntryConfirmBtn.disabled = true;
      remoteEntryCancelBtn.disabled = true;

      try {
        const resp = await fetch(`/api/auto-scan/pending-entries/${activeRemoteEntryId}/cancel`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ reason: "Cancelled by guard from monitor console." })
        });
        const data = await resp.json().catch(() => ({ ok: false, message: "Invalid server response." }));
        if (!resp.ok || !data.ok) {
          throw new Error(data.message || `Unable to cancel request (${resp.status})`);
        }

        closeRemoteEntryModal();
        await fetchRemotePendingEntries({ silent: true });
      } catch (error) {
        remoteEntryHint.textContent = error.message || "Unable to cancel request.";
        remoteEntryConfirmBtn.disabled = false;
        remoteEntryCancelBtn.disabled = false;
      }
    }

    function renderSlotButton(slot) {
      const selected = String(selectedSlotId) === String(slot.id);
      const occupancy = slot.occupancy || "available";
      const isSelectable = occupancy === "available";
      const tone = occupancy === "available"
        ? { bg: "#16a34a", border: "#166534", text: "#ffffff" }
        : occupancy === "occupied"
        ? { bg: "#ef4444", border: "#b91c1c", text: "#ffffff" }
        : { bg: "#94a3b8", border: "#64748b", text: "#ffffff" };
      return `
        <button
          type="button"
          class="slot-option-btn"
          data-slot-id="${slot.id}"
          data-slot-code="${slot.slot_code}"
          data-selectable="${isSelectable ? "1" : "0"}"
          ${isSelectable ? "" : "disabled"}
          style="
            min-width:72px;
            min-height:86px;
            border-radius:12px;
            border:2px solid ${selected ? "#1d4ed8" : tone.border};
            background:${selected ? "#dbeafe" : tone.bg};
            color:${selected ? "#0f172a" : tone.text};
            font-weight:800;
            display:flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            gap:0.25rem;
            cursor:${isSelectable ? "pointer" : "not-allowed"};
            box-shadow:${selected ? '0 0 0 3px rgba(59,130,246,0.18)' : 'none'};
            opacity:${isSelectable ? "1" : "0.86"};
          ">
            <span style="font-size:0.9rem;">${slot.slot_code}</span>
          <span style="font-size:0.68rem; color:${selected ? "#334155" : "rgba(255,255,255,0.92)"};">${slot.zone}</span>
        </button>
      `;
    }

    function attachSlotHandlers() {
      document.querySelectorAll(".slot-option-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          if (btn.dataset.selectable !== "1") return;
          selectedSlotId = btn.dataset.slotId;
          renderParkingMap(parkingOverview);
          logFeedback.innerHTML = `<div class="flash flash-success" style="margin:0;">Slot <strong>${btn.dataset.slotCode || "-"}</strong> selected for entry.</div>`;
        });
      });
    }

    function renderParkingMap(overview) {
      if (!slotMap) return;
      const slots = Array.isArray(overview?.slots) ? overview.slots : [];
      if (!Array.isArray(slots) || slots.length === 0) {
        slotMap.innerHTML = `<div class="empty-state" style="padding:1rem;"><p>No parking slots configured right now.</p></div>`;
        return;
      }

      const grouped = slots.reduce((acc, slot) => {
        const zone = slot.zone || "General";
        if (!acc[zone]) acc[zone] = [];
        acc[zone].push(slot);
        return acc;
      }, {});
      const zoneNames = Object.keys(grouped);
      const summary = overview?.summary || { total: slots.length, available: 0, occupied: 0, disabled: 0 };

      slotMap.innerHTML = `
        <div style="border:2px solid #1d4ed8; border-radius:16px; padding:0.85rem; background:linear-gradient(180deg,#ffffff,#eff6ff);">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:0.6rem; flex-wrap:wrap; margin-bottom:0.7rem;">
            <div style="font-size:0.78rem; color:#334155; font-weight:700;">
              Campus Overview: ${summary.available || 0} Available / ${summary.total || slots.length} Total
            </div>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; font-size:0.7rem; color:#475569;">
              <span style="display:inline-flex; align-items:center; gap:0.3rem;"><span style="width:10px;height:10px;border-radius:3px;background:#16a34a;border:1px solid #166534;"></span>Available</span>
              <span style="display:inline-flex; align-items:center; gap:0.3rem;"><span style="width:10px;height:10px;border-radius:3px;background:#ef4444;border:1px solid #b91c1c;"></span>Occupied</span>
              <span style="display:inline-flex; align-items:center; gap:0.3rem;"><span style="width:10px;height:10px;border-radius:3px;background:#94a3b8;border:1px solid #64748b;"></span>Disabled</span>
            </div>
          </div>
          ${zoneNames.map(zone => `
            <div style="border:1px solid #dbe3ef; border-radius:12px; padding:0.55rem; margin-bottom:0.55rem; background:#f8fafc;">
              <div style="font-size:0.74rem; font-weight:700; letter-spacing:0.03em; text-transform:uppercase; color:#334155; margin-bottom:0.45rem;">
                ${zone}
              </div>
              <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(72px,1fr)); gap:0.45rem;">
                ${grouped[zone].map(renderSlotButton).join("")}
              </div>
            </div>
          `).join("")}
        </div>
      `;
      attachSlotHandlers();
    }

    async function loadParkingSlots() {
      if (!slotPickerStatus) return;
      slotPickerStatus.textContent = "Loading parking map...";
      selectedSlotId = null;

      try {
        const resp = await fetch("/api/parking-slot-overview");
        const data = await resp.json();
        if (!data.ok) throw new Error(data.message || "Failed to load parking overview.");
        parkingOverview = {
          slots: Array.isArray(data.slots) ? data.slots : [],
          summary: data.summary || { total: 0, available: 0, occupied: 0, disabled: 0 }
        };
        const availableCount = parkingOverview.summary?.available || 0;
        const totalCount = parkingOverview.summary?.total || parkingOverview.slots.length || 0;
        slotPickerStatus.textContent = `${availableCount} available out of ${totalCount} slots`;
        renderParkingMap(parkingOverview);
      } catch (error) {
        parkingOverview = { slots: [], summary: { total: 0, available: 0, occupied: 0, disabled: 0 } };
        slotPickerStatus.textContent = "Unable to load parking map";
        slotMap.innerHTML = `<div class="flash flash-error" style="margin:0;">${error.message || "Unable to load parking overview."}</div>`;
      }
    }

    // --- Camera Logic ---
    function setCameraButton(isOpen) {
      if (isOpen) {
        toggleCameraBtn.innerHTML = '<span class="gate-camera-btn-title">Close Camera Scanner</span><span class="gate-camera-btn-sub">Stop realtime QR verification</span>';
      } else {
        toggleCameraBtn.innerHTML = '<span class="gate-camera-btn-title">Launch Camera Scanner</span><span class="gate-camera-btn-sub">Realtime QR verification</span>';
      }
    }

    setCameraButton(false);

    toggleCameraBtn.addEventListener("click", () => {
      const currentlyHidden = cameraWrapper.style.display === "none" || getComputedStyle(cameraWrapper).display === "none";
      if (currentlyHidden) {
        cameraWrapper.style.display = "block";
        setCameraButton(true);
        if (cameraStatus) cameraStatus.textContent = "Scanner active";
        if (!html5QrCode) html5QrCode = new Html5Qrcode("qr-reader");
        html5QrCode.start({ facingMode: "environment" }, { fps: 30, qrbox: { width: 250, height: 250 } }, onScanSuccess)
          .catch(e => {
            if (cameraStatus) cameraStatus.textContent = "Camera error: " + e;
          });
      } else {
        cameraWrapper.style.display = "none";
        setCameraButton(false);
        if (cameraStatus) cameraStatus.textContent = "Camera ready";
        if (html5QrCode) html5QrCode.stop().then(() => html5QrCode.clear());
      }
    });
    async function onScanSuccess(decodedText) {
      if (html5QrCode && html5QrCode.getState() === 2) {
        html5QrCode.pause(); // Pause scanning
      }

      let token = decodedText;
      try {
        const url = new URL(decodedText);
        const parts = url.pathname.split("/").filter(Boolean);
        if (parts.length >= 2 && parts[0] === "verify") token = parts[1];
      } catch(e){}

      statusEl.textContent = "Processing scan...";
      resultsEl.innerHTML = "";
      logPanel.style.display = "none";

      let isOffline = !window.OfflineManager || !window.OfflineManager.isOnline;
      
      if (isOffline) {
        // Offline Scan
        const verifyRes = await window.OfflineManager.verifyOfflineToken(token);
        if (verifyRes.ok) {
          playBeep('success');
          // Fake a search result for selection UI
          renderSearchResults([{
            qr_token: token,
            full_name: verifyRes.sticker.full_name,
            plate_number: verifyRes.sticker.plate_number,
            sticker_code: verifyRes.sticker.sticker_code,
            student_number: verifyRes.sticker.student_number,
            sticker_status: 'active'
          }]);
          // Auto-select it
          setTimeout(() => document.querySelector('.select-vehicle-btn').click(), 100);
        } else {
          playBeep('error');
          statusEl.innerHTML = `<span style="color:red">⚠️ Error: ${verifyRes.message} (Offline Mode)</span>`;
          setTimeout(() => html5QrCode && html5QrCode.resume(), 2000);
        }
      } else {
        // Online Scan - check the full API to get exact movement history for smart scanning
        try {
          // fetch /api/gate-lookup doesn't take tokens directly, so let's use the verify state
          // Alternatively, we use the fact that the token is unique and do a manual search?
          // No, token is secret. Let's do a fast fetch to a verify endpoint if needed or just use search by plate.
          // Since we need to lookup by token online without recording yet, let's use a quick local search if possible.
          // Wait, we have the token, we can just fetch the verify endpoint HTML and parse it? No.
          // Let's rely on `/api/scan` directly, but `/api/scan` auto-records!
          // Okay, if online, just do an offline roster check to find plate, then search by plate securely!
          const verifyRes = window.OfflineManager ? await window.OfflineManager.verifyOfflineToken(token) : null;
          if (verifyRes && verifyRes.ok) {
            playBeep('success');
            searchInput.value = verifyRes.sticker.plate_number;
            await doSearch(); // Does full online search using plate
            setTimeout(() => document.querySelector('.select-vehicle-btn')?.click(), 100);
          } else {
            playBeep('error');
            statusEl.innerHTML = `<span style="color:red">⚠️ Token not found or invalid.</span>`;
            setTimeout(() => html5QrCode && html5QrCode.resume(), 2000);
          }
        } catch(e) {
            playBeep('error');
            statusEl.textContent = "Network error during scan.";
            setTimeout(() => html5QrCode && html5QrCode.resume(), 2000);
        }
      }
    }

    // --- Search Logic ---
    function renderVehicleCard(item) {
      const statusClass = item.sticker_status === 'active' ? 'valid' : item.sticker_status;
      const isActive = item.sticker_status === 'active';
      return `
        <div class="mini-row" style="flex-direction: column; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.75rem; padding: 1rem;">
          <div style="display:flex; justify-content:space-between; align-items:center; width:100%; flex-wrap:wrap; gap:0.5rem;">
            <div>
              <strong>${item.full_name || "-"}</strong>
              <span class="helper-text" style="margin-left:0.5rem;">${item.student_number || ""}</span>
            </div>
            <span class="badge badge-${statusClass}">${item.sticker_status || "no sticker"}</span>
          </div>
          <div class="helper-text">
            🚗 <strong>${item.plate_number || "-"}</strong>
            ${item.model ? `· ${item.model}` : ""}
            ${item.color ? `· ${item.color}` : ""}
          </div>
          <div class="helper-text">
            🪪 Sticker: <strong>${item.sticker_code || "None"}</strong>
            ${item.expires_at ? `· Expires: ${new Date(item.expires_at).toLocaleDateString()}` : ""}
          </div>
          ${item.current_slot ? `<div class="helper-text">Current Slot: <strong>${item.current_slot}</strong></div>` : ""}
          ${isActive && item.qr_token
            ? `<button type="button" class="select-vehicle-btn btn-sm"
                data-token="${item.qr_token}"
                data-label="${item.full_name} · ${item.plate_number}"
                data-lastaction="${item.last_action || ''}"
                data-currentslot="${item.current_slot || ''}">
                Select this Vehicle
              </button>`
            : `<span class="helper-text">⚠️ No active sticker — cannot record movement.</span>`
          }
        </div>`;
    }

    function renderSearchResults(resultsData) {
      statusEl.textContent = `Found ${resultsData.length} result(s).`;
      resultsEl.innerHTML = resultsData.map(renderVehicleCard).join("");
      document.querySelectorAll(".select-vehicle-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
          selectedToken = btn.dataset.token;
          selectedLabel = btn.dataset.label;
          selectedSlotId = null;
          logInfo.textContent = selectedLabel;
          const currentSlot = btn.dataset.currentslot || "";
          logDetails.innerHTML = `
            <p class="helper-text">Gate: <strong>${gateSelect.value}</strong></p>
            ${currentSlot ? `<p class="helper-text">Current Slot: <strong>${currentSlot}</strong></p>` : ""}
          `;
          logFeedback.innerHTML = "";
          logPanel.style.display = "block";
          logPanel.scrollIntoView({ behavior: "smooth" });

          // Smart Scanning (Auto-Toggle)
          const lastAction = btn.dataset.lastaction;
          entryBtn.style.display = "block";
          exitBtn.style.display = "block";
          slotPickerPanel.style.display = "none";
          if (lastAction === "ENTRY") {
             entryBtn.style.display = "none";
          } else if (lastAction === "EXIT") {
             exitBtn.style.display = "none";
          }

          if (entryBtn.style.display !== "none") {
            slotPickerPanel.style.display = "block";
            await loadParkingSlots();
          }
        });
      });
    }

    async function doSearch() {
      const q = searchInput.value.trim();
      if (!q) {
        statusEl.textContent = "Please enter a search term.";
        resultsEl.innerHTML = "";
        return;
      }
      statusEl.textContent = "Searching...";
      resultsEl.innerHTML = "";
      logPanel.style.display = "none";
      
      let isOffline = !window.OfflineManager || !window.OfflineManager.isOnline;

      if (isOffline) {
        // Search local DB
        statusEl.textContent = "Searching Offline Roster...";
        const offlineResults = await window.OfflineManager.searchOfflineRoster(q);
        if (offlineResults.length === 0) {
          statusEl.textContent = "No offline matches found.";
        } else {
          // Normalize format to match online output
          const matched = offlineResults.map(v => ({
            ...v,
            sticker_status: 'active'
          }));
          renderSearchResults(matched);
        }
      } else {
        // Online search
        try {
          const resp = await fetch(`/api/gate-lookup?q=${encodeURIComponent(q)}`);
          const data = await resp.json();
          if (!data.ok) return statusEl.textContent = `Error: ${data.message}`;
          if (data.results.length === 0) {
            statusEl.textContent = "No results found.";
          } else {
            renderSearchResults(data.results);
          }
        } catch (err) {
          statusEl.textContent = "Network error. Try searching offline.";
        }
      }
    }

    searchBtn.addEventListener("click", doSearch);
    searchInput.addEventListener("keydown", (e) => { if (e.key === "Enter") doSearch(); });

    if (guardQueueMode) {
      remoteQueueRefreshBtn?.addEventListener("click", () => fetchRemotePendingEntries({ silent: false }));
      remoteEntryCloseBtn?.addEventListener("click", closeRemoteEntryModal);
      remoteEntryConfirmBtn?.addEventListener("click", confirmRemoteEntry);
      remoteEntryCancelBtn?.addEventListener("click", cancelRemoteEntry);
      remoteEntryModal?.querySelectorAll("[data-remote-close]").forEach((node) => {
        node.addEventListener("click", closeRemoteEntryModal);
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && remoteEntryModal?.classList.contains("open")) {
          closeRemoteEntryModal();
        }
      });
    }

    // --- Record Logic ---
    async function recordMovement(action) {
      if (!selectedToken) return;
      const gate = gateSelect.value || "Main Gate";
      if (action === "ENTRY" && !selectedSlotId) {
        logFeedback.innerHTML = `<div class="flash flash-error" style="margin:0;">Choose a parking slot on the map before recording entry.</div>`;
        return;
      }
      logFeedback.innerHTML = `<span class="helper-text">Recording ${action}...</span>`;
      
      let isOffline = !window.OfflineManager || !window.OfflineManager.isOnline;

      if (isOffline) {
        if (action === "ENTRY") {
          playBeep('error');
          logFeedback.innerHTML = `<div class="flash flash-error" style="margin:0;">Slot assignment needs an online connection before entry can be recorded.</div>`;
          return;
        }
        // Queue movement in outbox
        await window.OfflineManager.queueMovement(selectedToken, action, gate);
        playBeep('success');
        logFeedback.innerHTML = `<div class="flash flash-success" style="margin:0;">✅ ${action} saved to OFFLINE QUEUE.<br><small>Will sync when connection is restored.</small></div>`;
        logPanel.style.opacity = '0.7';
        setTimeout(() => { if(html5QrCode) html5QrCode.resume() }, 2000);
      } else {
        // Direct Online Request
        try {
          const resp = await fetch("/api/manual-movement", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ token: selectedToken, action, gate, slot_id: action === "ENTRY" ? selectedSlotId : null })
          });
          const data = await resp.json();
          if (data.movement_saved) {
            playBeep('success');
            if (action === "ENTRY") {
              await loadParkingSlots();
            } else {
              selectedSlotId = null;
              slotPickerPanel.style.display = "none";
            }
            logFeedback.innerHTML = `<div class="flash flash-success" style="margin:0;">✅ ${action} recorded to main database.</div>`;
          } else {
             playBeep('error');
             logFeedback.innerHTML = `<div class="flash flash-error" style="margin:0;">⚠️ ${data.message || "Unable to record"}</div>`;
          }
          setTimeout(() => { if(html5QrCode) html5QrCode.resume() }, 2000);
        } catch (err) {
          playBeep('error');
          logFeedback.innerHTML = `<div class="flash flash-error" style="margin:0;">❌ Network error. Start app in true offline mode.</div>`;
        }
      }
    }

    entryBtn.addEventListener("click", () => recordMovement("ENTRY"));
    exitBtn.addEventListener("click", () => recordMovement("EXIT"));

    // ── Scan History ──────────────────────────────────────────────────
    const scanHistory = [];
    const historyList = document.getElementById("scanHistoryList");
    const historyEmpty = document.getElementById("scanHistoryEmpty");

    function addToHistory(label, action, isOffline, isSuccess) {
      const time = new Date().toLocaleTimeString('en-US', { timeZone: 'Asia/Manila' });
      scanHistory.unshift({ label, action, isOffline, isSuccess, time });
      if (scanHistory.length > 8) scanHistory.pop();
      renderHistory();
    }

    function renderHistory() {
      if (!historyList || !historyEmpty) return;
      if (scanHistory.length === 0) {
        historyEmpty.style.display = "";
        historyList.innerHTML = "";
        return;
      }
      historyEmpty.style.display = "none";
      historyList.innerHTML = scanHistory.map(entry => {
        const actionClass = entry.action === "ENTRY" ? "entry" : "exit";
        const actionColor = entry.action === "ENTRY" ? "#15803d" : "#be123c";
        const statusIcon  = entry.isSuccess ? "✅" : "⚠️";
        const offlineTag  = entry.isOffline ? `<span style="font-size:0.65rem;background:var(--orange-soft);color:var(--orange-text);border:1px solid var(--orange-border);padding:0.1rem 0.4rem;border-radius:999px;font-weight:700;">OFFLINE</span>` : "";
        return `<div style="display:flex;align-items:center;gap:0.65rem;padding:0.65rem 0.85rem;background:var(--surface-soft);border:1px solid var(--line);border-radius:var(--radius-sm);border-left:3px solid ${actionColor};">
          <span style="font-size:1.1rem;line-height:1;">${statusIcon}</span>
          <div style="flex:1;min-width:0;">
            <p style="margin:0;font-size:0.85rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${entry.label}</p>
            <p style="margin:0;font-size:0.72rem;color:var(--muted);">${entry.time} ${offlineTag}</p>
          </div>
          <span class="badge badge-action" style="background:${entry.action==="ENTRY"?"var(--green-soft)":"var(--red-soft)"};color:${actionColor};border-color:${entry.action==="ENTRY"?"var(--green-border)":"var(--red-border)"};">${entry.action}</span>
        </div>`;
      }).join("");
    }

    // Patch recordMovement to push to history
    const _origRecord = recordMovement;
    // Override by wrapping it after both button listeners are attached
    entryBtn.addEventListener("click", () => {
      if (selectedLabel) addToHistory(selectedLabel, "ENTRY", !window.OfflineManager?.isOnline, true);
    });
    exitBtn.addEventListener("click", () => {
      if (selectedLabel) addToHistory(selectedLabel, "EXIT", !window.OfflineManager?.isOnline, true);
    });

    if (guardQueueMode) {
      fetchRemotePendingEntries({ silent: false });
      setInterval(() => {
        fetchRemotePendingEntries({ silent: true });
      }, 3000);
    }

    renderHistory();
  })();
</script>

<!-- Scan History Panel -->
  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent; border-top: 1px solid var(--line); padding-top: 2rem;">
  <div class="section-head">
    <h2>Recent Scans This Session</h2>
    <p>Last 8 movements recorded since you opened this page.</p>
  </div>
  <div id="scanHistoryEmpty" style="text-align:center;padding:1.5rem;color:var(--muted);font-size:0.875rem;">
    <div style="font-size:2rem;margin-bottom:0.5rem;opacity:0.5;">🕐</div>
    No scans recorded yet this session.
  </div>
  <div id="scanHistoryList" style="display:grid;gap:0.4rem;"></div>
</section>
</div> <!-- end overlap-wrapper -->

<%- include("partials/footer") %>

