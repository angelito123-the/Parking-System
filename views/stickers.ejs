<%- include("partials/header") %>
<%
  const stickerBaseUrl = typeof requestBaseUrl === "string" && requestBaseUrl
    ? requestBaseUrl
    : APP_BASE_URL;
  const pageFlash = typeof flash !== 'undefined' ? flash : null;

  function stickerDisplayStatus(sticker) {
    if (sticker.status !== 'active') return sticker.status;
    if (sticker.expires_at && new Date(sticker.expires_at).getTime() < Date.now()) return 'expired';
    return 'active';
  }
%>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Sticker Management</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Total Issued</h3>
      <p><%= stickers.length %></p>
    </div>
    <div class="hero-card" style="background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.4);">
      <h3>Active Stickers</h3>
      <p><%= stickers.filter(s => s.status === 'active').length %></p>
    </div>
  </div>
  <% if (pageFlash) { %>
    <div class="flash flash-<%= pageFlash.type === 'success' ? 'success' : 'error' %>" style="margin-top: 1rem;">
      <%= pageFlash.type === 'success' ? '✅' : '⚠️' %> <%= pageFlash.message %>
    </div>
  <% } %>
</section>

<div class="overlap-wrapper" style="display: grid; gap: 3rem;">
  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
    <div class="section-head">
      <h2 style="font-size: 1.25rem;">Sticker Issuance</h2>
      <p>Create secure QR-enabled stickers for validated student vehicles.</p>
    </div>
  <form method="post" action="/stickers" class="form-grid">
    <label for="st_vehicle_id">Vehicle</label>
    <select id="st_vehicle_id" name="vehicle_id" required>
      <option value="">Select vehicle</option>
      <% vehicles.forEach(vehicle => { %>
        <option value="<%= vehicle.id %>">
          <%= vehicle.plate_number %> — <%= vehicle.student_number %> — <%= vehicle.full_name %>
        </option>
      <% }) %>
    </select>

    <label for="st_expires">Expiration Date (optional)</label>
    <input id="st_expires" type="date" name="expires_at" />

    <button type="submit">Issue Sticker</button>
  </form>
</section>

  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
    <div class="section-head">
      <h2 style="font-size: 1.25rem;">Issued Stickers</h2>
      <p>Total records: <strong><%= stickers.length %></strong></p>
    </div>
  <div class="table-wrap desktop-only-table">
    <table>
      <thead>
        <tr>
          <th>Sticker Code</th>
          <th>Student</th>
          <th>Plate Number</th>
          <th>Status</th>
          <th>Expires</th>
          <th>QR Code</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (stickers.length === 0) { %>
          <tr style="box-shadow: none;">
            <td colspan="7" style="background: transparent; border: none;">
              <div class="empty-state">
                <div class="empty-state-icon">🪪</div>
                <p>No stickers issued yet. Use the form above to issue one.</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% stickers.forEach(sticker => {
          const displayStatus = stickerDisplayStatus(sticker);
          const badgeClass = displayStatus === 'active' ? 'valid' : displayStatus;
        %>
          <tr>
            <td><strong><%= sticker.sticker_code %></strong></td>
            <td><%= sticker.student_number %> <span style="color:var(--muted); font-size:0.8rem; margin-left:0.5rem;"><%= sticker.full_name %></span></td>
            <td><span class="badge" style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1;"><%= sticker.plate_number %></span></td>
            <td>
              <span class="badge badge-<%= badgeClass %>">
                <%= displayStatus %>
              </span>
            </td>
            <td style="color: var(--muted);"><%= sticker.expires_at ? new Date(sticker.expires_at).toLocaleDateString() : "No expiry" %></td>
            <td>
              <div class="action-row" style="gap: 1rem;">
                <a href="/stickers/<%= sticker.id %>/qr" target="_blank" class="link-btn" style="text-decoration:none; color:var(--blue-mid); font-weight:600; font-size:0.8rem;">View QR</a>
                <a href="/stickers/<%= sticker.id %>/qr" download="sticker-<%= sticker.sticker_code %>.png" class="link-btn" style="text-decoration:none; color:var(--text); font-weight:600; font-size:0.8rem;">⬇ Download</a>
              </div>
              <small class="helper-text" style="display:block; margin-top:0.25rem;"><%= stickerBaseUrl %>/verify/<%= sticker.qr_token %></small>
            </td>
            <td style="text-align: right; padding-right: 1.5rem;">
              <% if (sticker.status === "active") { %>
                <form method="post" action="/stickers/<%= sticker.id %>/revoke"
                      onsubmit="return confirm('Revoke sticker <%= sticker.sticker_code %>?')"
                      style="margin:0; text-align:right;">
                  <button type="submit" class="danger btn-sm">Revoke</button>
                </form>
              <% } else { %>
                <span class="helper-text">—</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile-Ready Cards -->
  <div class="mobile-data-list">
    <% if (stickers.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">🪪</div>
        <p>No stickers issued yet.</p>
      </div>
    <% } %>
    <% stickers.forEach(sticker => { 
      const displayStatus = stickerDisplayStatus(sticker);
      const badgeClass = displayStatus === 'active' ? 'valid' : displayStatus;
    %>
      <div class="mobile-data-card">
        <div class="card-header">
          <div class="card-title">Code: <%= sticker.sticker_code %></div>
          <span class="badge badge-<%= badgeClass %>"><%= displayStatus %></span>
        </div>
        <div class="card-body">
          <div class="card-item">👤 <strong>Owner:</strong> <%= sticker.full_name %></div>
          <div class="card-item">🚗 <strong>Plate:</strong> <%= sticker.plate_number %></div>
          <div class="card-item">📅 <strong>Expires:</strong> <%= sticker.expires_at ? new Date(sticker.expires_at).toLocaleDateString() : "Never" %></div>
        </div>
        <div class="card-actions">
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
            <a href="/stickers/<%= sticker.id %>/qr" target="_blank" class="btn btn-mobile-touch" style="background:var(--blue-soft); color:var(--blue-mid); border: 1px solid rgba(37,99,235,0.2); text-decoration:none;">View QR</a>
            <a href="/stickers/<%= sticker.id %>/qr" download class="btn btn-mobile-touch" style="background:var(--surface-soft); color:var(--text); border:1px solid var(--line); text-decoration:none;">Download</a>
          </div>
          <% if (sticker.status === "active") { %>
            <form style="margin:0;" method="post" action="/stickers/<%= sticker.id %>/revoke"
                  onsubmit="return confirm('Revoke sticker <%= sticker.sticker_code %>?')">
              <button type="submit" class="danger btn-mobile-touch">Revoke Sticker</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
  </section>
</div>
</section>

<%- include("partials/footer") %>
