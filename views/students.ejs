<%- include("partials/header") %>

<% const pageFlash = typeof flash !== 'undefined' ? flash : null; %>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Students &amp; Vehicles</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Enrolled Students</h3>
      <p><%= students.length %></p>
    </div>
    <div class="hero-card">
      <h3>Registered Vehicles</h3>
      <p><%= students.reduce((t, s) => t + (s.vehicles ? s.vehicles.length : 0), 0) %></p>
    </div>
  </div>
  <% if (pageFlash) { %>
    <div class="flash flash-<%= pageFlash.type === 'success' ? 'success' : 'error' %>" style="margin-top: 1rem;">
      <strong><%= pageFlash.type === 'success' ? 'Success:' : 'Notice:' %></strong> <%= pageFlash.message %>
    </div>
  <% } %>
</section>

<div class="overlap-wrapper">

  <!-- section -->
  <section class="reg-panel">
    <div class="section-head">
      <h2>New Registration</h2>
      <p>Register a student. You may also add their vehicle in the same step - vehicle fields are optional.</p>
    </div>

    <form method="post" action="/students" class="form-grid" id="regForm">
      <!-- Student Fields -->
      <div class="form-group-label">Student Information</div>
      <div class="form-row-2">
        <div>
          <label for="s_student_number">Student Number <span class="req">*</span></label>
          <input id="s_student_number" name="student_number" required placeholder="e.g. 2024-00123" />
        </div>
        <div>
          <label for="s_full_name">Full Name <span class="req">*</span></label>
          <input id="s_full_name" name="full_name" required placeholder="Last Name, First Name M." />
        </div>
      </div>
      <div class="form-row-2">
        <div>
          <label for="s_program">Program</label>
          <input id="s_program" name="program" placeholder="e.g. BS Aviation Technology" />
        </div>
        <div>
          <label for="s_email">Email</label>
          <input id="s_email" name="email" type="email" placeholder="student@school.edu.ph" />
        </div>
      </div>

      <!-- Vehicle Toggle -->
      <div class="vehicle-toggle-row">
        <button type="button" class="btn-ghost" id="vehicleToggle" onclick="toggleVehicleSection()">Add Vehicle Details</button>
      </div>

      <!-- Vehicle Fields (hidden by default) -->
      <div id="vehicleSection" class="vehicle-section" style="display:none;">
        <div class="form-group-label" style="margin-top:0;">Vehicle Information <span class="optional-label">(optional)</span></div>
        <div class="form-row-2">
          <div>
            <label for="v_plate">Plate Number</label>
            <input id="v_plate" name="plate_number" placeholder="e.g. ABC 1234" />
          </div>
          <div>
            <label for="v_model">Vehicle Model</label>
            <input id="v_model" name="model" placeholder="e.g. Honda Click 125i" />
          </div>
        </div>
        <div class="form-row-2">
          <div>
            <label for="v_color">Color</label>
            <input id="v_color" name="color" placeholder="e.g. Black" />
          </div>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" id="regSubmitBtn">Save Student</button>
      </div>
    </form>
  </section>

  <!-- section -->
  <section class="directory-panel">
    <div class="section-head">
      <h2>Student Directory</h2>
      <p>Click <strong>Edit</strong> on any student or vehicle to update their information.</p>
    </div>

    <div class="table-tools">
      <label for="studentSearch" class="sr-only">Search students</label>
      <input
        id="studentSearch"
        type="search"
        placeholder="Search by name, student number, program, email, or plate..."
      />
      <p id="studentSearchCount" class="helper-text">Showing <%= students.length %> students</p>
    </div>

    <% if (students.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M16 19v-1a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v1"></path>
            <circle cx="9.5" cy="7" r="3"></circle>
            <path d="M17 11a3 3 0 1 0 0-6"></path>
            <path d="M21 19v-1.3a4 4 0 0 0-2.8-3.8"></path>
          </svg>
        </div>
        <p>No students registered yet. Use the form above to add one.</p>
      </div>
    <% } %>

    <div id="studentDirectory" class="student-directory">
    <% students.forEach(student => { %>
      <div class="student-card" data-searchable="<%= student.student_number %> <%= student.full_name %> <%= student.program %> <%= student.email %> <%= (student.vehicles || []).map(v => v.plate_number + ' ' + v.model).join(' ') %>">

        <!-- section -->
        <div class="sc-header">
          <div class="sc-meta">
            <div class="sc-name"><%= student.full_name %></div>
            <span class="badge" style="background:var(--blue-soft); color:var(--blue-mid); border:1px solid rgba(37,99,235,0.2);">
              <%= student.student_number %>
            </span>
          </div>
          <div class="sc-header-actions">
            <button type="button" class="btn-edit-sm" onclick="toggleStudentEdit(<%= student.id %>)" id="editStudentBtn_<%= student.id %>">Edit</button>
            <form style="margin:0;" method="post" action="/students/<%= student.id %>/delete"
                  onsubmit="return confirm('Delete <%= student.full_name %>? This will also remove all their vehicles and cannot be undone.')">
              <button type="submit" class="btn-delete-sm">Delete</button>
            </form>
          </div>
        </div>

        <!-- Student Info Row -->
        <div class="sc-info-row">
          <% if (student.program) { %>
            <span class="sc-info-chip">Program: <%= student.program %></span>
          <% } %>
          <% if (student.email) { %>
            <span class="sc-info-chip">Email: <%= student.email %></span>
          <% } %>
          <% if (!student.program && !student.email) { %>
            <span class="sc-info-chip muted">No program or email on file</span>
          <% } %>
        </div>

        <!-- section -->
        <div class="inline-edit-form" id="studentEditForm_<%= student.id %>" style="display:none;">
          <form method="post" action="/students/<%= student.id %>/edit" class="edit-form-grid">
            <div class="form-row-2">
              <div>
                <label>Student Number</label>
                <input name="student_number" value="<%= student.student_number %>" required />
              </div>
              <div>
                <label>Full Name</label>
                <input name="full_name" value="<%= student.full_name %>" required />
              </div>
            </div>
            <div class="form-row-2">
              <div>
                <label>Program</label>
                <input name="program" value="<%= student.program || '' %>" />
              </div>
              <div>
                <label>Email</label>
                <input name="email" type="email" value="<%= student.email || '' %>" />
              </div>
            </div>
            <div class="edit-form-actions">
              <button type="submit" class="btn-save-sm">Save Changes</button>
              <button type="button" class="btn-cancel-sm" onclick="toggleStudentEdit(<%= student.id %>)">Cancel</button>
            </div>
          </form>
        </div>

        <!-- section -->
        <div class="sc-vehicles">
          <div class="sv-header">
            <span class="sv-title">Vehicles (<%= (student.vehicles || []).length %>)</span>
            <button type="button" class="btn-add-vehicle" onclick="toggleAddVehicle(<%= student.id %>)" id="addVehicleBtn_<%= student.id %>">Add Vehicle</button>
          </div>

          <!-- Add Vehicle Inline Form -->
          <div class="inline-edit-form add-vehicle-form" id="addVehicleForm_<%= student.id %>" style="display:none;">
            <form method="post" action="/vehicles" class="edit-form-grid">
              <input type="hidden" name="student_id" value="<%= student.id %>" />
              <div class="form-row-3">
                <div>
                  <label>Plate Number <span class="req">*</span></label>
                  <input name="plate_number" required placeholder="e.g. ABC 1234" />
                </div>
                <div>
                  <label>Model</label>
                  <input name="model" placeholder="e.g. Honda Click 125i" />
                </div>
                <div>
                  <label>Color</label>
                  <input name="color" placeholder="e.g. Black" />
                </div>
              </div>
              <div class="edit-form-actions">
                <button type="submit" class="btn-save-sm">Register Vehicle</button>
                <button type="button" class="btn-cancel-sm" onclick="toggleAddVehicle(<%= student.id %>)">Cancel</button>
              </div>
            </form>
          </div>

          <!-- Vehicle List -->
          <% if (!student.vehicles || student.vehicles.length === 0) { %>
            <div class="sv-empty" id="svEmpty_<%= student.id %>">No vehicles registered yet.</div>
          <% } %>

          <% (student.vehicles || []).forEach(vehicle => { %>
            <div class="sv-item" id="svItem_<%= vehicle.id %>">
              <div class="sv-item-main">
                <div class="sv-plate">
                  <span class="badge" style="background:#f1f5f9; color:#334155; border:1px solid #cbd5e1; font-size:0.8rem;">
                    <%= vehicle.plate_number %>
                  </span>
                  <span class="sv-model"><%= vehicle.model || 'Unknown model' %></span>
                  <% if (vehicle.color) { %>
                    <span class="sv-color"> - <%= vehicle.color %></span>
                  <% } %>
                </div>
                <div class="sv-item-actions">
                  <button type="button" class="btn-edit-xs" onclick="toggleVehicleEdit(<%= vehicle.id %>)">Edit</button>
                  <form style="margin:0;" method="post" action="/vehicles/<%= vehicle.id %>/delete"
                        onsubmit="return confirm('Delete vehicle <%= vehicle.plate_number %>? This cannot be undone.')">
                    <button type="submit" class="btn-delete-xs">Delete</button>
                  </form>
                </div>
              </div>

              <!-- Inline Vehicle Edit Form -->
              <div class="inline-edit-form vehicle-edit-form" id="vehicleEditForm_<%= vehicle.id %>" style="display:none;">
                <form method="post" action="/vehicles/<%= vehicle.id %>/edit" class="edit-form-grid">
                  <div class="form-row-3">
                    <div>
                      <label>Plate Number</label>
                      <input name="plate_number" value="<%= vehicle.plate_number %>" required />
                    </div>
                    <div>
                      <label>Model</label>
                      <input name="model" value="<%= vehicle.model || '' %>" />
                    </div>
                    <div>
                      <label>Color</label>
                      <input name="color" value="<%= vehicle.color || '' %>" />
                    </div>
                  </div>
                  <div class="edit-form-actions">
                    <button type="submit" class="btn-save-sm">Save</button>
                    <button type="button" class="btn-cancel-sm" onclick="toggleVehicleEdit(<%= vehicle.id %>)">Cancel</button>
                  </div>
                </form>
              </div>
            </div>
          <% }) %>
        </div>

      </div>
    <% }) %>
    </div>
  </section>
</div>

<!-- section -->
<style>
  .overlap-wrapper {
    display: grid;
    gap: 1.75rem;
  }

  .reg-panel,
  .directory-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
  }

  .section-head {
    margin-bottom: 1.1rem;
  }

  .section-head h2 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 760;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .section-head p {
    margin: 0.45rem 0 0;
    color: var(--muted);
    max-width: 70ch;
  }

  .form-group-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--muted);
    margin-top: 0.6rem;
  }

  .form-row-2,
  .form-row-3 {
    display: grid;
    gap: 0.8rem;
  }

  .form-row-2 {
    grid-template-columns: 1fr 1fr;
  }

  .form-row-3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .form-actions {
    margin-top: 0.7rem;
  }

  .req {
    color: var(--red-text);
  }

  .optional-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: none;
    letter-spacing: 0;
  }

  .vehicle-toggle-row {
    margin: 0.6rem 0 0.25rem;
  }

  .vehicle-section {
    background: color-mix(in oklab, var(--surface-soft) 92%, #ffffff 8%);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1.05rem;
    display: grid;
    gap: 0.7rem;
    animation: revealUp 0.2s ease;
  }

  .btn-ghost {
    background: var(--surface-soft);
    border: 1px solid var(--line-strong);
    color: var(--text-secondary);
    font-size: 0.83rem;
    font-weight: 650;
    padding: 0.56rem 0.95rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 0.16s ease, background-color 0.16s ease, color 0.16s ease;
    width: auto;
    box-shadow: none;
  }

  .btn-ghost:hover {
    background: var(--surface);
    border-color: var(--blue-mid);
    color: var(--blue-mid);
  }

  .table-tools {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .table-tools input[type="search"] {
    flex: 1 1 370px;
    max-width: 540px;
  }

  .table-tools .helper-text {
    margin: 0;
    font-size: 0.88rem;
    color: var(--muted);
  }

  .student-directory {
    display: grid;
    gap: 0.9rem;
  }

  .student-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1.2rem 1.3rem;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.16s ease, box-shadow 0.16s ease;
    display: grid;
    gap: 0.78rem;
  }

  .student-card:hover {
    border-color: rgba(37, 99, 235, 0.32);
    box-shadow: var(--shadow-md);
  }

  .sc-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .sc-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .sc-name {
    font-size: 1.03rem;
    font-weight: 760;
    font-family: "Plus Jakarta Sans", sans-serif;
    color: var(--text);
  }

  .sc-header-actions {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .sc-info-row {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .sc-info-chip {
    font-size: 0.78rem;
    color: var(--muted);
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.24rem 0.66rem;
  }

  .sc-info-chip.muted {
    font-style: italic;
  }

  .btn-edit-sm,
  .btn-edit-xs {
    background: var(--surface-soft);
    color: var(--blue-mid);
    border: 1px solid rgba(37, 99, 235, 0.24);
    font-weight: 650;
  }

  .btn-delete-sm,
  .btn-delete-xs {
    background: #fff7f8;
    color: var(--red-text);
    border: 1px solid var(--red-border);
    font-weight: 650;
  }

  .btn-edit-sm,
  .btn-delete-sm {
    font-size: 0.78rem;
    padding: 0.34rem 0.74rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.16s ease;
  }

  .btn-edit-xs,
  .btn-delete-xs {
    font-size: 0.73rem;
    padding: 0.2rem 0.56rem;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.16s ease;
  }

  .btn-edit-sm:hover,
  .btn-edit-xs:hover {
    background: var(--blue-soft);
  }

  .btn-delete-sm:hover,
  .btn-delete-xs:hover {
    background: var(--red-soft);
  }

  .inline-edit-form {
    background: var(--surface-soft);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    padding: 1rem 1.1rem;
    animation: revealUp 0.18s ease;
  }

  .edit-form-grid {
    display: grid !important;
    gap: 0.66rem;
    width: 100%;
  }

  .edit-form-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .btn-save-sm {
    background: linear-gradient(135deg, var(--blue-1), var(--blue-mid));
    color: #fff;
    border: none;
    font-size: 0.81rem;
    font-weight: 650;
    padding: 0.46rem 0.9rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: filter 0.16s ease;
  }

  .btn-save-sm:hover {
    filter: brightness(0.96);
  }

  .btn-cancel-sm {
    background: var(--surface);
    color: var(--muted);
    border: 1px solid var(--line);
    font-size: 0.81rem;
    font-weight: 650;
    padding: 0.46rem 0.9rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .btn-cancel-sm:hover {
    background: var(--surface-soft);
    color: var(--text);
  }

  .sc-vehicles {
    border-top: 1px solid var(--line);
    padding-top: 0.85rem;
    display: grid;
    gap: 0.5rem;
  }

  .sv-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.2rem;
  }

  .sv-title {
    font-size: 0.74rem;
    font-weight: 720;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .btn-add-vehicle {
    background: var(--surface);
    border: 1px solid var(--line-strong);
    color: var(--blue-mid);
    font-size: 0.76rem;
    font-weight: 650;
    padding: 0.22rem 0.64rem;
    border-radius: 999px;
    cursor: pointer;
  }

  .btn-add-vehicle:hover {
    background: var(--blue-soft);
    border-color: var(--blue-mid);
  }

  .sv-empty {
    font-size: 0.8rem;
    color: var(--muted);
    font-style: italic;
    padding: 0.2rem 0;
  }

  .sv-item {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .sv-item-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.72rem;
    padding: 0.62rem 0.82rem;
    flex-wrap: wrap;
  }

  .sv-plate {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .sv-model {
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .sv-color {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .sv-item-actions {
    display: flex;
    gap: 0.3rem;
    align-items: center;
  }

  .add-vehicle-form {
    margin: 0.26rem 0 0.5rem;
    border-color: var(--green-border);
  }

  @media (max-width: 900px) {
    .form-row-2,
    .form-row-3 {
      grid-template-columns: 1fr;
    }

    .table-tools {
      align-items: stretch;
    }

    .table-tools input[type="search"] {
      max-width: none;
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .reg-panel,
    .directory-panel {
      padding: 1.1rem;
    }

    .sc-header {
      flex-direction: column;
      gap: 0.5rem;
    }

    .sc-header-actions {
      width: 100%;
      justify-content: flex-end;
    }

    .student-card {
      padding: 1rem;
    }

    .sv-item-main {
      flex-direction: column;
      align-items: flex-start;
    }

    .sv-item-actions {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>

<script>
  // Toggle vehicle section in registration form
  function toggleVehicleSection() {
    const section = document.getElementById('vehicleSection');
    const btn = document.getElementById('vehicleToggle');
    const isVisible = section.style.display !== 'none';
    section.style.display = isVisible ? 'none' : 'grid';
    btn.textContent = isVisible ? 'Add Vehicle Details' : 'Hide Vehicle Details';

    // Update submit button text
    const submitBtn = document.getElementById('regSubmitBtn');
    submitBtn.textContent = isVisible ? 'Save Student' : 'Save Student and Vehicle';
  }

  // Toggle student inline edit form
  function toggleStudentEdit(id) {
    const form = document.getElementById('studentEditForm_' + id);
    const btn = document.getElementById('editStudentBtn_' + id);
    const isVisible = form.style.display !== 'none';
    form.style.display = isVisible ? 'none' : 'block';
    btn.textContent = isVisible ? 'Edit' : 'Close';
  }

  // Toggle vehicle inline edit form
  function toggleVehicleEdit(id) {
    const form = document.getElementById('vehicleEditForm_' + id);
    const isVisible = form.style.display !== 'none';
    form.style.display = isVisible ? 'none' : 'block';
  }

  // Toggle add vehicle form per student
  function toggleAddVehicle(studentId) {
    const form = document.getElementById('addVehicleForm_' + studentId);
    const btn = document.getElementById('addVehicleBtn_' + studentId);
    const isVisible = form.style.display !== 'none';
    form.style.display = isVisible ? 'none' : 'block';
    btn.textContent = isVisible ? 'Add Vehicle' : 'Cancel';
  }

  // Search filter
  (() => {
    const searchInput = document.getElementById("studentSearch");
    const countLabel = document.getElementById("studentSearchCount");
    if (!searchInput || !countLabel) return;

    const cards = Array.from(document.querySelectorAll("#studentDirectory .student-card"));
    const total = cards.length;

    function updateFilter() {
      const q = searchInput.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach(card => {
        const match = !q || card.dataset.searchable.toLowerCase().includes(q);
        card.style.display = match ? "" : "none";
        if (match) visible++;
      });
      countLabel.textContent = q
        ? `Showing ${visible} of ${total} students`
        : `Showing ${total} student${total !== 1 ? 's' : ''}`;
    }

    searchInput.addEventListener("input", updateFilter);
    updateFilter();
  })();
</script>

<%- include("partials/footer") %>

