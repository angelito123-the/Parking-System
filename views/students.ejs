<%- include("partials/header") %>

<% const pageFlash = typeof flash !== 'undefined' ? flash : null; %>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Student Management</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Enrolled Students</h3>
      <p><%= students.length %></p>
    </div>
  </div>
  <% if (pageFlash) { %>
    <div class="flash flash-<%= pageFlash.type === 'success' ? 'success' : 'error' %>" style="margin-top: 1rem;">
      <%= pageFlash.type === 'success' ? '✅' : '⚠️' %> <%= pageFlash.message %>
    </div>
  <% } %>
</section>

<div class="overlap-wrapper" style="display: grid; gap: 3rem;">
  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
    <div class="section-head">
      <h2 style="font-size: 1.25rem;">Student Registration</h2>
      <p>Add officially enrolled students eligible for parking access.</p>
    </div>
  <form method="post" action="/students" class="form-grid">
    <label for="s_student_number">Student Number</label>
    <input id="s_student_number" name="student_number" required placeholder="e.g. 2024-00123" />

    <label for="s_full_name">Full Name</label>
    <input id="s_full_name" name="full_name" required placeholder="Last Name, First Name" />

    <label for="s_program">Program</label>
    <input id="s_program" name="program" placeholder="e.g. BS Aviation Technology" />

    <label for="s_email">Email</label>
    <input id="s_email" name="email" type="email" placeholder="student@school.edu.ph" />

    <button type="submit">Save Student</button>
  </form>
</section>

  <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
    <div class="section-head">
      <h2 style="font-size: 1.25rem;">Student Directory</h2>
      <p>Manage existing records.</p>
    </div>

  <div class="table-tools">
    <label for="studentSearch" class="sr-only">Search students</label>
    <input
      id="studentSearch"
      type="search"
      placeholder="Search by name, student number, program, or email..."
    />
    <p id="studentSearchCount" class="helper-text">Showing <%= students.length %> records</p>
  </div>

  <div class="table-wrap desktop-only-table">
    <table id="studentTable">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Program</th>
          <th>Email</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (students.length === 0) { %>
          <tr style="box-shadow: none;">
            <td colspan="5" style="background: transparent; border: none;">
              <div class="empty-state">
                <div class="empty-state-icon">🎓</div>
                <p>No students registered yet. Use the form above to add one.</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% students.forEach(student => { %>
          <tr>
            <td><strong><%= student.student_number %></strong></td>
            <td><%= student.full_name %></td>
            <td><%= student.program || "-" %></td>
            <td style="color: var(--muted);"><%= student.email || "-" %></td>
            <td style="text-align: right; padding-right: 1.5rem;">
              <form style="margin:0; text-align:right;" method="post" action="/students/<%= student.id %>/delete"
                    onsubmit="return confirm('Delete <%= student.full_name %>? This cannot be undone.')">
                <button type="submit" class="danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile-Ready Cards -->
  <div class="mobile-data-list" id="studentCards">
    <% if (students.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">🎓</div>
        <p>No students registered yet.</p>
      </div>
    <% } %>
    <% students.forEach(student => { %>
      <div class="mobile-data-card" data-searchable="<%= student.student_number %> <%= student.full_name %> <%= student.program %> <%= student.email %>">
        <div class="card-header">
          <div class="card-title"><%= student.full_name %></div>
          <span class="badge" style="background:var(--blue-soft); color:var(--blue-mid); border:1px solid rgba(37,99,235,0.2);"><%= student.student_number %></span>
        </div>
        <div class="card-body">
          <div class="card-item">🎓 <strong>Program:</strong> <%= student.program || "-" %></div>
          <div class="card-item">✉️ <strong>Email:</strong> <%= student.email || "-" %></div>
        </div>
        <div class="card-actions">
          <form style="margin:0;" method="post" action="/students/<%= student.id %>/delete"
                onsubmit="return confirm('Delete <%= student.full_name %>? This cannot be undone.')">
            <button type="submit" class="danger btn-mobile-touch">Delete Student Record</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
  </section>
</div>

<script>
  (() => {
    const searchInput = document.getElementById("studentSearch");
    const table = document.getElementById("studentTable");
    const countLabel = document.getElementById("studentSearchCount");
    if (!searchInput || !table || !countLabel) return;

    const rows = Array.from(table.querySelectorAll("tbody tr"));
    const cards = Array.from(document.querySelectorAll("#studentCards .mobile-data-card"));
    const emptyRow = rows.find((r) => r.children.length === 1);
    const emptyCard = document.querySelector("#studentCards .empty-state");

    function updateFilter() {
      const q = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      // Filter Table Rows
      rows.forEach((row) => {
        if (row.children.length === 1) return; // Skip empty state row
        const match = !q || row.textContent.toLowerCase().includes(q);
        row.style.display = match ? "" : "none";
        if (match) visibleCount++;
      });
      if (emptyRow) emptyRow.style.display = (visibleCount === 0 && rows.length > 0) ? "" : "none";

      // Filter Cards
      let visibleCards = 0;
      cards.forEach((card) => {
        const text = card.dataset.searchable.toLowerCase();
        const match = !q || text.includes(q);
        card.style.display = match ? "flex" : "none";
        if (match) visibleCards++;
      });
      if (emptyCard) emptyCard.style.display = (visibleCards === 0 && cards.length > 0) ? "block" : "none";

      countLabel.textContent = q
        ? `Showing ${visibleCount || visibleCards} records`
        : `Showing ${rows.length > 1 ? rows.length : cards.length} records`;
    }

    searchInput.addEventListener("input", updateFilter);
    updateFilter();
  })();
</script>

<%- include("partials/footer") %>
