      </main>
    </div>
  </div>

  <!-- Mobile Navigation removed (now handled by top nav) -->
  <script>
    (() => {
      const clock = document.getElementById("liveClock");
      if (!clock) return;
      const render = () => {
        clock.textContent = new Date().toLocaleTimeString([], {
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit"
        });
      };
      render();
      setInterval(render, 1000);
    })();
  </script>
  <script>
    (() => {
      const body = document.body;
      requestAnimationFrame(() => body.classList.add("is-ready"));
    })();
  </script>
  <script>
    (() => {
      const body = document.body;
      if (!body) return;

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let isNavigating = false;

      const shouldAnimateLink = (link, event) => {
        if (!link) return false;
        if (prefersReducedMotion) return false;
        if (isNavigating) return false;
        if (event.defaultPrevented) return false;
        if (event.button !== 0) return false;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return false;
        if (link.hasAttribute("download")) return false;
        if (link.dataset.noTransition === "true") return false;
        if (link.target && link.target !== "_self") return false;

        const href = link.getAttribute("href") || "";
        if (!href || href.startsWith("#") || href.startsWith("javascript:")) return false;

        let nextUrl;
        try {
          nextUrl = new URL(link.href, window.location.href);
        } catch {
          return false;
        }

        if (nextUrl.origin !== window.location.origin) return false;
        const samePage = nextUrl.pathname === window.location.pathname
          && nextUrl.search === window.location.search
          && nextUrl.hash === window.location.hash;
        if (samePage) return false;
        return true;
      };

      document.addEventListener("pointerdown", (event) => {
        if (prefersReducedMotion) return;
        const target = event.target instanceof Element ? event.target.closest("button, .btn-sm, .link-btn, .quick-link-card, .top-nav-links a, .icon-btn") : null;
        if (!target) return;
        if ("disabled" in target && target.disabled) return;
        target.classList.remove("ui-tap-pop");
        void target.offsetWidth;
        target.classList.add("ui-tap-pop");
      });

      document.addEventListener("animationend", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.classList.contains("ui-tap-pop")) {
          target.classList.remove("ui-tap-pop");
        }
      });

      document.addEventListener("click", (event) => {
        const source = event.target instanceof Element ? event.target : null;
        if (!source) return;
        const link = source.closest("a[href]");
        if (!shouldAnimateLink(link, event)) return;
        event.preventDefault();

        isNavigating = true;
        body.classList.add("page-transitioning");
        window.setTimeout(() => {
          window.location.assign(link.href);
        }, 170);
      }, true);

      window.addEventListener("pageshow", () => {
        isNavigating = false;
        body.classList.remove("page-transitioning");
      });
    })();
  </script>
</body>
</html>
