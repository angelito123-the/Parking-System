<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f2942">
  <title>NAAP Parking System</title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="manifest" href="/manifest.json" />
  <script src="/offline-sync.js"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(() => console.log('Service Worker registered'))
          .catch((err) => console.error('SW registration failed:', err));
      });
    }

    window.addEventListener('load', () => {
      if (window.OfflineManager) {
        OfflineManager.init((isOnline) => {
          const badge = document.getElementById('networkIndicator');
          const mobileBadge = document.getElementById('mobileNetworkIndicator');
          [badge, mobileBadge].forEach(el => {
            if (el) {
              el.textContent = isOnline ? 'Online' : 'Offline';
              el.classList.toggle('is-online', isOnline);
              el.classList.toggle('is-offline', !isOnline);
            }
          });
        });
      }
    });
  </script>
  <!-- Dark Mode Init (Prevent FOUC) -->
  <script>
    (function () {
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <style>
    html,
    body {
      background: #eaf1f9;
    }

    html[data-theme="dark"],
    html[data-theme="dark"] body {
      background: #0e1826;
    }
  </style>
</head>
<%
  const pathNow = typeof currentPath === "string" ? currentPath : "";
  const safeUser = typeof currentUser === "object" && currentUser ? currentUser : null;
  const roleNow = String(safeUser?.role || "").toLowerCase();
  const usernameNow = String(safeUser?.username || "User");
  const avatarInitial = usernameNow ? usernameNow.charAt(0).toUpperCase() : "U";
  const roleLabelMap = {
    admin: "Admin",
    guard: "Guard"
  };
  const roleLabel = roleLabelMap[roleNow] || "User";
  const pageSlug = (pathNow === "/" ? "dashboard" : pathNow.replace(/\//g, "-").replace(/^-+/, "")) || "dashboard";
  const pageTitleMap = {
    "/": "Dashboard",
    "/admin": "Admin Dashboard",
    "/admin/slots": "Available Slots",
    "/admin/updates": "Latest Updates",
    "/admin/records": "Gate Records",
    "/guard": "Guard Dashboard",
    "/admin/users": "User Management",
    "/students": "Students & Vehicles",
    "/stickers": "Stickers",
    "/reports": "Reports",
    "/scanner": "Gate Console",
    "/scanner/auto": "Automatic Gate Camera"
  };
  const pageTitle = pageTitleMap[pathNow] || "NAAP Parking";
  const navLinksByRole = {
    admin: [
      { href: "/admin", label: "Dashboard", active: ["/", "/admin"] },
      { href: "/students", label: "Students & Vehicles", active: ["/students", "/vehicles"] },
      { href: "/stickers", label: "Stickers", active: ["/stickers"] },
      { href: "/scanner", label: "Gate Console", active: ["/scanner", "/scanner/auto", "/guard"] },
      { href: "/admin/slots", label: "Available Slots", active: ["/admin/slots"] },
      { href: "/admin/updates", label: "Latest Updates", active: ["/admin/updates"] },
      { href: "/admin/records", label: "Gate Records", active: ["/admin/records"] },
      { href: "/reports", label: "Reports", active: ["/reports"] },
      { href: "/admin/users", label: "Users", active: ["/admin/users"] }
    ],
    guard: [
      { href: "/guard", label: "Dashboard", active: ["/guard"] },
      { href: "/scanner", label: "Gate Console", active: ["/scanner"] },
      { href: "/scanner/auto", label: "Phone Camera", active: ["/scanner/auto"] }
    ]
  };
  const navLinks = navLinksByRole[roleNow] || [];
  const workflowByRole = {
    admin: [
      {
        href: "/admin",
        label: "Dashboard",
        match: ["/", "/admin"],
        hint: "Start by checking live metrics and pending alerts."
      },
      {
        href: "/students",
        label: "Students",
        match: ["/students"],
        hint: "Register or update student and vehicle records."
      },
      {
        href: "/stickers",
        label: "Stickers",
        match: ["/stickers"],
        hint: "Issue active QR stickers linked to vehicles."
      },
      {
        href: "/scanner",
        label: "Gate Check",
        match: ["/scanner", "/scanner/auto", "/guard"],
        hint: "Verify entries and exits, then assign parking."
      },
      {
        href: "/admin/slots",
        label: "Slots",
        match: ["/admin/slots"],
        hint: "Monitor availability and view per-slot activity."
      },
      {
        href: "/admin/updates",
        label: "Updates",
        match: ["/admin/updates"],
        hint: "Track latest gate movements and overstay alerts."
      },
      {
        href: "/admin/records",
        label: "Records",
        match: ["/admin/records"],
        hint: "Review historical logs for reports and audits."
      }
    ],
    guard: [
      {
        href: "/guard",
        label: "Monitor",
        match: ["/guard"],
        hint: "Watch queue health, occupancy, and active alerts."
      },
      {
        href: "/scanner/auto",
        label: "Capture QR",
        match: ["/scanner/auto"],
        hint: "Use phone camera mode to detect QR stickers automatically."
      },
      {
        href: "/scanner",
        label: "Confirm Entry",
        match: ["/scanner"],
        hint: "Review match results, assign slot, and save movement."
      }
    ]
  };
  const workflowSteps = workflowByRole[roleNow] || [];
  const currentWorkflowIndex = workflowSteps.findIndex((step) => Array.isArray(step.match) && step.match.includes(pathNow));
  const currentWorkflowStep = currentWorkflowIndex >= 0 ? workflowSteps[currentWorkflowIndex] : null;
  const nextWorkflowStep =
    currentWorkflowIndex >= 0 && currentWorkflowIndex < workflowSteps.length - 1
      ? workflowSteps[currentWorkflowIndex + 1]
      : null;
  const navIconFallback = '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3"></circle></svg>';
  const navIconByHref = {
    "/admin": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"></path><path d="M5 9.5V21h14V9.5"></path></svg>',
    "/guard": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 5-3.2 8.5-7 10-3.8-1.5-7-5-7-10V6l7-3Z"></path><path d="m9.5 12 1.8 1.8L15 10.3"></path></svg>',
    "/admin/slots": '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="8" height="8" rx="1.5"></rect><rect x="13" y="3" width="8" height="8" rx="1.5"></rect><rect x="3" y="13" width="8" height="8" rx="1.5"></rect><rect x="13" y="13" width="8" height="8" rx="1.5"></rect></svg>',
    "/admin/updates": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a6 6 0 0 0-6 6v3.5L4.8 15a1 1 0 0 0 .8 1.5h12.8a1 1 0 0 0 .8-1.5L18 12.5V9a6 6 0 0 0-6-6Z"></path><path d="M9.5 18a2.5 2.5 0 0 0 5 0"></path></svg>',
    "/admin/records": '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="3" width="16" height="18" rx="2"></rect><path d="M8 8h8"></path><path d="M8 12h8"></path><path d="M8 16h5"></path></svg>',
    "/admin/users": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 19v-1a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v1"></path><circle cx="9.5" cy="7" r="3"></circle><path d="M17 11a3 3 0 1 0 0-6"></path><path d="M21 19v-1.3a4 4 0 0 0-2.8-3.8"></path></svg>',
    "/students": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z"></path><path d="M9 7V5a3 3 0 0 1 6 0v2"></path><circle cx="12" cy="12" r="1.5"></circle></svg>',
    "/stickers": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v5h-2a2 2 0 0 0 0 4h2v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-3h2a2 2 0 0 0 0-4H4V6a2 2 0 0 1 2-2Z"></path><path d="M9 9h6"></path><path d="M9 15h6"></path></svg>',
    "/reports": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 20V9"></path><path d="M12 20V4"></path><path d="M19 20v-7"></path></svg>',
    "/scanner": '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 8V6a2 2 0 0 1 2-2h2"></path><path d="M20 8V6a2 2 0 0 0-2-2h-2"></path><path d="M4 16v2a2 2 0 0 0 2 2h2"></path><path d="M20 16v2a2 2 0 0 1-2 2h-2"></path><path d="M7 12h10"></path></svg>',
    "/scanner/auto": '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="2"></rect><circle cx="12" cy="13" r="3"></circle><path d="M8 6l1.2-2h5.6L16 6"></path></svg>'
  };
%>

  <body class="page-<%= pageSlug %>">
    <div class="app-shell">
      <!-- Top Navigation -->
      <nav class="top-nav">
        <div class="top-nav-upper">
          <div class="brand">
            <h1>NAAP Parking</h1>
          </div>
          <div class="top-nav-actions">
            <button class="icon-btn theme-toggle" id="themeToggle" title="Toggle theme mode" aria-label="Toggle theme mode">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </button>
            <span class="chip chip-live is-online desktop-only" id="networkIndicator">Online</span>
            <span class="role-chip"><%= roleLabel %></span>
            <a href="/logout" class="icon-btn signout-btn" title="Sign out" aria-label="Sign out">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                <path d="M10 17l5-5-5-5"></path>
                <path d="M15 12H3"></path>
              </svg>
            </a>
            <div class="avatar-dot top-nav-avatar"><%= avatarInitial %></div>
          </div>
        </div>

        <div class="top-nav-links">
          <% navLinks.forEach((link) => { %>
            <% const isActive = Array.isArray(link.active) && link.active.includes(pathNow); %>
            <a href="<%= link.href %>" class="<%= isActive ? 'active' : '' %>">
              <span class="nav-link-icon" aria-hidden="true"><%- navIconByHref[link.href] || navIconFallback %></span>
              <span><%= link.label %></span>
            </a>
          <% }) %>
        </div>
      </nav>

      <% if (workflowSteps.length) { %>
      <section class="workflow-rail" aria-label="Workflow guide">
        <div class="workflow-rail-head">
          <div>
            <p class="workflow-rail-kicker"><%= roleLabel %> Flow</p>
            <p class="workflow-rail-sub">
              <%= currentWorkflowStep
                ? currentWorkflowStep.hint
                : "Support page. Use the workflow steps to jump back to operations." %>
            </p>
          </div>
          <% if (nextWorkflowStep) { %>
            <a href="<%= nextWorkflowStep.href %>" class="workflow-next-link">Next: <%= nextWorkflowStep.label %></a>
          <% } else if (currentWorkflowStep) { %>
            <span class="workflow-next-done">Final step</span>
          <% } else { %>
            <span class="workflow-next-done">Support page</span>
          <% } %>
        </div>
        <div class="workflow-rail-steps">
          <% workflowSteps.forEach((step, index) => { %>
            <% const state = currentWorkflowIndex >= 0
              ? (index < currentWorkflowIndex ? "done" : index === currentWorkflowIndex ? "current" : "upcoming")
              : "upcoming"; %>
            <a href="<%= step.href %>" class="workflow-rail-step is-<%= state %>">
              <span class="workflow-rail-index"><%= index + 1 %></span>
              <span class="workflow-rail-label"><%= step.label %></span>
            </a>
          <% }) %>
        </div>
      </section>
      <% } %>

      <div class="main-shell">

        <main class="container">

          <script>
            // Theme Toggle Logic
            window.addEventListener('DOMContentLoaded', () => {
              const toggleBtn = document.getElementById('themeToggle');
              const mobileToggleBtn = document.getElementById('mobileThemeToggle');
              const moonIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>';
              const sunIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="M6.34 17.66l-1.41 1.41"></path><path d="M19.07 4.93l-1.41 1.41"></path></svg>';

              const setThemeIcon = (theme) => {
                const isDark = theme === 'dark';
                const icon = isDark ? sunIcon : moonIcon;
                const label = isDark ? 'Switch to light mode' : 'Switch to dark mode';
                [toggleBtn, mobileToggleBtn].forEach(btn => {
                  if (!btn) return;
                  btn.innerHTML = icon;
                  btn.title = label;
                  btn.setAttribute('aria-label', label);
                });
              };

              const handleToggle = () => {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                setThemeIcon(newTheme);

                [toggleBtn, mobileToggleBtn].forEach(btn => {
                  if (btn) btn.blur();
                });
              };
              setThemeIcon(document.documentElement.getAttribute('data-theme') || 'light');

              if (toggleBtn) toggleBtn.addEventListener('click', handleToggle);
              if (mobileToggleBtn) mobileToggleBtn.addEventListener('click', handleToggle);
            });
          </script>
