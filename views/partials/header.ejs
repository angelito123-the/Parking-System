<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f2942">
  <title>NAAP Parking System</title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="manifest" href="/manifest.json" />
  <script src="/offline-sync.js"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(() => console.log('Service Worker registered'))
          .catch((err) => console.error('SW registration failed:', err));
      });
    }

    window.addEventListener('load', () => {
      if (window.OfflineManager) {
        OfflineManager.init((isOnline) => {
          const badge = document.getElementById('networkIndicator');
          const mobileBadge = document.getElementById('mobileNetworkIndicator');
          [badge, mobileBadge].forEach(el => {
            if (el) {
              el.textContent = isOnline ? '🟢 Online' : '🔴 Offline';
              if (!isOnline) {
                el.style.background = '#fef2f2';
                el.style.color = '#991b1b';
                el.style.borderColor = '#fecaca';
              } else {
                el.style.background = '';
                el.style.color = '';
                el.style.borderColor = '';
              }
            }
          });
        });
      }
    });
  </script>
  <!-- Dark Mode Init (Prevent FOUC) -->
  <script>
    (function() {
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<% const pathNow=typeof currentPath==="string" ? currentPath : "" ; const pageSlug=(pathNow==="/" ? "dashboard" :
  pathNow.replace(/\//g, "-" ).replace(/^-+/, "" )) || "dashboard" ; const pageTitleMap={ "/" : "Dashboard"
  , "/students" : "Students" , "/vehicles" : "Vehicles" , "/stickers" : "Stickers" , "/reports" : "Reports" , "/scanner"
  : "Gate Console" }; const pageTitle=pageTitleMap[pathNow] || "Verification" ; %>

  <body class="page-<%= pageSlug %>">
    <div class="app-shell">
      <aside class="sidebar">
        <div class="sidebar-user">
          <div class="avatar-dot">N</div>
          <div>
            <p class="user-label">NAAP Guard</p>
            <p class="user-sub">Access Control</p>
          </div>
        </div>
        <p class="menu-title">Navigation</p>
        <nav class="side-nav">
          <a href="/" class="<%= pathNow === '/' ? 'active' : '' %>">Dashboard</a>
          <a href="/students" class="<%= pathNow === '/students' ? 'active' : '' %>">Students</a>
          <a href="/vehicles" class="<%= pathNow === '/vehicles' ? 'active' : '' %>">Vehicles</a>
          <a href="/stickers" class="<%= pathNow === '/stickers' ? 'active' : '' %>">Stickers</a>
          <a href="/reports" class="<%= pathNow === '/reports' ? 'active' : '' %>">Reports</a>
          <a href="/scanner" class="<%= pathNow === '/scanner' ? 'active' : '' %>">Gate Console</a>
        </nav>
        <div style="margin-top: auto; padding-top: 1.25rem; border-top: 1px solid var(--line); margin-top: 1.25rem;">
          <a href="/logout"
            style="display:flex; align-items:center; gap:0.5rem; text-decoration:none; color: var(--muted); font-size:0.82rem; font-weight:600; padding:0.5rem 0.5rem; border-radius:4px; transition: background 0.15s;"
            onmouseover="this.style.background='#fee2e2'; this.style.color='#991b1b'"
            onmouseout="this.style.background='transparent'; this.style.color='var(--muted)'">
            <span>⎋</span> Sign Out
          </a>
        </div>
      </aside>
      <div class="main-shell">
        <!-- Desktop Topbar -->
        <header class="topbar desktop-only">
          <div class="brand">
            <p class="brand-kicker">National Aviation Academy of the Philippines</p>
            <h1>Parking Management System</h1>
            <p class="brand-sub">Student vehicle control, QR sticker issuance, and gate verification.</p>
          </div>
          <div class="topbar-meta">
            <p class="meta-title">Current Module</p>
            <h2 class="page-title">
              <%= pageTitle %>
            </h2>
            <div class="topbar-chips">
              <button class="theme-toggle" id="themeToggle" title="Toggle Dark/Light Mode" style="margin-right: 0.5rem;">🌓</button>
              <span class="chip chip-live" id="networkIndicator">🟢 Online</span>
              <span class="chip" id="liveClock">--:--:--</span>
            </div>
          </div>
        </header>

        <!-- Mobile Topbar -->
        <header class="mobile-topbar mobile-only">
          <div class="mobile-topbar-left">
            <div class="mobile-avatar">N</div>
            <div>
              <p class="mobile-topbar-title">NAAP Parking</p>
              <p class="mobile-topbar-sub">
                <%= pageTitle %>
              </p>
            </div>
          </div>
          <div style="display:flex; align-items:center; gap:0.5rem;">
            <button class="theme-toggle" id="mobileThemeToggle" title="Toggle Dark/Light Mode" style="width: 28px; height: 28px; font-size: 0.85rem;">🌓</button>
            <span class="chip chip-live" id="mobileNetworkIndicator" style="font-size:0.7rem;">🟢 Online</span>
            <span class="chip" id="liveClock" style="font-size:0.7rem;">--:--:--</span>
          </div>
        </header>

        <main class="container">
        
        <script>
          // Theme Toggle Logic
          window.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('themeToggle');
            const mobileToggleBtn = document.getElementById('mobileThemeToggle');
            
            const handleToggle = () => {
              const currentTheme = document.documentElement.getAttribute('data-theme');
              const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
              document.documentElement.setAttribute('data-theme', newTheme);
              localStorage.setItem('theme', newTheme);
              
              // Update button icons if needed
              [toggleBtn, mobileToggleBtn].forEach(btn => {
                if(btn) btn.blur();
              });
            };

            if (toggleBtn) toggleBtn.addEventListener('click', handleToggle);
            if (mobileToggleBtn) mobileToggleBtn.addEventListener('click', handleToggle);
          });
        </script>