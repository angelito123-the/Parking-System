<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f2942">
  <title>NAAP Parking System</title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="manifest" href="/manifest.json" />
  <script src="/offline-sync.js"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(() => console.log('Service Worker registered'))
          .catch((err) => console.error('SW registration failed:', err));
      });
    }

    window.addEventListener('load', () => {
      if (window.OfflineManager) {
        OfflineManager.init((isOnline) => {
          const badge = document.getElementById('networkIndicator');
          const mobileBadge = document.getElementById('mobileNetworkIndicator');
          [badge, mobileBadge].forEach(el => {
            if (el) {
              el.textContent = isOnline ? 'Online' : 'Offline';
              el.classList.toggle('is-online', isOnline);
              el.classList.toggle('is-offline', !isOnline);
            }
          });
        });
      }
    });
  </script>
  <!-- Dark Mode Init (Prevent FOUC) -->
  <script>
    (function () {
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<%
  const pathNow = typeof currentPath === "string" ? currentPath : "";
  const safeUser = typeof currentUser === "object" && currentUser ? currentUser : null;
  const roleNow = String(safeUser?.role || "").toLowerCase();
  const usernameNow = String(safeUser?.username || "User");
  const avatarInitial = usernameNow ? usernameNow.charAt(0).toUpperCase() : "U";
  const roleLabelMap = {
    admin: "Admin",
    guard: "Guard"
  };
  const roleLabel = roleLabelMap[roleNow] || "User";
  const pageSlug = (pathNow === "/" ? "dashboard" : pathNow.replace(/\//g, "-").replace(/^-+/, "")) || "dashboard";
  const pageTitleMap = {
    "/": "Dashboard",
    "/admin": "Admin Dashboard",
    "/guard": "Guard Dashboard",
    "/admin/users": "User Management",
    "/students": "Students & Vehicles",
    "/stickers": "Stickers",
    "/reports": "Reports",
    "/scanner": "Gate Console",
    "/scanner/auto": "Automatic Gate Camera"
  };
  const pageTitle = pageTitleMap[pathNow] || "NAAP Parking";
  const navLinksByRole = {
    admin: [
      { href: "/admin", label: "Dashboard", active: ["/", "/admin"] },
      { href: "/admin/users", label: "Users", active: ["/admin/users"] },
      { href: "/students", label: "Students & Vehicles", active: ["/students", "/vehicles"] },
      { href: "/stickers", label: "Stickers", active: ["/stickers"] },
      { href: "/reports", label: "Reports", active: ["/reports"] },
      { href: "/scanner", label: "Gate Console", active: ["/scanner", "/scanner/auto", "/guard"] }
    ],
    guard: [
      { href: "/guard", label: "Dashboard", active: ["/guard"] },
      { href: "/scanner", label: "Gate Console", active: ["/scanner", "/scanner/auto"] }
    ]
  };
  const navLinks = navLinksByRole[roleNow] || [];
%>

  <body class="page-<%= pageSlug %>">
    <div class="app-shell">
      <!-- Top Navigation -->
      <nav class="top-nav">
        <div class="top-nav-upper">
          <div class="brand">
            <h1>NAAP Parking</h1>
          </div>
          <div class="top-nav-actions">
            <button class="icon-btn theme-toggle" id="themeToggle" title="Toggle theme mode" aria-label="Toggle theme mode">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </button>
            <span class="chip chip-live is-online desktop-only" id="networkIndicator">Online</span>
            <span class="role-chip"><%= roleLabel %></span>
            <a href="/logout" class="icon-btn signout-btn" title="Sign out" aria-label="Sign out">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                <path d="M10 17l5-5-5-5"></path>
                <path d="M15 12H3"></path>
              </svg>
            </a>
            <div class="avatar-dot top-nav-avatar"><%= avatarInitial %></div>
          </div>
        </div>

        <div class="top-nav-links">
          <% navLinks.forEach((link) => { %>
            <% const isActive = Array.isArray(link.active) && link.active.includes(pathNow); %>
            <a href="<%= link.href %>" class="<%= isActive ? 'active' : '' %>"><%= link.label %></a>
          <% }) %>
        </div>
      </nav>

      <div class="main-shell">

        <main class="container">

          <script>
            // Theme Toggle Logic
            window.addEventListener('DOMContentLoaded', () => {
              const toggleBtn = document.getElementById('themeToggle');
              const mobileToggleBtn = document.getElementById('mobileThemeToggle');
              const moonIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>';
              const sunIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="M6.34 17.66l-1.41 1.41"></path><path d="M19.07 4.93l-1.41 1.41"></path></svg>';

              const setThemeIcon = (theme) => {
                const isDark = theme === 'dark';
                const icon = isDark ? sunIcon : moonIcon;
                const label = isDark ? 'Switch to light mode' : 'Switch to dark mode';
                [toggleBtn, mobileToggleBtn].forEach(btn => {
                  if (!btn) return;
                  btn.innerHTML = icon;
                  btn.title = label;
                  btn.setAttribute('aria-label', label);
                });
              };

              const handleToggle = () => {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                setThemeIcon(newTheme);

                [toggleBtn, mobileToggleBtn].forEach(btn => {
                  if (btn) btn.blur();
                });
              };
              setThemeIcon(document.documentElement.getAttribute('data-theme') || 'light');

              if (toggleBtn) toggleBtn.addEventListener('click', handleToggle);
              if (mobileToggleBtn) mobileToggleBtn.addEventListener('click', handleToggle);
            });
          </script>
