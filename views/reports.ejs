<%- include("partials/header") %>
  <% const rowsSafe=Array.isArray(rows) ? rows : []; const gateStatsSafe=Array.isArray(gateStats) ? gateStats : [];
    const studentStatsSafe=Array.isArray(studentStats) ? studentStats : []; const hourStatsSafe=Array.isArray(hourStats)
    ? hourStats : []; %>

    <section class="dashboard-hero">
      <div class="hero-greeting">
        <h2>Analytics</h2>
        <h1>System Reports</h1>
      </div>
      <div class="hero-cards">
        <div class="hero-card">
          <h3>Total Scans</h3>
          <p><%= summary.totalScans %></p>
        </div>
        <div class="hero-card">
          <h3>Valid Scans</h3>
          <p><%= summary.validScans %></p>
        </div>
        <div class="hero-card">
          <h3>Total Entries</h3>
          <p><%= summary.totalEntries %></p>
        </div>
        <div class="hero-card">
          <h3>Total Exits</h3>
          <p><%= summary.totalExits %></p>
        </div>
        <div class="hero-card" style="background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.4);">
          <h3>Unique Students</h3>
          <p><%= summary.uniqueStudents %></p>
        </div>
      </div>
    </section>

    <div class="overlap-wrapper" style="display: grid; gap: 3rem;">
      <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Data Filters & Export</h2>
          <p>Filter scan history and review operational metrics.</p>
        </div>
        <form method="get" action="/reports" class="filters-grid">
          <div>
            <label>From</label>
            <input type="date" name="from" value="<%= filters.from %>" style="border: 1px solid var(--line);" />
          </div>
          <div>
            <label>To</label>
            <input type="date" name="to" value="<%= filters.to %>" style="border: 1px solid var(--line);" />
          </div>
          <div>
            <label>Gate</label>
            <select name="gate" style="border: 1px solid var(--line);">
              <option value="ALL" <%=filters.gate==="ALL" ? "selected" : "" %>>All Gates</option>
              <% gateStatsSafe.forEach(item=> { %>
                <% const gateName=item.gate || "Unspecified" ; %>
                  <option value="<%= gateName %>" <%=filters.gate===gateName ? "selected" : "" %>><%= gateName %></option>
              <% }) %>
            </select>
          </div>
          <div class="filters-actions">
            <button type="submit" style="background: var(--blue-mid); color: #fff;">Apply Filters</button>
            <a class="link-btn"
              href="/reports?from=<%= filters.from %>&to=<%= filters.to %>&gate=<%= filters.gate %>&format=csv">
              ⬇ Export CSV
            </a>
          </div>
        </form>
      </section>

      <section class="dashboard-grid">
        <article class="panel">
          <div class="section-head">
            <h2>Top Students</h2>
            <p>Most frequently scanned students.</p>
          </div>
          <% if (studentStatsSafe.length===0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">📊</div>
              <p>No scan data found.</p>
            </div>
            <% } else { %>
              <div class="table-wrap desktop-only-table">
                <table>
                  <thead>
                    <tr>
                      <th>Student Number</th>
                      <th>Name</th>
                      <th>Total Scans</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% studentStatsSafe.forEach(item=> { %>
                      <tr>
                        <td><strong><%= item.student_number %></strong></td>
                        <td><%= item.full_name %></td>
                        <td><strong><%= item.total_scans %></strong></td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <!-- Mobile Cards for Top Students -->
              <div class="mobile-data-list">
                <% studentStatsSafe.forEach(item => { %>
                  <div class="mobile-data-card">
                    <div class="card-header">
                      <div class="card-title"><%= item.full_name %></div>
                      <span class="badge" style="background:var(--blue-soft); color:var(--blue-mid);"><%= item.total_scans %> Scans</span>
                    </div>
                    <div class="card-body">
                      <div class="card-item">🆔 <strong>ID:</strong> <%= item.student_number %></div>
                    </div>
                  </div>
                <% }) %>
              </div>
              <% } %>
        </article>

        <article class="panel">
          <div class="section-head">
            <h2>Gate and Hour Trends</h2>
            <p>Traffic distribution snapshots.</p>
          </div>
          <div class="mini-list">
            <h4>By Gate</h4>
            <% if (gateStatsSafe.length===0) { %>
              <div class="empty-state"><p>No gate data.</p></div>
              <% } else { %>
                <% gateStatsSafe.forEach(item=> { %>
                  <div class="mini-row">
                    <span><%= item.gate || "Unspecified" %></span>
                    <strong><%= item.total %></strong>
                  </div>
                  <% }) %>
              <% } %>
          </div>
          <div class="mini-list" style="margin-top:1.5rem;">
            <h4>By Hour</h4>
            <% if (hourStatsSafe.length===0) { %>
              <div class="empty-state"><p>No hourly data.</p></div>
              <% } else { %>
                <% hourStatsSafe.forEach(item=> { %>
                  <div class="mini-row">
                    <span><%= item.hour_slot %></span>
                    <strong><%= item.total %></strong>
                  </div>
                  <% }) %>
              <% } %>
          </div>
        </article>
      </section>

      <section class="panel" style="border:none; box-shadow:none; padding:0; background:transparent;">
        <div class="section-head">
          <h2 style="font-size: 1.25rem;">Detailed Scan Records</h2>
          <p>Total: <strong><%= rowsSafe.length %></strong> records.</p>
        </div>
        <% if (rowsSafe.length===0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <p>No scan records found.</p>
          </div>
          <% } else { %>
            <div class="table-wrap desktop-only-table">
              <table>
                <thead>
                  <tr>
                    <th>Date/Time</th>
                    <th>Student</th>
                    <th>Plate</th>
                    <th>Sticker</th>
                    <th>Result</th>
                    <th>Movement</th>
                    <th>Gate</th>
                  </tr>
                </thead>
                <tbody>
                  <% rowsSafe.forEach(row=> { %>
                    <tr>
                      <td style="color: var(--muted); font-size:0.8rem;"><%= new Date(row.scanned_at).toLocaleString('en-US', { hour:'numeric', minute:'numeric', month:'short', day:'numeric' }) %></td>
                      <td><strong><%= row.student_number || "-" %></strong><br><small><%= row.full_name || "" %></small></td>
                      <td><span class="badge" style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1;"><%= row.plate_number || "-" %></span></td>
                      <td><%= row.sticker_code || "-" %></td>
                      <td><span class="badge badge-<%= (row.result || " INVALID").toLowerCase() %>"><%= row.result || "-" %></span></td>
                      <td><span class="badge badge-action"><%= row.action || "-" %></span></td>
                      <td><%= row.gate || "-" %></td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>

            <!-- Mobile-Ready Cards for Detailed Records -->
            <div class="mobile-data-list">
              <% rowsSafe.forEach(row => { %>
                <div class="mobile-data-card">
                  <div class="card-header">
                    <div class="card-title"><%= row.full_name || "Guest" %></div>
                    <span class="badge badge-action"><%= row.action %></span>
                  </div>
                  <div class="card-body">
                    <div class="card-item">🚗 <strong>Plate:</strong> <%= row.plate_number || "-" %></div>
                    <div class="card-item">🛡️ <strong>Status:</strong> <span class="badge badge-<%= (row.result || 'INVALID').toLowerCase() %>"><%= row.result %></span></div>
                    <div class="card-item">📅 <strong>Time:</strong> <%= new Date(row.scanned_at).toLocaleTimeString() %></div>
                  </div>
                </div>
              <% }) %>
            </div>
            <% } %>
      </section>
    </div> <!-- overlap-wrapper end -->

    <%- include("partials/footer") %>