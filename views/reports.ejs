<%- include("partials/header") %>
<%
  const rowsSafe = Array.isArray(rows) ? rows : [];
  const gateStatsSafe = Array.isArray(gateStats) ? gateStats : [];
  const studentStatsSafe = Array.isArray(studentStats) ? studentStats : [];
  const hourStatsSafe = Array.isArray(hourStats) ? hourStats : [];
%>

<section class="panel">
  <div class="section-head">
    <h2>Analytics and Reports</h2>
    <p>Filter scan history, review operational metrics, and export CSV for thesis documentation.</p>
  </div>
  <form method="get" action="/reports" class="filters-grid">
    <div>
      <label>From</label>
      <input type="date" name="from" value="<%= filters.from %>" />
    </div>
    <div>
      <label>To</label>
      <input type="date" name="to" value="<%= filters.to %>" />
    </div>
    <div>
      <label>Gate</label>
      <select name="gate">
        <option value="ALL" <%= filters.gate === "ALL" ? "selected" : "" %>>All Gates</option>
        <% gateStatsSafe.forEach(item => { %>
          <% const gateName = item.gate || "Unspecified"; %>
          <option value="<%= gateName %>" <%= filters.gate === gateName ? "selected" : "" %>><%= gateName %></option>
        <% }) %>
      </select>
    </div>
    <div class="filters-actions">
      <button type="submit">Apply Filters</button>
      <a
        class="link-btn"
        href="/reports?from=<%= filters.from %>&to=<%= filters.to %>&gate=<%= filters.gate %>&format=csv"
      >
        Export CSV
      </a>
    </div>
  </form>
</section>

<section class="cards">
  <article class="card"><h3>Total Scans</h3><p><%= summary.totalScans %></p></article>
  <article class="card"><h3>Valid Scans</h3><p><%= summary.validScans %></p></article>
  <article class="card"><h3>Total Entry</h3><p><%= summary.totalEntries %></p></article>
  <article class="card"><h3>Total Exit</h3><p><%= summary.totalExits %></p></article>
  <article class="card"><h3>Unique Students</h3><p><%= summary.uniqueStudents %></p></article>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <div class="section-head">
      <h2>Top Students by Scans</h2>
      <p>Most frequently scanned students in selected period.</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Student Number</th><th>Name</th><th>Total Scans</th></tr>
        </thead>
        <tbody>
          <% if (studentStatsSafe.length === 0) { %>
            <tr><td colspan="3">No data.</td></tr>
          <% } %>
          <% studentStatsSafe.forEach(item => { %>
            <tr>
              <td><%= item.student_number %></td>
              <td><%= item.full_name %></td>
              <td><%= item.total_scans %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="section-head">
      <h2>Gate and Hour Trends</h2>
      <p>Traffic distribution by gate and time.</p>
    </div>
    <div class="mini-list">
      <h4>By Gate</h4>
      <% if (gateStatsSafe.length === 0) { %><p class="helper-text">No gate data.</p><% } %>
      <% gateStatsSafe.forEach(item => { %>
        <div class="mini-row">
          <span><%= item.gate || "Unspecified" %></span>
          <strong><%= item.total %></strong>
        </div>
      <% }) %>
    </div>
    <div class="mini-list">
      <h4>By Hour</h4>
      <% if (hourStatsSafe.length === 0) { %><p class="helper-text">No hour data.</p><% } %>
      <% hourStatsSafe.forEach(item => { %>
        <div class="mini-row">
          <span><%= item.hour_slot %></span>
          <strong><%= item.total %></strong>
        </div>
      <% }) %>
    </div>
  </article>
</section>

<section class="panel">
  <div class="section-head">
    <h2>Detailed Scan Records</h2>
    <p>Complete scan logs for the selected range.</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Date/Time</th>
          <th>Student Number</th>
          <th>Name</th>
          <th>Plate</th>
          <th>Sticker</th>
          <th>Result</th>
          <th>Action</th>
          <th>Gate</th>
        </tr>
      </thead>
      <tbody>
        <% if (rowsSafe.length === 0) { %>
          <tr><td colspan="8">No records for selected filter.</td></tr>
        <% } %>
        <% rowsSafe.forEach(row => { %>
          <tr>
            <td><%= new Date(row.scanned_at).toLocaleString() %></td>
            <td><%= row.student_number || "-" %></td>
            <td><%= row.full_name || "-" %></td>
            <td><%= row.plate_number || "-" %></td>
            <td><%= row.sticker_code || "-" %></td>
            <td><span class="badge badge-<%= (row.result || "INVALID").toLowerCase() %>"><%= row.result || "-" %></span></td>
            <td><span class="badge badge-action"><%= row.action || "-" %></span></td>
            <td><%= row.gate || "-" %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("partials/footer") %>
