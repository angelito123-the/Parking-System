<%- include("partials/header") %>
<%
  const safeParkingSlots = Array.isArray(parkingSlots) ? parkingSlots : [];
  const safeParkingSlotSummary = typeof parkingSlotSummary === "object" && parkingSlotSummary
    ? parkingSlotSummary
    : {
      total: safeParkingSlots.length,
      available: safeParkingSlots.filter((slot) => slot.occupancy === "available").length,
      occupied: safeParkingSlots.filter((slot) => slot.occupancy === "occupied").length,
      disabled: safeParkingSlots.filter((slot) => slot.occupancy === "disabled").length
    };
  const initialSelectedSlot = safeParkingSlots.find((slot) => slot.occupancy === "available") || safeParkingSlots[0] || null;
  const initialSelectedSlotCode = initialSelectedSlot?.slot_code ? String(initialSelectedSlot.slot_code) : "";
%>

<section class="dashboard-hero">
  <div class="hero-greeting">
    <h2>Access Control</h2>
    <h1>Available Slots</h1>
  </div>
  <div class="hero-cards">
    <div class="hero-card">
      <h3>Total Slots</h3>
      <p id="slotMetricTotal"><%= safeParkingSlotSummary.total %></p>
    </div>
    <div class="hero-card" style="background: rgba(34, 197, 94, 0.22); border-color: rgba(134, 239, 172, 0.45);">
      <h3>Available</h3>
      <p id="slotMetricAvailable"><%= safeParkingSlotSummary.available %></p>
    </div>
    <div class="hero-card" style="background: rgba(245, 158, 11, 0.22); border-color: rgba(252, 211, 77, 0.45);">
      <h3>Occupied</h3>
      <p id="slotMetricOccupied"><%= safeParkingSlotSummary.occupied %></p>
    </div>
    <div class="hero-card" style="background: rgba(71, 85, 105, 0.22); border-color: rgba(148, 163, 184, 0.45);">
      <h3>Disabled</h3>
      <p id="slotMetricDisabled"><%= safeParkingSlotSummary.disabled %></p>
    </div>
  </div>
</section>

<div class="overlap-wrapper" style="display:grid; gap:1.25rem;">
  <section class="panel">
    <div class="section-head">
      <h2>Parking Slot Monitoring</h2>
      <p>See which vehicle is parked in each occupied slot. Click any slot to review history.</p>
    </div>
    <div class="refresh-row" style="margin-bottom:0.8rem;">
      <span id="slotsLastUpdated" class="helper-text">Last updated: --</span>
      <button type="button" id="slotsRefreshBtn" class="refresh-btn btn-sm">Refresh</button>
    </div>

    <div class="parking-slots-toolbar">
      <div class="parking-slots-toolbar-left">
        <span id="parkingSlotsMeta" class="helper-text">
          <%= safeParkingSlotSummary.available %> available | <%= safeParkingSlotSummary.occupied %> occupied | <%= safeParkingSlotSummary.disabled %> disabled | <%= safeParkingSlotSummary.total %> total
        </span>
        <label for="parkingSlotSearch" class="sr-only">Find parking slot</label>
        <input
          type="search"
          id="parkingSlotSearch"
          class="slot-search-input"
          placeholder="Find slot code, zone, plate, or student..." />
      </div>
      <div class="slot-filter-group" role="group" aria-label="Parking slot status filter">
        <button type="button" class="slot-filter-btn is-active" data-slot-filter="all">All (<%= safeParkingSlotSummary.total %>)</button>
        <button type="button" class="slot-filter-btn" data-slot-filter="available">Available (<%= safeParkingSlotSummary.available %>)</button>
        <button type="button" class="slot-filter-btn" data-slot-filter="occupied">Occupied (<%= safeParkingSlotSummary.occupied %>)</button>
        <button type="button" class="slot-filter-btn" data-slot-filter="disabled">Disabled (<%= safeParkingSlotSummary.disabled %>)</button>
      </div>
    </div>

    <div id="availableSlotsStrip" class="available-slots-strip">
      <% const initialAvailableSlots = safeParkingSlots.filter((slot) => slot.occupancy === "available"); %>
      <% if (!initialAvailableSlots.length) { %>
        <span class="available-slots-empty">No available slots right now.</span>
      <% } else { %>
        <span class="available-slots-label">Available now:</span>
        <% initialAvailableSlots.slice(0, 18).forEach((slot) => { %>
          <button type="button" class="available-slot-pill" data-slot-pill="<%= slot.slot_code || '' %>"><%= slot.slot_code || "-" %></button>
        <% }) %>
        <% if (initialAvailableSlots.length > 18) { %>
          <span class="available-slots-more">+<%= initialAvailableSlots.length - 18 %> more</span>
        <% } %>
      <% } %>
    </div>

    <div class="parking-space-layout">
      <div class="parking-space-map-shell">
        <div id="parkingSlotsList" class="parking-space-map">
          <% if (!safeParkingSlots.length) { %>
            <div class="empty-state" style="padding:1.25rem 1rem;">
              <p>No parking slots configured.</p>
            </div>
          <% } %>
        </div>
      </div>

      <aside class="parking-space-panel">
        <div class="parking-space-panel-head">
          <div>
            <p class="parking-space-panel-label">Selected Parking Space</p>
            <h3 id="slotInspectorTitle"><%= initialSelectedSlotCode || "Not selected" %></h3>
          </div>
          <span id="slotInspectorStatus" class="parking-inspector-badge">--</span>
        </div>
        <p id="slotInspectorSubtitle" class="helper-text" style="margin-bottom:0.7rem;">
          Select a slot to review assignment details and recent parking activity.
        </p>
        <div id="slotInspectorDetails" class="parking-inspector-details"></div>

        <div class="parking-inspector-history-head">
          <strong>Recent Activity</strong>
          <button type="button" id="openSlotHistoryBtn" class="btn-sm">Open Full History</button>
        </div>
        <div id="slotInspectorHistory" class="parking-inspector-history-list">
          <div class="empty-state" style="padding:0.8rem;">
            <p>Select a slot to load recent history.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>
</div>

<div id="slotHistoryModal" class="slot-history-modal" aria-hidden="true">
  <div class="slot-history-backdrop" data-close-slot-history></div>
  <div class="slot-history-dialog" role="dialog" aria-modal="true" aria-labelledby="slotHistoryTitle">
    <div class="slot-history-head">
      <h3 id="slotHistoryTitle">Slot History</h3>
      <button type="button" class="slot-history-close" data-close-slot-history aria-label="Close slot history">x</button>
    </div>
    <p id="slotHistoryMeta" class="helper-text" style="margin:0 0 0.75rem;">Loading slot history...</p>
    <div id="slotHistoryList" class="slot-history-list">
      <div class="empty-state" style="padding:1rem;"><p>Loading slot history...</p></div>
    </div>
  </div>
</div>

<script>
  (() => {
    const slotMetricTotal = document.getElementById("slotMetricTotal");
    const slotMetricAvailable = document.getElementById("slotMetricAvailable");
    const slotMetricOccupied = document.getElementById("slotMetricOccupied");
    const slotMetricDisabled = document.getElementById("slotMetricDisabled");
    const lastUpdatedEl = document.getElementById("slotsLastUpdated");
    const refreshBtn = document.getElementById("slotsRefreshBtn");
    const parkingSlotsMetaEl = document.getElementById("parkingSlotsMeta");
    const parkingSlotsListEl = document.getElementById("parkingSlotsList");
    const parkingSlotSearchEl = document.getElementById("parkingSlotSearch");
    const availableSlotsStripEl = document.getElementById("availableSlotsStrip");
    const slotFilterButtons = Array.from(document.querySelectorAll(".slot-filter-btn[data-slot-filter]"));
    const slotInspectorTitleEl = document.getElementById("slotInspectorTitle");
    const slotInspectorStatusEl = document.getElementById("slotInspectorStatus");
    const slotInspectorSubtitleEl = document.getElementById("slotInspectorSubtitle");
    const slotInspectorDetailsEl = document.getElementById("slotInspectorDetails");
    const slotInspectorHistoryEl = document.getElementById("slotInspectorHistory");
    const openSlotHistoryBtnEl = document.getElementById("openSlotHistoryBtn");
    const slotHistoryModal = document.getElementById("slotHistoryModal");
    const slotHistoryTitle = document.getElementById("slotHistoryTitle");
    const slotHistoryMeta = document.getElementById("slotHistoryMeta");
    const slotHistoryList = document.getElementById("slotHistoryList");

    const initialParkingSlots = <%- JSON.stringify(safeParkingSlots) %>;
    const initialParkingSlotSummary = <%- JSON.stringify(safeParkingSlotSummary) %>;
    let activeSlotFilter = "all";
    let slotSearchQuery = "";
    let latestParkingSlots = Array.isArray(initialParkingSlots) ? initialParkingSlots : [];
    let latestParkingSlotSummary = (initialParkingSlotSummary && typeof initialParkingSlotSummary === "object")
      ? initialParkingSlotSummary
      : { total: latestParkingSlots.length, available: 0, occupied: 0, disabled: 0 };
    let selectedSlotCode = String(<%- JSON.stringify(initialSelectedSlotCode) %> || "").trim().toUpperCase();
    let selectedSlotHistoryRows = [];
    let slotInspectorLoading = false;
    let slotInspectorError = "";
    let slotHistoryRequestId = 0;
    const slotHistoryCache = new Map();

    if (slotHistoryModal && slotHistoryModal.parentElement !== document.body) {
      document.body.appendChild(slotHistoryModal);
    }

    function toPht(value) {
      return new Date(value).toLocaleString("en-US", { timeZone: "Asia/Manila" });
    }

    function normalizeSlotCode(value) {
      return String(value || "").trim().toUpperCase();
    }

    function computeParkingSlotSummary(slots) {
      const source = Array.isArray(slots) ? slots : [];
      const summary = { total: source.length, available: 0, occupied: 0, disabled: 0 };
      source.forEach((slot) => {
        const occupancy = slot?.occupancy || "available";
        if (occupancy === "available") summary.available += 1;
        else if (occupancy === "occupied") summary.occupied += 1;
        else summary.disabled += 1;
      });
      return summary;
    }

    function normalizeParkingSlotSummary(summary, slots) {
      const fallback = computeParkingSlotSummary(slots);
      return {
        total: Number.isFinite(Number(summary?.total)) ? Number(summary.total) : fallback.total,
        available: Number.isFinite(Number(summary?.available)) ? Number(summary.available) : fallback.available,
        occupied: Number.isFinite(Number(summary?.occupied)) ? Number(summary.occupied) : fallback.occupied,
        disabled: Number.isFinite(Number(summary?.disabled)) ? Number(summary.disabled) : fallback.disabled
      };
    }

    function getSelectedSlot() {
      const code = normalizeSlotCode(selectedSlotCode);
      if (!code) return null;
      return latestParkingSlots.find((slot) => normalizeSlotCode(slot.slot_code) === code) || null;
    }

    function renderParkingSlotCard(slot) {
      const occupancy = slot.occupancy || "available";
      const code = slot.slot_code || "-";
      const isSelected = normalizeSlotCode(code) === normalizeSlotCode(selectedSlotCode);
      const tileMeta = occupancy === "occupied"
        ? (slot.occupied_by_plate || "Occupied")
        : occupancy === "available"
          ? "Available"
          : "Unavailable";

      return `<button
        type="button"
        class="parking-slot-tile ${occupancy} ${isSelected ? "selected" : ""}"
        data-slot-code="${code}"
        aria-pressed="${isSelected ? "true" : "false"}"
        aria-label="Parking slot ${code} ${occupancy}">
        <span class="tile-code">${code}</span>
        <span class="tile-meta">${tileMeta}</span>
      </button>`;
    }

    function renderEmptyParkingSlots(message = "No parking slots configured.") {
      return `<div class="empty-state" style="padding:1.25rem 1rem;"><p>${message}</p></div>`;
    }

    function getSlotFilterCount(filterKey, summary) {
      if (filterKey === "available") return summary.available || 0;
      if (filterKey === "occupied") return summary.occupied || 0;
      if (filterKey === "disabled") return summary.disabled || 0;
      return summary.total || 0;
    }

    function updateSlotFilterButtons(summary) {
      if (!slotFilterButtons.length) return;
      const labels = { all: "All", available: "Available", occupied: "Occupied", disabled: "Disabled" };
      slotFilterButtons.forEach((button) => {
        const key = button.dataset.slotFilter || "all";
        const count = getSlotFilterCount(key, summary);
        button.textContent = `${labels[key] || "All"} (${count})`;
        const isActive = key === activeSlotFilter;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
    }

    function renderAvailableSlotsStrip(slots, summary) {
      if (!availableSlotsStripEl) return;
      const availableSlots = (slots || [])
        .filter((slot) => (slot.occupancy || "available") === "available")
        .sort((a, b) => String(a.slot_code || "").localeCompare(String(b.slot_code || "")));

      if (!availableSlots.length) {
        availableSlotsStripEl.innerHTML = '<span class="available-slots-empty">No available slots right now.</span>';
        return;
      }

      const visible = availableSlots.slice(0, 18);
      availableSlotsStripEl.innerHTML = `
        <span class="available-slots-label">Available now (${summary.available || availableSlots.length}):</span>
        ${visible.map((slot) => `<button type="button" class="available-slot-pill" data-slot-pill="${slot.slot_code || ""}">${slot.slot_code || "-"}</button>`).join("")}
        ${availableSlots.length > visible.length ? `<span class="available-slots-more">+${availableSlots.length - visible.length} more</span>` : ""}
      `;
    }

    function focusSlotTileByCode(slotCode) {
      if (!slotCode || !parkingSlotsListEl) return;
      const code = normalizeSlotCode(slotCode);
      const tiles = Array.from(parkingSlotsListEl.querySelectorAll(".parking-slot-tile"));
      const target = tiles.find((tile) => normalizeSlotCode(tile.dataset.slotCode) === code);
      if (!target) return;
      target.scrollIntoView({ behavior: "smooth", block: "center" });
      target.classList.add("slot-focus-pulse");
      window.setTimeout(() => target.classList.remove("slot-focus-pulse"), 1200);
    }

    function applyParkingSlotFilters(slots) {
      const source = Array.isArray(slots) ? slots : [];
      const query = String(slotSearchQuery || "").trim().toLowerCase();
      return source.filter((slot) => {
        const occupancy = slot.occupancy || "available";
        if (activeSlotFilter !== "all" && occupancy !== activeSlotFilter) return false;
        if (!query) return true;
        const searchable = [slot.slot_code || "", slot.zone || "", slot.occupied_by_plate || "", slot.occupied_by_name || ""].join(" ").toLowerCase();
        return searchable.includes(query);
      });
    }

    function groupSlotsByZone(slots) {
      return (slots || []).reduce((acc, slot) => {
        const zone = slot.zone || "General";
        if (!acc[zone]) acc[zone] = [];
        acc[zone].push(slot);
        return acc;
      }, {});
    }

    function renderSlotInspectorHistoryItem(item) {
      const parkedAt = item.parked_at || item.scanned_at;
      const stateClass = item.is_ongoing ? "inside" : "exited";
      const stateLabel = item.is_ongoing ? "INSIDE" : "EXITED";
      return `<article class="parking-inspector-history-item ${stateClass}">
        <div class="parking-inspector-history-top">
          <strong>${item.full_name || "Unknown Student"}</strong>
          <span class="parking-inspector-mini-badge ${stateClass}">${stateLabel}</span>
        </div>
        <p>${item.plate_number || "-"} | ${item.student_number || "-"}</p>
        <p>${parkedAt ? toPht(parkedAt) : "-"} | ${item.duration_label || "-"}</p>
      </article>`;
    }

    function renderSlotInspector() {
      if (!slotInspectorTitleEl || !slotInspectorStatusEl || !slotInspectorSubtitleEl || !slotInspectorDetailsEl || !slotInspectorHistoryEl) return;
      const slot = getSelectedSlot();
      if (!slot) {
        slotInspectorTitleEl.textContent = "Not selected";
        slotInspectorStatusEl.textContent = "--";
        slotInspectorStatusEl.className = "parking-inspector-badge";
        slotInspectorSubtitleEl.textContent = "Select a slot to review assignment details and recent parking activity.";
        slotInspectorDetailsEl.innerHTML = '<div class="empty-state" style="padding:0.8rem;"><p>No slot selected.</p></div>';
        slotInspectorHistoryEl.innerHTML = '<div class="empty-state" style="padding:0.8rem;"><p>Select a slot to load recent history.</p></div>';
        if (openSlotHistoryBtnEl) openSlotHistoryBtnEl.disabled = true;
        return;
      }

      const occupancy = slot.occupancy || "available";
      const statusText = occupancy.toUpperCase();
      slotInspectorTitleEl.textContent = slot.slot_code || "-";
      slotInspectorStatusEl.textContent = statusText;
      slotInspectorStatusEl.className = `parking-inspector-badge ${occupancy}`;
      slotInspectorSubtitleEl.textContent = occupancy === "available"
        ? "This slot is open and ready for a new entry assignment."
        : occupancy === "occupied"
          ? "This slot is currently occupied. Review current assignment and activity."
          : "This slot is currently disabled and cannot be assigned.";

      slotInspectorDetailsEl.innerHTML = `
        <div class="parking-inspector-detail"><span>Zone</span><strong>${slot.zone || "General"}</strong></div>
        <div class="parking-inspector-detail"><span>Status</span><strong>${statusText}</strong></div>
        <div class="parking-inspector-detail"><span>Plate</span><strong>${slot.occupied_by_plate || "-"}</strong></div>
        <div class="parking-inspector-detail"><span>Student</span><strong>${slot.occupied_by_name || "-"}</strong></div>
      `;

      if (openSlotHistoryBtnEl) openSlotHistoryBtnEl.disabled = false;
      if (slotInspectorLoading) {
        slotInspectorHistoryEl.innerHTML = '<div class="empty-state" style="padding:0.8rem;"><p>Loading recent history...</p></div>';
        return;
      }
      if (slotInspectorError) {
        slotInspectorHistoryEl.innerHTML = `<div class="flash flash-error" style="margin:0;">${slotInspectorError}</div>`;
        return;
      }
      if (!selectedSlotHistoryRows.length) {
        slotInspectorHistoryEl.innerHTML = '<div class="empty-state" style="padding:0.8rem;"><p>No recent activity for this slot.</p></div>';
        return;
      }
      slotInspectorHistoryEl.innerHTML = selectedSlotHistoryRows.slice(0, 5).map(renderSlotInspectorHistoryItem).join("");
    }

    async function loadSelectedSlotHistory(slotCode, force = false) {
      const normalizedCode = normalizeSlotCode(slotCode);
      if (!normalizedCode) return;
      if (!force && slotHistoryCache.has(normalizedCode)) {
        selectedSlotHistoryRows = slotHistoryCache.get(normalizedCode) || [];
        slotInspectorError = "";
        slotInspectorLoading = false;
        renderSlotInspector();
        return;
      }

      slotInspectorLoading = true;
      slotInspectorError = "";
      renderSlotInspector();
      const requestId = ++slotHistoryRequestId;
      try {
        const resp = await fetch(`/api/parking-slot-history?slot_code=${encodeURIComponent(normalizedCode)}`, { credentials: "same-origin" });
        const data = await resp.json();
        if (!data.ok) throw new Error(data.message || "Unable to load slot history.");
        const rows = Array.isArray(data.rows) ? data.rows : [];
        slotHistoryCache.set(normalizedCode, rows);
        if (requestId !== slotHistoryRequestId || normalizeSlotCode(selectedSlotCode) !== normalizedCode) return;
        selectedSlotHistoryRows = rows;
        slotInspectorError = "";
      } catch (error) {
        if (requestId !== slotHistoryRequestId || normalizeSlotCode(selectedSlotCode) !== normalizedCode) return;
        selectedSlotHistoryRows = [];
        slotInspectorError = error.message || "Unable to load slot history.";
      } finally {
        if (requestId !== slotHistoryRequestId || normalizeSlotCode(selectedSlotCode) !== normalizedCode) return;
        slotInspectorLoading = false;
        renderSlotInspector();
      }
    }

    function renderEmptySlotHistory(message) {
      return `<div class="empty-state" style="padding:1rem;"><p>${message}</p></div>`;
    }

    function renderSlotHistoryCard(item) {
      const parkedAt = item.parked_at || item.scanned_at;
      const exitedAtText = item.exited_at ? toPht(item.exited_at) : "Still parked";
      const durationText = item.duration_label || "-";
      const statusChip = item.is_ongoing
        ? `<span class="badge badge-inside">ONGOING</span>`
        : `<span class="badge badge-soft">COMPLETED</span>`;
      return `<div class="slot-history-card">
        <div class="slot-history-card-head">
          <strong>${item.full_name || "Unknown Student"}</strong>
          <span class="badge badge-soft">${item.parking_slot || "-"}</span>
        </div>
        <div>${statusChip}</div>
        <div class="slot-history-card-meta">Student No: <strong>${item.student_number || "-"}</strong></div>
        <div class="slot-history-card-meta">Plate: <strong>${item.plate_number || "-"}</strong></div>
        <div class="slot-history-card-meta">Entry Gate: <strong>${item.entry_gate || item.gate || "-"}</strong></div>
        <div class="slot-history-card-meta">Parked At: <strong>${parkedAt ? toPht(parkedAt) : "-"}</strong></div>
        <div class="slot-history-card-meta">Exited At: <strong>${exitedAtText}</strong></div>
        <div class="slot-history-card-meta">Duration: <strong>${durationText}</strong></div>
      </div>`;
    }

    function closeSlotHistoryModal() {
      if (!slotHistoryModal) return;
      slotHistoryModal.classList.remove("open");
      slotHistoryModal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
    }

    async function openSlotHistoryModal(slotCode) {
      if (!slotCode || !slotHistoryModal) return;
      slotHistoryModal.classList.add("open");
      slotHistoryModal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");
      if (slotHistoryTitle) slotHistoryTitle.textContent = `Slot ${slotCode} History`;
      if (slotHistoryMeta) slotHistoryMeta.textContent = "Loading slot history...";
      if (slotHistoryList) slotHistoryList.innerHTML = renderEmptySlotHistory("Loading slot history...");

      try {
        const resp = await fetch(`/api/parking-slot-history?slot_code=${encodeURIComponent(slotCode)}`);
        const data = await resp.json();
        if (!data.ok) throw new Error(data.message || "Failed to load slot history.");
        const rows = Array.isArray(data.rows) ? data.rows : [];
        if (slotHistoryList) {
          slotHistoryList.innerHTML = rows.length
            ? rows.map(renderSlotHistoryCard).join("")
            : renderEmptySlotHistory(`No parking history found for slot ${slotCode}.`);
        }
        if (slotHistoryMeta) {
          slotHistoryMeta.textContent = `${rows.length} parking entr${rows.length === 1 ? "y" : "ies"} found for slot ${slotCode}`;
        }
      } catch (error) {
        if (slotHistoryList) slotHistoryList.innerHTML = renderEmptySlotHistory(error.message || "Unable to load slot history.");
        if (slotHistoryMeta) slotHistoryMeta.textContent = error.message || "Unable to load slot history.";
      }
    }

    function attachParkingSlotHandlers() {
      const tiles = Array.from(document.querySelectorAll(".parking-slot-tile"));
      tiles.forEach((tile) => {
        const slotCode = normalizeSlotCode(tile.dataset.slotCode);
        tile.addEventListener("click", () => {
          if (!slotCode) return;
          const changed = slotCode !== normalizeSlotCode(selectedSlotCode);
          selectedSlotCode = slotCode;
          if (changed) {
            selectedSlotHistoryRows = [];
            slotInspectorError = "";
          }
          renderParkingSlotsSection();
        });
      });
    }

    function renderParkingSlotsSection() {
      const summary = normalizeParkingSlotSummary(latestParkingSlotSummary, latestParkingSlots);
      if (slotMetricTotal) slotMetricTotal.textContent = summary.total;
      if (slotMetricAvailable) slotMetricAvailable.textContent = summary.available;
      if (slotMetricOccupied) slotMetricOccupied.textContent = summary.occupied;
      if (slotMetricDisabled) slotMetricDisabled.textContent = summary.disabled;
      updateSlotFilterButtons(summary);
      renderAvailableSlotsStrip(latestParkingSlots, summary);

      const previousSelected = normalizeSlotCode(selectedSlotCode);
      const selectedStillExists = latestParkingSlots.some((slot) => normalizeSlotCode(slot.slot_code) === previousSelected);
      if (!selectedStillExists) {
        const fallback = latestParkingSlots.find((slot) => (slot.occupancy || "available") === "available") || latestParkingSlots[0] || null;
        selectedSlotCode = normalizeSlotCode(fallback?.slot_code || "");
        selectedSlotHistoryRows = [];
        slotInspectorError = "";
      }
      const selectedChanged = normalizeSlotCode(selectedSlotCode) !== previousSelected;

      const filteredSlots = applyParkingSlotFilters(latestParkingSlots);
      if (parkingSlotsMetaEl) {
        parkingSlotsMetaEl.textContent = `${summary.available} available | ${summary.occupied} occupied | ${summary.disabled} disabled | ${summary.total} total | Showing ${filteredSlots.length}`;
      }
      if (parkingSlotsListEl) {
        const emptyMessage = latestParkingSlots.length ? "No slots match the selected filter." : "No parking slots configured.";
        if (!filteredSlots.length) {
          parkingSlotsListEl.innerHTML = renderEmptyParkingSlots(emptyMessage);
        } else {
          const grouped = groupSlotsByZone(filteredSlots);
          const zoneNames = Object.keys(grouped).sort((a, b) => String(a).localeCompare(String(b), undefined, { numeric: true }));
          parkingSlotsListEl.innerHTML = zoneNames.map((zoneName) => {
            const zoneSlots = grouped[zoneName]
              .slice()
              .sort((a, b) => String(a.slot_code || "").localeCompare(String(b.slot_code || ""), undefined, { numeric: true }));
            const zoneAvailable = zoneSlots.filter((slot) => (slot.occupancy || "available") === "available").length;
            return `
              <section class="parking-zone-section">
                <div class="parking-zone-header">
                  <h4>${zoneName}</h4>
                  <span>${zoneAvailable}/${zoneSlots.length} available</span>
                </div>
                <div class="parking-zone-grid">
                  ${zoneSlots.map(renderParkingSlotCard).join("")}
                </div>
              </section>
            `;
          }).join("");
        }
      }

      attachParkingSlotHandlers();
      renderSlotInspector();
      const selectedCode = normalizeSlotCode(selectedSlotCode);
      if (selectedCode && (selectedChanged || !slotHistoryCache.has(selectedCode))) {
        loadSelectedSlotHistory(selectedCode);
      }
    }

    async function refreshSlots() {
      try {
        const resp = await fetch("/api/parking-slot-overview", { credentials: "same-origin" });
        const data = await resp.json();
        if (!data.ok) return;
        latestParkingSlots = Array.isArray(data.slots) ? data.slots : [];
        latestParkingSlotSummary = normalizeParkingSlotSummary(data.summary || {}, latestParkingSlots);
        renderParkingSlotsSection();
        if (lastUpdatedEl) lastUpdatedEl.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
      } catch (error) {
        console.error("Failed to refresh parking slots:", error);
      }
    }

    slotFilterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextFilter = button.dataset.slotFilter || "all";
        if (nextFilter === activeSlotFilter) return;
        activeSlotFilter = nextFilter;
        renderParkingSlotsSection();
      });
    });

    if (parkingSlotSearchEl) {
      parkingSlotSearchEl.addEventListener("input", () => {
        slotSearchQuery = parkingSlotSearchEl.value || "";
        renderParkingSlotsSection();
      });
    }

    if (availableSlotsStripEl) {
      availableSlotsStripEl.addEventListener("click", (event) => {
        const source = event.target instanceof Element ? event.target : null;
        if (!source) return;
        const trigger = source.closest("[data-slot-pill]");
        if (!trigger) return;
        const slotCode = trigger.dataset.slotPill || "";
        if (!slotCode) return;
        activeSlotFilter = "all";
        slotSearchQuery = slotCode;
        selectedSlotCode = normalizeSlotCode(slotCode);
        selectedSlotHistoryRows = [];
        slotInspectorError = "";
        if (parkingSlotSearchEl) parkingSlotSearchEl.value = slotCode;
        renderParkingSlotsSection();
        focusSlotTileByCode(slotCode);
      });
    }

    if (openSlotHistoryBtnEl) {
      openSlotHistoryBtnEl.addEventListener("click", () => {
        const slotCode = normalizeSlotCode(selectedSlotCode);
        if (!slotCode) return;
        openSlotHistoryModal(slotCode);
      });
    }

    if (refreshBtn) refreshBtn.addEventListener("click", refreshSlots);
    if (slotHistoryModal) {
      slotHistoryModal.querySelectorAll("[data-close-slot-history]").forEach((el) => {
        el.addEventListener("click", closeSlotHistoryModal);
      });
    }
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeSlotHistoryModal();
    });

    latestParkingSlotSummary = normalizeParkingSlotSummary(latestParkingSlotSummary, latestParkingSlots);
    renderParkingSlotsSection();
    refreshSlots();
    setInterval(refreshSlots, 20000);
  })();
</script>

